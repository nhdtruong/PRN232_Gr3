@page
@using System.Security.Claims
@model PROJECT_PRN232_.WebApp.Pages.Teacher.MyClassesModel
@{
    ViewData["Title"] = "Lớp học của tôi";
}

<div class="container-fluid py-4" style="max-width: 1200px;">
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h1 class="fw-bold text-dark mb-1" style="font-size: 1.85rem;">📚 Lớp học của tôi</h1>
            <p class="text-muted mb-0">Danh sách các lớp học bạn đang phụ trách giảng dạy.</p>
        </div>
    </div>

    <!-- Top Alert Messages Container -->
    <div id="alertContainer"></div>

    <div class="row g-4">
        @if (Model.MyClasses.Count == 0)
        {
            <div class="col-12 text-center py-5 text-muted">
                <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                <p>Bạn chưa được phân công giảng dạy lớp nào.</p>
            </div>
        }
        else
        {
            @foreach (var c in Model.MyClasses)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100 position-relative overflow-hidden">
                        <div class="card-header bg-white border-bottom-0 pt-4 pb-2 px-4 d-flex justify-content-between align-items-center">
                            <span class="badge bg-primary-subtle text-primary border rounded-pill px-3 py-1">@c.Subject</span>
                            <span class="text-muted small"><i class="bi bi-people me-1"></i> Tối đa @c.MaxCapacity hs</span>
                        </div>
                        <div class="card-body px-4">
                            <h5 class="fw-bold mb-1">@c.ClassName</h5>
                            <p class="text-muted small mb-3">Mã lớp: CLS-@c.Id</p>
                            
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <div class="d-flex align-items-center text-secondary small">
                                    <i class="bi bi-journal-bookmark me-1"></i> @c.TotalLessons buổi
                                </div>
                                <div class="d-flex align-items-center text-success small fw-semibold">
                                    <i class="bi bi-check-circle me-1"></i> Đang hoạt động
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-light border-top-0 p-3 text-center">
                            <button type="button" class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-semibold w-100" 
                                onclick="openTransferModal(@c.Id, '@c.ClassName')" data-bs-toggle="modal" data-bs-target="#transferModal">
                                <i class="bi bi-arrow-left-right me-1"></i> Xin đổi lớp
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- Modal Xin đổi lớp -->
<div class="modal fade" id="transferModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header border-bottom px-4 py-3">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-arrow-left-right text-danger me-2"></i> Đơn xin đổi lớp</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="transferForm">
                <div class="modal-body p-4 bg-light">
                    <div class="form-error-container"></div>
                    
                    <input type="hidden" id="transferClassId" />
                    
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-muted small">Lớp học</label>
                        <input type="text" id="transferClassName" class="form-control fw-bold" readonly disabled />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-muted small">Đổi cho giáo viên (*)</label>
                        <select class="form-select" id="transferToTeacherId" required>
                            <option value="" selected disabled>-- Chọn giáo viên --</option>
                            @foreach (var t in Model.OtherTeachers)
                            {
                                <option value="@t.Id">@t.FullName (@t.Username)</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-muted small">Lý do xin đổi (*)</label>
                        <textarea class="form-control" id="transferReason" rows="3" placeholder="Nhập lý do chi tiết..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer px-4 py-3 border-top bg-white">
                    <button type="button" class="btn btn-light rounded-3 px-4 fw-semibold border" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger rounded-3 px-4 fw-semibold">Gửi yêu cầu</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const teacherId = @User.FindFirstValue(ClaimTypes.NameIdentifier);

        function openTransferModal(classId, className) {
            document.getElementById('transferClassId').value = classId;
            document.getElementById('transferClassName').value = className;
            document.getElementById('transferToTeacherId').value = '';
            document.getElementById('transferReason').value = '';
            $('.form-error-container').html('');
        }

        document.getElementById('transferForm').addEventListener('submit', function (e) {
            e.preventDefault();
            
            const classId = parseInt(document.getElementById('transferClassId').value);
            const toTeacherId = parseInt(document.getElementById('transferToTeacherId').value);
            const reason = document.getElementById('transferReason').value;

            const bodyData = {
                classId: classId,
                fromTeacherId: parseInt(teacherId),
                toTeacherId: toTeacherId,
                reason: reason
            };

            fetch('/api/classtransfer', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(bodyData)
            })
            .then(async res => {
                if (!res.ok) {
                    const err = await res.json();
                    throw new Error(err.message || "Có lỗi xảy ra khi gửi yêu cầu.");
                }
            })
            .then(() => {
                bootstrap.Modal.getInstance(document.getElementById('transferModal')).hide();
                showAlert("Đã gửi yêu cầu đổi lớp thành công! Vui lòng chờ Admin phê duyệt.", "success");
            })
            .catch(err => {
                $('.form-error-container').html(`
                    <div class="alert alert-danger py-2 mb-3 small"><i class="bi bi-exclamation-triangle-fill me-1"></i> ${err.message}</div>
                `);
            });
        });

        function showAlert(message, type) {
            const container = document.getElementById('alertContainer');
            container.innerHTML = `
                <div class="alert alert-${type} alert-dismissible fade show rounded-3 shadow-sm border-0 mb-4" role="alert">
                    <i class="bi ${type === 'success' ? 'bi-check-circle-fill' : 'bi-info-circle-fill'} me-2"></i> ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;
            setTimeout(() => {
                $(`.alert`).alert('close');
            }, 5000);
        }
    </script>
}
