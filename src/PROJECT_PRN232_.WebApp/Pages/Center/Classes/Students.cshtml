@page
@model PROJECT_PRN232_.WebApp.Pages.Center.Classes.StudentsModel
@{
    ViewData["Title"] = "Thành viên lớp học - EduBridge";
}

<!-- Custom style rules for premium checkboxes and layouts -->
<style>
    :root {
        --eb-indigo-gradient: linear-gradient(135deg, #4F46E5, #7C3AED);
        --eb-indigo-hover: #4338CA;
        --eb-indigo-light: #EEF2FF;
        --eb-indigo-border: #E0E7FF;
        --eb-text-dark: #1E293B;
        --eb-text-muted: #64748B;
        --eb-bg-light: #F8FAFC;
    }

    .eb-card {
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid var(--eb-indigo-border);
        box-shadow: 0 4px 20px rgba(79, 70, 229, 0.04);
        padding: 24px;
        margin-bottom: 24px;
    }

    .eb-table {
        width: 100%;
        margin-bottom: 0;
        border-collapse: separate;
        border-spacing: 0;
    }

    .eb-table th {
        background: #F1F5F9;
        color: var(--eb-text-dark);
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 12px 16px;
        border-bottom: 2px solid #E2E8F0;
    }

    .eb-table td {
        padding: 14px 16px;
        vertical-align: middle;
        border-bottom: 1px solid #F1F5F9;
        color: var(--eb-text-dark);
        font-size: 0.92rem;
    }

    .eb-table tr:hover td {
        background-color: #F8FAFC;
    }

    .eb-btn-primary {
        background: var(--eb-indigo-gradient);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 600;
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 12px rgba(79, 70, 229, 0.2);
        transition: all 0.25s ease;
        text-decoration: none;
    }

    .eb-btn-primary:hover {
        background: var(--eb-indigo-hover);
        color: #fff;
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(79, 70, 229, 0.3);
    }

    .eb-btn-outline {
        border: 1px solid #CBD5E1;
        background: #fff;
        color: var(--eb-text-dark);
        border-radius: 10px;
        padding: 8px 16px;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.25s ease;
    }

    .eb-btn-outline:hover {
        background: var(--eb-bg-light);
        border-color: #94A3B8;
    }

    .form-control {
        border: 1px solid #CBD5E1;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 0.9rem;
    }

    /* Custom Checkbox Design */
    .custom-checkbox-wrapper {
        display: inline-flex;
        align-items: center;
        cursor: pointer;
    }

    .custom-checkbox-wrapper input[type="checkbox"] {
        display: none;
    }

    .custom-checkbox {
        width: 20px;
        height: 20px;
        border: 2px solid #CBD5E1;
        border-radius: 6px;
        margin-right: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        background: #fff;
    }

    .custom-checkbox-wrapper input[type="checkbox"]:checked + .custom-checkbox {
        background: #4F46E5;
        border-color: #4F46E5;
    }

    .custom-checkbox-wrapper input[type="checkbox"]:checked + .custom-checkbox::after {
        content: "\F272"; /* bootstrap-icons check icon code */
        font-family: "bootstrap-icons";
        color: #fff;
        font-size: 0.8rem;
        font-weight: bold;
    }
</style>

<div class="container-fluid py-4" style="max-width: 1400px;">
    <!-- Breadcrumbs -->
    <div class="mb-3">
        <a asp-page="/Center/Classes/Index" class="text-decoration-none small text-muted">
            <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách lớp học
        </a>
    </div>

    <!-- Title Header -->
    <div class="mb-4">
        <h1 class="fw-bold text-dark mb-1" style="font-size: 1.85rem;">
            👥 Thành viên lớp: <span class="text-primary">@Model.ClassInfo.ClassName</span>
        </h1>
        <p class="text-muted mb-0">Quản lý xếp lớp, chuyển lớp hoặc rút tên học viên ra khỏi lớp học.</p>
    </div>

    <!-- Alerts -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm border-0 mb-4" role="alert" style="background-color: #DCFCE7; color: #15803D;">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm border-0 mb-4" role="alert" style="background-color: #FEE2E2; color: #B91C1C;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <!-- LEFT: ENROLLED STUDENTS LIST -->
        <div class="col-lg-7">
            <div class="eb-card p-0 overflow-hidden" style="border-radius: 12px;">
                <div class="p-4 border-bottom">
                    <h5 class="fw-bold text-dark mb-1">Danh sách học viên đang theo học</h5>
                    <p class="text-muted small mb-0">Hiện tại có <strong>@Model.EnrolledStudents.Count()</strong> học viên đang ở trong lớp này.</p>
                </div>
                
                @if (!Model.EnrolledStudents.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-people-fill text-secondary opacity-50 display-6 d-block mb-3"></i>
                        <p class="mb-0 fw-semibold">Chưa có học viên nào trong lớp này.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="eb-table">
                            <thead>
                                <tr>
                                    <th class="text-center" style="width: 60px;">STT</th>
                                    <th>Họ và Tên</th>
                                    <th>Ngày sinh</th>
                                    <th>Giới tính</th>
                                    <th class="text-center" style="width: 200px;">Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ int enrolledIdx = 1; }
                                @foreach (var s in Model.EnrolledStudents)
                                {
                                    <tr>
                                        <td class="text-center text-muted fw-semibold">@enrolledIdx</td>
                                        <td>
                                            <div class="fw-bold" style="color: var(--eb-text-dark);">@s.FullName</div>
                                            <span class="text-muted small">Mã số: #@s.Id</span>
                                        </td>
                                        <td class="small text-muted">@(s.DateOfBirth?.ToString("dd/MM/yyyy") ?? "-")</td>
                                        <td>
                                            <span class="badge bg-light text-dark border px-2 py-1">@(s.Gender ?? "-")</span>
                                        </td>
                                        <td class="text-center">
                                            <div class="d-inline-flex gap-2">
                                                <button class="eb-btn-outline py-1 px-3" onclick="openTransferModal(@s.Id, '@s.FullName')" data-bs-toggle="modal" data-bs-target="#transferModal">
                                                    <i class="bi bi-arrow-left-right me-1"></i> Chuyển lớp
                                                </button>
                                                <form method="post" asp-page-handler="Remove" asp-route-studentId="@s.Id" onsubmit="return confirm('Bạn có chắc chắn muốn xóa học sinh @s.FullName khỏi lớp này?');" style="display:inline;">
                                                    <input type="hidden" asp-for="ClassId" />
                                                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-3 py-1 px-3 fw-semibold">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                    enrolledIdx++;
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- RIGHT: AVAILABLE STUDENTS LIST (TICK TO ENROLL MULTI) -->
        <div class="col-lg-5">
            <div class="eb-card">
                <div class="mb-3 d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold text-dark mb-1">Xếp học viên vào lớp</h5>
                        <p class="text-muted small mb-0">Tích chọn các học sinh dưới đây để xếp vào lớp này.</p>
                    </div>
                </div>

                <form method="post" asp-page-handler="EnrollMulti">
                    <input type="hidden" asp-for="ClassId" />

                    <!-- Search filter in available list -->
                    <div class="mb-3">
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0" style="border-radius: 10px 0 0 10px;"><i class="bi bi-search"></i></span>
                            <input type="text" id="searchAvailableInput" class="form-control border-start-0" placeholder="Tìm nhanh học viên..." style="border-radius: 0 10px 10px 0;">
                        </div>
                    </div>

                    <!-- Master checkbox selection -->
                    <div class="mb-2 p-2 bg-light rounded-3 d-flex align-items-center justify-content-between">
                        <label class="custom-checkbox-wrapper mb-0 fw-semibold text-dark small">
                            <input type="checkbox" id="checkAllStudents" onclick="toggleSelectAll(this)" />
                            <span class="custom-checkbox"></span>
                            <span>Chọn tất cả học sinh hiển thị</span>
                        </label>
                        <span class="badge bg-primary rounded-pill" id="selectedCounter">Đã chọn: 0</span>
                    </div>

                    <!-- List of students with scrollbar -->
                    <div class="border rounded-4 overflow-y-auto mb-3" style="max-height: 400px; background-color: var(--eb-bg-light);">
                        @if (!Model.AvailableStudents.Any())
                        {
                            <div class="text-center py-5 text-muted">
                                <i class="bi bi-person-check-fill opacity-50 display-6 d-block mb-2"></i>
                                <p class="mb-0 small fw-semibold">Tất cả học viên đã được xếp vào lớp học này.</p>
                            </div>
                        }
                        else
                        {
                            <div class="list-group list-group-flush" id="availableStudentsList">
                                @foreach (var s in Model.AvailableStudents)
                                {
                                    <div class="list-group-item available-student-item d-flex align-items-center justify-content-between p-3" data-name="@s.FullName.ToLower()" data-id="@s.Id">
                                        <label class="custom-checkbox-wrapper mb-0 flex-grow-1">
                                            <input type="checkbox" name="SelectedStudentIds" value="@s.Id" class="student-checkbox" onclick="updateCounter()" />
                                            <span class="custom-checkbox"></span>
                                            <div>
                                                <strong class="text-dark d-block">@s.FullName</strong>
                                                <span class="text-muted small">Mã số: #@s.Id | Giới tính: @(s.Gender ?? "-")</span>
                                            </div>
                                        </label>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <button type="submit" class="eb-btn-primary w-100 justify-content-center py-2.5">
                        <i class="bi bi-user-plus me-1"></i> Xếp lớp học viên đã chọn
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- TRANSFER MODAL -->
<div class="modal fade" id="transferModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="transferTitle" style="color: var(--eb-text-dark);">Chuyển Lớp</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="Transfer" id="transferForm">
                <input type="hidden" asp-for="ClassId" />
                <input type="hidden" asp-for="StudentId" id="transferStudentId" />
                
                <div class="modal-body py-3">
                    <div class="mb-3">
                        <label asp-for="TargetClassId" class="form-label fw-semibold text-muted small">Chọn lớp học mới (Đang hoạt động)</label>
                        <select asp-for="TargetClassId" class="form-select" required>
                            @foreach (var c in Model.ActiveClasses)
                            {
                                <option value="@c.Id">@c.ClassName (ID: @c.Id)</option>
                            }
                        </select>
                        <span asp-validation-for="TargetClassId" class="text-danger small"></span>
                    </div>
                </div>
                
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="eb-btn-outline py-2" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="eb-btn-primary py-2">Xác nhận chuyển</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openTransferModal(studentId, studentName) {
            document.getElementById('transferStudentId').value = studentId;
            document.getElementById('transferTitle').textContent = `Chuyển lớp cho học viên: ${studentName}`;
        }

        function toggleSelectAll(masterCheckbox) {
            const visibleCheckboxes = $('.available-student-item:visible .student-checkbox');
            visibleCheckboxes.prop('checked', masterCheckbox.checked);
            updateCounter();
        }

        function updateCounter() {
            const checkedCount = $('.student-checkbox:checked').length;
            document.getElementById('selectedCounter').textContent = `Đã chọn: ${checkedCount}`;
        }

        // Live search filter for available students
        document.getElementById('searchAvailableInput').addEventListener('input', function(e) {
            const query = e.target.value.toLowerCase().trim();
            
            $('.available-student-item').each(function() {
                const item = $(this);
                const sName = item.data('name');
                const sId = item.data('id').toString();

                if (sName.includes(query) || sId.includes(query)) {
                    item.show();
                } else {
                    item.hide();
                    // Uncheck hidden checkboxes
                    item.find('.student-checkbox').prop('checked', false);
                }
            });

            // Reset select all state on search filter change
            document.getElementById('checkAllStudents').checked = false;
            updateCounter();
        });
    </script>
}
