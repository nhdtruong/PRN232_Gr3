@page
@model PROJECT_PRN232_.WebApp.Pages.Center.Classes.StudentsModel
@{
    ViewData["Title"] = "Thành viên lớp học - EduBridge";
}

<!-- Custom style rules for premium checkboxes and layouts -->
<style>
    :root {
        --eb-indigo-gradient: linear-gradient(135deg, #4F46E5, #7C3AED);
        --eb-indigo-hover: #4338CA;
        --eb-indigo-light: #EEF2FF;
        --eb-indigo-border: #E0E7FF;
        --eb-text-dark: #1E293B;
        --eb-text-muted: #64748B;
        --eb-bg-light: #F8FAFC;
    }

    .eb-card {
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid var(--eb-indigo-border);
        box-shadow: 0 4px 20px rgba(79, 70, 229, 0.04);
        padding: 24px;
        margin-bottom: 24px;
    }

    .eb-table {
        width: 100%;
        margin-bottom: 0;
        border-collapse: separate;
        border-spacing: 0;
    }

    .eb-table th {
        background: #F1F5F9;
        color: var(--eb-text-dark);
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 12px 16px;
        border-bottom: 2px solid #E2E8F0;
    }

    .eb-table td {
        padding: 14px 16px;
        vertical-align: middle;
        border-bottom: 1px solid #F1F5F9;
        color: var(--eb-text-dark);
        font-size: 0.92rem;
    }

    .eb-table tr:hover td {
        background-color: #F8FAFC;
    }

    .eb-btn-primary {
        background: var(--eb-indigo-gradient);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 600;
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 12px rgba(79, 70, 229, 0.2);
        transition: all 0.25s ease;
        text-decoration: none;
    }

    .eb-btn-primary:hover {
        background: var(--eb-indigo-hover);
        color: #fff;
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(79, 70, 229, 0.3);
    }

    .eb-btn-outline {
        border: 1px solid #CBD5E1;
        background: #fff;
        color: var(--eb-text-dark);
        border-radius: 10px;
        padding: 8px 16px;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.25s ease;
    }

    .eb-btn-outline:hover {
        background: var(--eb-bg-light);
        border-color: #94A3B8;
    }

    .form-control {
        border: 1px solid #CBD5E1;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 0.9rem;
    }

    /* Custom Checkbox Design */
    .custom-checkbox-wrapper {
        display: inline-flex;
        align-items: center;
        cursor: pointer;
    }

    .custom-checkbox-wrapper input[type="checkbox"] {
        display: none;
    }

    .custom-checkbox {
        width: 20px;
        height: 20px;
        border: 2px solid #CBD5E1;
        border-radius: 6px;
        margin-right: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        background: #fff;
    }

    .custom-checkbox-wrapper input[type="checkbox"]:checked + .custom-checkbox {
        background: #4F46E5;
        border-color: #4F46E5;
    }

    .custom-checkbox-wrapper input[type="checkbox"]:checked + .custom-checkbox::after {
        content: "\F272"; /* bootstrap-icons check icon code */
        font-family: "bootstrap-icons";
        color: #fff;
        font-size: 0.8rem;
        font-weight: bold;
    }
</style>

<div class="container-fluid py-4" style="max-width: 1400px;">
    <!-- Breadcrumbs -->
    <div class="mb-3">
        <a href="/Center/Classes/Index" class="text-decoration-none small text-muted">
            <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách lớp học
        </a>
    </div>

    <!-- Title Header -->
    <div class="mb-4">
        <h1 class="fw-bold text-dark mb-1" style="font-size: 1.85rem;">
            👥 Thành viên lớp: <span class="text-primary" id="classTitleName">Đang tải...</span>
        </h1>
        <p class="text-muted mb-0">Quản lý xếp lớp, chuyển lớp hoặc rút tên học viên ra khỏi lớp học.</p>
    </div>

    <!-- Top Alert Messages Container -->
    <div id="alertContainer"></div>

    <div class="row g-4">
        <!-- LEFT: ENROLLED STUDENTS LIST -->
        <div class="col-lg-7">
            <div class="eb-card p-0 overflow-hidden" style="border-radius: 12px;">
                <div class="p-4 border-bottom">
                    <h5 class="fw-bold text-dark mb-1">Danh sách học viên đang theo học</h5>
                    <p class="text-muted small mb-0">Hiện tại có <strong id="enrolledCount">0</strong> học viên đang ở trong lớp này.</p>
                </div>
                
                <div id="enrolledSection">
                    <div class="table-responsive">
                        <table class="eb-table">
                            <thead>
                                <tr>
                                    <th class="text-center" style="width: 60px;">STT</th>
                                    <th>Họ và Tên</th>
                                    <th>Ngày sinh</th>
                                    <th>Giới tính</th>
                                    <th class="text-center" style="width: 200px;">Hành động</th>
                                </tr>
                            </thead>
                            <tbody id="enrolledStudentsList">
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        <div class="spinner-border text-primary" role="status">
                                            <span class="visually-hidden">Đang tải...</span>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT: AVAILABLE STUDENTS LIST -->
        <div class="col-lg-5">
            <div class="eb-card">
                <div class="mb-3 d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold text-dark mb-1">Xếp học viên vào lớp</h5>
                        <p class="text-muted small mb-0">Tích chọn các học sinh dưới đây để xếp vào lớp này.</p>
                    </div>
                    <div>
                        <button type="button" class="btn btn-sm text-white px-3 fw-semibold shadow-sm rounded-pill" style="background: var(--eb-indigo-gradient);" data-bs-toggle="modal" data-bs-target="#createStudentModal">
                            <i class="bi bi-person-plus-fill me-1"></i> Thêm mới
                        </button>
                    </div>
                </div>

                <form id="enrollMultiForm" novalidate>
                    <!-- Search filter in available list -->
                    <div class="mb-3">
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0" style="border-radius: 10px 0 0 10px;"><i class="bi bi-search"></i></span>
                            <input type="text" id="searchAvailableInput" class="form-control border-start-0" placeholder="Tìm nhanh học viên..." style="border-radius: 0 10px 10px 0;">
                        </div>
                    </div>

                    <!-- Master checkbox selection -->
                    <div class="mb-2 p-2 bg-light rounded-3 d-flex align-items-center justify-content-between">
                        <label class="custom-checkbox-wrapper mb-0 fw-semibold text-dark small">
                            <input type="checkbox" id="checkAllStudents" onclick="toggleSelectAll(this)" />
                            <span class="custom-checkbox"></span>
                            <span>Chọn tất cả học sinh hiển thị</span>
                        </label>
                        <span class="badge bg-primary rounded-pill" id="selectedCounter">Đã chọn: 0</span>
                    </div>

                    <!-- List of students with scrollbar -->
                    <div class="border rounded-4 overflow-y-auto mb-3" style="max-height: 400px; background-color: var(--eb-bg-light);" id="availableStudentsContainer">
                        <div class="list-group list-group-flush" id="availableStudentsList">
                            <!-- Available students loaded here -->
                        </div>
                    </div>

                    <button type="submit" class="eb-btn-primary w-100 justify-content-center py-2.5">
                        <i class="bi bi-user-plus me-1"></i> Xếp lớp học viên đã chọn
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- TRANSFER MODAL -->
<div class="modal fade" id="transferModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="transferTitle" style="color: var(--eb-text-dark);">Chuyển Lớp</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="transferForm" novalidate>
                <input type="hidden" id="transferStudentId" />
                
                <div class="modal-body py-3">
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-muted small">Chọn lớp học mới (Đang hoạt động)</label>
                        <select id="targetClassIdSelect" class="form-select" required>
                            <!-- Target classes loaded here -->
                        </select>
                    </div>
                </div>
                
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="eb-btn-outline py-2" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="eb-btn-primary py-2">Xác nhận chuyển</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Create Student Modal -->
<div class="modal fade" id="createStudentModal" tabindex="-1" aria-labelledby="createStudentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header border-0 bg-light py-3">
                <h5 class="modal-title fw-bold text-dark" id="createStudentModalLabel">
                    <i class="bi bi-person-plus-fill text-primary me-2"></i>Thêm Học sinh mới vào lớp
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="createStudentAndEnrollForm" novalidate>
                <div class="modal-body p-4">
                    <div class="create-student-error-container"></div>
                    <h6 class="fw-bold text-dark border-bottom pb-2 mb-3">1. Thông tin Học sinh</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted small">Họ và Tên (*)</label>
                            <input type="text" id="newStudentFullName" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted small">Ngày sinh (*)</label>
                            <input type="date" id="newStudentDob" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted small">Giới tính</label>
                            <select id="newStudentGender" class="form-select">
                                <option value="">Chọn giới tính</option>
                                <option value="Male">Nam</option>
                                <option value="Female">Nữ</option>
                            </select>
                        </div>
                    </div>

                    <h6 class="fw-bold text-dark border-bottom pb-2 mb-3">2. Thông tin Phụ huynh</h6>
                    <div class="mb-3">
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="isNewParentRadio" value="false" id="oldParentRadio" checked onchange="toggleParentForm()">
                            <label class="form-check-label" for="oldParentRadio">Chọn phụ huynh có sẵn</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="isNewParentRadio" value="true" id="newParentRadio" onchange="toggleParentForm()">
                            <label class="form-check-label" for="newParentRadio">Tạo phụ huynh mới</label>
                        </div>
                    </div>

                    <!-- Select Existing Parent -->
                    <div id="existingParentSection">
                        <label class="form-label fw-semibold text-muted small">Chọn Phụ huynh (*)</label>
                        <select class="form-select" id="existingParentSelect">
                            <option value="" selected disabled>-- Chọn phụ huynh --</option>
                        </select>
                    </div>

                    <!-- Create New Parent Form -->
                    <div id="newParentSection" class="d-none bg-light p-3 rounded-3 mt-2">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small">Họ và tên Phụ huynh (*)</label>
                                <input type="text" class="form-control" id="npFullName" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small">Tên đăng nhập (*)</label>
                                <input type="text" class="form-control" id="npUsername" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small">Mật khẩu (*)</label>
                                <input type="password" class="form-control" id="npPassword" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small">Số điện thoại</label>
                                <input type="text" class="form-control" id="npPhone" />
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-semibold text-muted small">Email</label>
                                <input type="email" class="form-control" id="npEmail" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 py-3 bg-light">
                    <button type="button" class="btn btn-secondary px-4 rounded-pill" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn text-white px-4 rounded-pill shadow-sm" style="background: var(--eb-indigo-gradient);">
                        <i class="bi bi-person-check-fill me-1"></i> Thêm và Xếp lớp
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        const classId = @Model.ClassId;
        let enrolledIds = [];

        function toggleParentForm() {
            const isNew = document.getElementById('newParentRadio').checked;
            document.getElementById('existingParentSection').classList.toggle('d-none', isNew);
            document.getElementById('newParentSection').classList.toggle('d-none', !isNew);
        }

        function loadClassInfo() {
            fetch(`/api/center/classes/${classId}`)
                .then(res => {
                    if (!res.ok) throw new Error("Không tìm thấy thông tin lớp học.");
                    return res.json();
                })
                .then(c => {
                    document.getElementById('classTitleName').textContent = c.className;
                })
                .catch(err => {
                    console.error(err);
                    document.getElementById('classTitleName').textContent = "Không rõ";
                });
        }

        function loadMembers() {
            // Load enrolled students
            fetch(`/api/center/classes/${classId}/students`)
                .then(res => {
                    if (!res.ok) throw new Error("Lỗi tải thành viên lớp.");
                    return res.json();
                })
                .then(enrolledList => {
                    const tbody = document.getElementById('enrolledStudentsList');
                    document.getElementById('enrolledCount').textContent = enrolledList.length;
                    enrolledIds = enrolledList.map(s => s.id);

                    if (enrolledList.length === 0) {
                        tbody.innerHTML = `
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="bi bi-people-fill text-secondary opacity-50 display-6 d-block mb-3"></i>
                                    <p class="mb-0 fw-semibold">Chưa có học viên nào trong lớp này.</p>
                                </td>
                            </tr>
                        `;
                    } else {
                        let html = '';
                        enrolledList.forEach((s, idx) => {
                            const dobStr = s.dateOfBirth ? new Date(s.dateOfBirth).toLocaleDateString('vi-VN') : '-';
                            html += `
                                <tr>
                                    <td class="text-center text-muted fw-semibold">${idx + 1}</td>
                                    <td>
                                        <div class="fw-bold" style="color: var(--eb-text-dark);">${s.fullName}</div>
                                        <span class="text-muted small">Mã số: #${s.id}</span>
                                    </td>
                                    <td class="small text-muted">${dobStr}</td>
                                    <td>
                                        <span class="badge bg-light text-dark border px-2 py-1">${s.gender || "-"}</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="d-inline-flex gap-2">
                                            <button class="eb-btn-outline py-1 px-3" onclick="openTransferModal(${s.id}, '${s.fullName}')" data-bs-toggle="modal" data-bs-target="#transferModal">
                                                <i class="bi bi-arrow-left-right me-1"></i> Chuyển lớp
                                            </button>
                                            <button class="btn btn-outline-danger btn-sm rounded-3 py-1 px-3 fw-semibold" onclick="removeStudent(${s.id}, '${s.fullName}')">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            `;
                        });
                        tbody.innerHTML = html;
                    }

                    // Once enrolled list is loaded, reload available list to filter out enrolled students
                    loadAvailableStudents();
                })
                .catch(err => {
                    document.getElementById('enrolledStudentsList').innerHTML = `
                        <tr>
                            <td colspan="5" class="text-center py-5 text-danger">
                                <i class="bi bi-exclamation-triangle fs-3 d-block mb-2"></i> ${err.message}
                            </td>
                        </tr>
                    `;
                });
        }

        function loadAvailableStudents() {
            fetch('/api/center/students')
                .then(res => {
                    if (!res.ok) throw new Error("Không thể tải danh sách học viên.");
                    return res.json();
                })
                .then(allStudents => {
                    // Filter out enrolled students
                    const available = allStudents.filter(s => !enrolledIds.includes(s.id));
                    const container = document.getElementById('availableStudentsList');
                    document.getElementById('checkAllStudents').checked = false;
                    updateCounter();

                    if (available.length === 0) {
                        container.innerHTML = `
                            <div class="text-center py-5 text-muted">
                                <i class="bi bi-person-check-fill opacity-50 display-6 d-block mb-2"></i>
                                <p class="mb-0 small fw-semibold">Tất cả học viên đã được xếp vào lớp học này.</p>
                            </div>
                        `;
                    } else {
                        let html = '';
                        available.forEach(s => {
                            html += `
                                <div class="list-group-item available-student-item d-flex align-items-center justify-content-between p-3" data-name="${s.fullName.toLowerCase()}" data-id="${s.id}">
                                    <label class="custom-checkbox-wrapper mb-0 flex-grow-1">
                                        <input type="checkbox" value="${s.id}" class="student-checkbox" onclick="updateCounter()" />
                                        <span class="custom-checkbox"></span>
                                        <div>
                                            <strong class="text-dark d-block">${s.fullName}</strong>
                                            <span class="text-muted small">Mã số: #${s.id} | Giới tính: ${s.gender || "-"}</span>
                                        </div>
                                    </label>
                                </div>
                            `;
                        });
                        container.innerHTML = html;
                    }
                })
                .catch(err => {
                    console.error("Lỗi tải học sinh khả dụng:", err);
                    document.getElementById('availableStudentsList').innerHTML = `
                        <div class="text-center py-5 text-danger">${err.message}</div>
                    `;
                });
        }

        function loadParents() {
            fetch('/api/center/parents')
                .then(res => {
                    if (!res.ok) throw new Error("Không thể tải phụ huynh.");
                    return res.json();
                })
                .then(parents => {
                    const select = document.getElementById('existingParentSelect');
                    select.innerHTML = '<option value="" selected disabled>-- Chọn phụ huynh --</option>';
                    parents.forEach(p => {
                        const opt = document.createElement('option');
                        opt.value = p.id;
                        opt.textContent = `${p.fullName} (${p.username}) - ${p.phone || 'Chưa có SĐT'}`;
                        select.appendChild(opt);
                    });
                })
                .catch(err => console.error("Lỗi tải phụ huynh:", err));
        }

        function loadActiveClasses() {
            fetch('/api/center/classes')
                .then(res => {
                    if (!res.ok) throw new Error("Không thể tải lớp học.");
                    return res.json();
                })
                .then(classes => {
                    const select = document.getElementById('targetClassIdSelect');
                    select.innerHTML = '';
                    const activeClasses = classes.filter(c => c.status === 'Active' && c.id !== classId);
                    activeClasses.forEach(c => {
                        const opt = document.createElement('option');
                        opt.value = c.id;
                        opt.textContent = `${c.className} (ID: ${c.id})`;
                        select.appendChild(opt);
                    });
                })
                .catch(err => console.error("Lỗi tải lớp hoạt động:", err));
        }

        function removeStudent(studentId, studentName) {
            if (!confirm(`Bạn có chắc chắn muốn xóa học sinh ${studentName} khỏi lớp này?`)) return;

            fetch(`/api/center/classes/${classId}/students/${studentId}`, {
                method: 'DELETE'
            })
            .then(async res => {
                const data = await res.json();
                if (!res.ok) throw new Error(data.message || "Không thể rút tên học sinh.");
                return data;
            })
            .then(data => {
                showAlert(data.message, "success");
                loadMembers();
            })
            .catch(err => {
                showAlert(err.message, "danger");
            });
        }

        function openTransferModal(studentId, studentName) {
            document.getElementById('transferStudentId').value = studentId;
            document.getElementById('transferTitle').textContent = `Chuyển lớp cho học viên: ${studentName}`;
        }

        // Handle Transfer Submit
        document.getElementById('transferForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const studentId = document.getElementById('transferStudentId').value;
            const targetId = document.getElementById('targetClassIdSelect').value;

            if (!targetId) {
                alert("Vui lòng chọn lớp học mục tiêu.");
                return;
            }

            fetch(`/api/center/students/${studentId}/transfer-class`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    fromClassId: classId,
                    toClassId: parseInt(targetId)
                })
            })
            .then(async res => {
                const data = await res.json();
                if (!res.ok) throw new Error(data.message || "Lỗi chuyển lớp.");
                return data;
            })
            .then(data => {
                bootstrap.Modal.getInstance(document.getElementById('transferModal')).hide();
                showAlert(data.message, "success");
                loadMembers();
            })
            .catch(err => {
                alert(err.message);
            });
        });

        // Handle Enroll Multi Submit
        document.getElementById('enrollMultiForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const checkedBoxes = document.querySelectorAll('.student-checkbox:checked');
            if (checkedBoxes.length === 0) {
                alert("Vui lòng chọn ít nhất một học sinh từ danh sách để xếp lớp!");
                return;
            }

            const promises = Array.from(checkedBoxes).map(box => {
                const studentId = parseInt(box.value);
                return fetch(`/api/center/classes/${classId}/students`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ studentId: studentId })
                }).then(async res => {
                    const data = await res.json();
                    return { ok: res.ok, message: data.message, id: studentId };
                });
            });

            Promise.all(promises)
                .then(results => {
                    const successes = results.filter(r => r.ok);
                    const failures = results.filter(r => !r.ok);

                    if (successes.length > 0) {
                        showAlert(`Đã xếp lớp thành công cho ${successes.length} học sinh!`, "success");
                    }
                    if (failures.length > 0) {
                        const failDetails = failures.map(f => `Học sinh ID ${f.id}: ${f.message}`).join('<br>');
                        showAlert(`Có ${failures.length} học sinh xếp lớp thất bại:<br>${failDetails}`, "danger");
                    }
                    loadMembers();
                })
                .catch(err => {
                    showAlert("Có lỗi hệ thống xảy ra khi xếp lớp.", "danger");
                });
        });

        // Handle Create Student and Enroll Submit
        document.getElementById('createStudentAndEnrollForm').addEventListener('submit', function(e) {
            e.preventDefault();
            $('.create-student-error-container').html('');

            const fullName = document.getElementById('newStudentFullName').value.trim();
            const dateOfBirth = document.getElementById('newStudentDob').value;
            const gender = document.getElementById('newStudentGender').value || null;
            const isNewParent = document.getElementById('newParentRadio').checked;

            const clientErrors = [];

            if (!fullName) {
                clientErrors.push("Họ và tên học sinh không được để trống.");
            } else if (!/^[a-zA-ZÀÁÂÃÈÉÊÌÍÒÓÔÕÙÚĂĐĨŨƠàáâãèéêìíòóôõùúăđĩũơƯĂÂÊÔƠƯưăâêôơưẠẢẤẦẨẪẬẮẰẲẴẶẸẺẼẾỀỂỄỆỈỊỌỎỐỒỔỖỘỚỜỞỠỢỤỦỨỪỬỮỰỲÝỶỸỴạảấầẩẫậắằẳẵặẹẻẽếềểễệỉịọỏốồổỗộớờởỡợụủứừửữựỳýỷỹỵ\s]+$/.test(fullName)) {
                clientErrors.push("Họ và tên học sinh chỉ được chứa chữ cái và khoảng trắng.");
            }

            if (!dateOfBirth) {
                clientErrors.push("Ngày sinh học sinh không được để trống.");
            } else if (new Date(dateOfBirth) > new Date()) {
                clientErrors.push("Ngày sinh không được vượt quá ngày hiện tại.");
            }

            let parentId = null;

            // Parent values if choosing existing parent
            if (!isNewParent) {
                parentId = document.getElementById('existingParentSelect').value;
                if (!parentId) {
                    clientErrors.push("Vui lòng chọn phụ huynh liên kết.");
                }
            } else {
                // New parent values
                const pFullName = document.getElementById('npFullName').value.trim();
                const pUsername = document.getElementById('npUsername').value.trim();
                const pPassword = document.getElementById('npPassword').value.trim();
                let pPhone = document.getElementById('npPhone').value.trim();
                const pEmail = document.getElementById('npEmail').value.trim();

                if (!pFullName) clientErrors.push("Họ và tên Phụ huynh không được để trống.");
                if (!pUsername) clientErrors.push("Tên đăng nhập Phụ huynh không được để trống.");
                if (!pPassword) clientErrors.push("Mật khẩu Phụ huynh không được để trống.");

                if (pPhone) {
                    pPhone = pPhone.replace(/[\s\-\(\)]/g, "");
                    if (pPhone.startsWith("+84")) {
                        pPhone = "0" + pPhone.substring(3);
                    } else if (pPhone.startsWith("84") && pPhone.length > 9) {
                        pPhone = "0" + pPhone.substring(2);
                    }
                    if (!/^(0[3|5|7|8|9])[0-9]{8}$/.test(pPhone)) {
                        clientErrors.push("Số điện thoại Phụ huynh không hợp lệ (phải gồm 10 chữ số và bắt đầu bằng đầu số di động VN như 03, 05, 07, 08, 09).");
                    }
                }

                if (pEmail && !/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(pEmail)) {
                    clientErrors.push("Địa chỉ email Phụ huynh không đúng định dạng.");
                }
            }

            if (clientErrors.length > 0) {
                $('.create-student-error-container').html(`
                    <div class="alert alert-danger border-0 py-2 rounded-3" role="alert">
                        <ul class="mb-0 ps-3">
                            ${clientErrors.map(err => `<li>${err}</li>`).join('')}
                        </ul>
                    </div>
                `);
                return;
            }

            // Start sequential flow
            let flowPromise = Promise.resolve();

            if (isNewParent) {
                const parentCreateData = {
                    fullName: document.getElementById('npFullName').value.trim(),
                    username: document.getElementById('npUsername').value.trim(),
                    password: document.getElementById('npPassword').value.trim(),
                    phone: document.getElementById('npPhone').value.trim() || null,
                    email: document.getElementById('npEmail').value.trim() || null
                };

                // Sanitize parent phone
                if (parentCreateData.phone) {
                    let sanitizedPhone = parentCreateData.phone.replace(/[\s\-\(\)]/g, "");
                    if (sanitizedPhone.startsWith("+84")) {
                        sanitizedPhone = "0" + sanitizedPhone.substring(3);
                    } else if (sanitizedPhone.startsWith("84") && sanitizedPhone.length > 9) {
                        sanitizedPhone = "0" + sanitizedPhone.substring(2);
                    }
                    parentCreateData.phone = sanitizedPhone;
                }

                flowPromise = fetch('/api/center/parents', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(parentCreateData)
                })
                .then(async res => {
                    const data = await res.json();
                    if (!res.ok) {
                        let errMsg = data.message || "Tạo phụ huynh mới thất bại.";
                        if (data.errors) {
                            const errorList = [];
                            for (const key in data.errors) {
                                if (data.errors.hasOwnProperty(key)) {
                                    errorList.push(...data.errors[key]);
                                }
                            }
                            errMsg = errorList.join(', ');
                        }
                        throw new Error(errMsg);
                    }
                    return data.id; // Returns created parent ID
                });
            } else {
                flowPromise = Promise.resolve(parseInt(parentId));
            }

            flowPromise
                .then(resolvedParentId => {
                    // Create student DTO
                    const studentCreateData = {
                        fullName: fullName,
                        dateOfBirth: dateOfBirth,
                        gender: gender,
                        parentId: resolvedParentId
                    };

                    return fetch('/api/center/students', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(studentCreateData)
                    })
                    .then(async res => {
                        const data = await res.json();
                        if (!res.ok) throw new Error(data.message || "Tạo học sinh mới thất bại.");
                        return data.id; // Returns created student ID
                    });
                })
                .then(resolvedStudentId => {
                    // Enroll student in class
                    return fetch(`/api/center/classes/${classId}/students`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ studentId: resolvedStudentId })
                    })
                    .then(async res => {
                        const data = await res.json();
                        if (!res.ok) throw new Error("Đã tạo học sinh và phụ huynh nhưng không thể xếp vào lớp học: " + (data.message || "Lỗi."));
                        return data;
                    });
                })
                .then(() => {
                    bootstrap.Modal.getInstance(document.getElementById('createStudentModal')).hide();
                    showAlert("Thêm học sinh mới và xếp lớp thành công!", "success");
                    loadMembers();
                    // Clear fields
                    document.getElementById('newStudentFullName').value = '';
                    document.getElementById('newStudentDob').value = '';
                    document.getElementById('newStudentGender').value = '';
                    document.getElementById('existingParentSelect').value = '';
                    document.getElementById('npFullName').value = '';
                    document.getElementById('npUsername').value = '';
                    document.getElementById('npPassword').value = '';
                    document.getElementById('npPhone').value = '';
                    document.getElementById('npEmail').value = '';
                })
                .catch(err => {
                    $('.create-student-error-container').html(`
                        <div class="alert alert-danger border-0 py-2 rounded-3" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> ${err.message}
                        </div>
                    `);
                });
        });

        function toggleSelectAll(masterCheckbox) {
            const items = document.querySelectorAll('.available-student-item');
            items.forEach(item => {
                if (item.style.display !== 'none') {
                    const checkbox = item.querySelector('.student-checkbox');
                    if (checkbox) {
                        checkbox.checked = masterCheckbox.checked;
                    }
                }
            });
            updateCounter();
        }

        function updateCounter() {
            const checkedCount = document.querySelectorAll('.student-checkbox:checked').length;
            document.getElementById('selectedCounter').textContent = `Đã chọn: ${checkedCount}`;
        }

        // Live search filter for available students (Vanilla JS)
        const searchInput = document.getElementById('searchAvailableInput');
        if (searchInput) {
            searchInput.addEventListener('input', function(e) {
                const query = e.target.value.toLowerCase().trim();
                const items = document.querySelectorAll('.available-student-item');

                items.forEach(item => {
                    const sName = item.getAttribute('data-name');
                    const sId = item.getAttribute('data-id');

                    if (sName.includes(query) || sId.includes(query)) {
                        item.style.setProperty('display', 'flex', 'important');
                    } else {
                        item.style.setProperty('display', 'none', 'important');
                        const checkbox = item.querySelector('.student-checkbox');
                        if (checkbox) {
                            checkbox.checked = false;
                        }
                    }
                });

                document.getElementById('checkAllStudents').checked = false;
                updateCounter();
            });
        }

        function showAlert(message, type) {
            const container = document.getElementById('alertContainer');
            container.innerHTML = `
                <div class="alert alert-${type} alert-dismissible fade show rounded-3 shadow-sm border-0 mb-4" role="alert">
                    <i class="bi ${type === 'success' ? 'bi-check-circle-fill' : 'bi-info-circle-fill'} me-2"></i> ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;
            setTimeout(() => {
                $(`.alert`).alert('close');
            }, 8000);
        }

        $(document).ready(function() {
            loadClassInfo();
            loadMembers();
            loadParents();
            loadActiveClasses();
        });
    </script>
}
