@page
@model PROJECT_PRN232_.WebApp.Pages.Center.Classes.IndexModel
@{
    ViewData["Title"] = "Quản lý Lớp học - EduBridge";
}

<!-- Custom Styles for Premium Indigo Design -->
<style>
    :root {
        --eb-indigo-gradient: linear-gradient(135deg, #4F46E5, #7C3AED);
        --eb-indigo-hover: #4338CA;
        --eb-indigo-light: #EEF2FF;
        --eb-indigo-border: #E0E7FF;
        --eb-text-dark: #1E293B;
        --eb-text-muted: #64748B;
        --eb-bg-light: #F8FAFC;
    }

    .eb-card {
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid var(--eb-indigo-border);
        box-shadow: 0 4px 20px rgba(79, 70, 229, 0.04);
        padding: 24px;
        margin-bottom: 24px;
    }

    .eb-nav-tabs {
        border-bottom: 2px solid #E2E8F0;
        margin-bottom: 24px;
        display: flex;
        gap: 8px;
    }

    .eb-nav-tab {
        font-weight: 600;
        font-size: 0.95rem;
        color: var(--eb-text-muted);
        padding: 12px 16px;
        text-decoration: none;
        border-bottom: 3px solid transparent;
        transition: all 0.25s ease;
        cursor: pointer;
    }

    .eb-nav-tab:hover, .eb-nav-tab.active {
        color: #4F46E5;
        border-bottom-color: #4F46E5;
    }

    .form-control, .form-select {
        border: 1px solid #CBD5E1;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 0.9rem;
        transition: all 0.2s ease;
    }

    .form-control:focus, .form-select:focus {
        border-color: #6366F1;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
    }

    .eb-btn-primary {
        background: var(--eb-indigo-gradient);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 600;
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 12px rgba(79, 70, 229, 0.2);
        transition: all 0.25s ease;
        text-decoration: none;
        cursor: pointer;
    }

    .eb-btn-primary:hover {
        background: var(--eb-indigo-hover);
        color: #fff;
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(79, 70, 229, 0.3);
    }

    .eb-btn-outline {
        border: 1px solid #CBD5E1;
        background: #fff;
        color: var(--eb-text-dark);
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.25s ease;
        cursor: pointer;
    }

    .eb-btn-outline:hover {
        background: var(--eb-bg-light);
        border-color: #94A3B8;
    }

    .eb-table {
        width: 100%;
        margin-bottom: 0;
        border-collapse: separate;
        border-spacing: 0;
    }

    .eb-table th {
        background: #F1F5F9;
        color: var(--eb-text-dark);
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 14px 16px;
        border-bottom: 2px solid #E2E8F0;
    }

    .eb-table td {
        padding: 16px;
        vertical-align: middle;
        border-bottom: 1px solid #F1F5F9;
        color: var(--eb-text-dark);
        font-size: 0.92rem;
    }

    .eb-table tr:hover td {
        background-color: #F8FAFC;
    }

    .badge-active {
        background-color: #DCFCE7;
        color: #15803D;
        font-weight: 600;
        font-size: 0.8rem;
        padding: 6px 12px;
        border-radius: 20px;
        border: 1px solid #BBF7D0;
    }

    .badge-closed {
        background-color: #FEE2E2;
        color: #B91C1C;
        font-weight: 600;
        font-size: 0.8rem;
        padding: 6px 12px;
        border-radius: 20px;
        border: 1px solid #FCA5A5;
    }

    .eb-action-btn {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #E2E8F0;
        background: #fff;
        color: var(--eb-text-muted);
        transition: all 0.25s ease;
        text-decoration: none;
        cursor: pointer;
    }

    .eb-action-btn:hover {
        transform: scale(1.08);
    }

    .eb-action-btn.view:hover {
        background-color: #EFF6FF;
        color: #2563EB;
        border-color: #BFDBFE;
    }

    .eb-action-btn.edit:hover {
        background-color: #FFFBEB;
        color: #D97706;
        border-color: #FDE68A;
    }

    .eb-action-btn.delete:hover {
        background-color: #FEF2F2;
        color: #DC2626;
        border-color: #FECACA;
    }
</style>

<div class="container-fluid py-4" style="max-width: 1400px;">
    <!-- Title Section -->
    <div class="mb-4">
        <h1 class="fw-bold text-dark mb-1" style="font-size: 1.85rem;">Quản lý lớp học</h1>
        <p class="text-muted mb-0">Thiết lập và đồng bộ thông tin phòng học, ca học và lịch học trung tâm bằng REST API.</p>
    </div>

    <!-- Navigation Tabs -->
    <div class="eb-nav-tabs">
        <span onclick="switchTab('classes-tab', this)" class="eb-nav-tab active">Danh sách lớp học</span>
        <span onclick="switchTab('rooms-tab', this)" class="eb-nav-tab">Quản lý phòng học</span>
        <span onclick="switchTab('slots-tab', this)" class="eb-nav-tab">Quản lý ca học</span>
    </div>

    <!-- Top Alert Messages Container -->
    <div id="alertContainer"></div>

    <!-- TAB 1: CLASSES MANAGEMENT -->
    <div id="classes-tab" class="tab-content">
        <!-- Filter Card -->
        <div class="eb-card">
            <h5 class="fw-bold mb-3" style="color: var(--eb-text-dark);">Danh sách lớp học</h5>
            <div class="row g-3">
                <div class="col-md-3">
                    <input type="text" id="filterClassName" class="form-control" placeholder="Tìm tên/mã lớp..." oninput="applyFilters()">
                </div>
                <div class="col-md-3">
                    <select id="filterStatus" class="form-select" onchange="applyFilters()">
                        <option value="">Trạng thái lớp</option>
                        <option value="Active">Đang hoạt động</option>
                        <option value="Closed">Đã đóng</option>
                    </select>
                </div>
                <div class="col-md-6 d-flex justify-content-between align-items-center">
                    <button class="eb-btn-primary" data-bs-toggle="modal" data-bs-target="#createClassModal">
                        <i class="bi bi-plus-lg"></i> Thêm lớp mới
                    </button>
                    <div class="d-flex gap-2">
                        <button class="eb-btn-outline" onclick="resetFilters()">Làm mới bộ lọc</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Table Card -->
        <div class="eb-card p-0 overflow-hidden" style="border-radius: 12px;">
            <div class="table-responsive">
                <table class="eb-table table-hover">
                    <thead>
                        <tr>
                            <th class="text-center" style="width: 60px;">STT</th>
                            <th style="width: 80px;">ID</th>
                            <th style="width: 120px;">Mã lớp</th>
                            <th>Tên lớp</th>
                            <th class="text-center" style="width: 100px;">Sĩ số</th>
                            <th>Môn học</th>
                            <th>Giáo viên</th>
                            <th class="text-center" style="width: 120px;">Tổng số buổi</th>
                            <th style="width: 180px;">Trạng thái</th>
                            <th class="text-center" style="width: 180px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="classesTableBody">
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">
                                <span class="spinner-border spinner-border-sm text-primary me-2" role="status"></span> Đang tải danh sách lớp học...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- TAB 2: ROOMS MANAGEMENT -->
    <div id="rooms-tab" class="tab-content" style="display: none;">
        <div class="row">
            <div class="col-md-4">
                <div class="eb-card">
                    <h5 class="fw-bold mb-3">Thêm phòng học mới</h5>
                    <form method="post" asp-page-handler="CreateRoom">
                        <div class="mb-3">
                            <label class="form-label fw-semibold small text-muted">Tên phòng học</label>
                            <input name="RoomInput.RoomName" class="form-control" placeholder="Ví dụ: Phòng 101" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold small text-muted">Sức chứa tối đa</label>
                            <input name="RoomInput.Capacity" type="number" class="form-control" value="30" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold small text-muted">Trang thiết bị</label>
                            <input name="RoomInput.Equipment" class="form-control" placeholder="Ví dụ: Điều hòa, Máy chiếu..." />
                        </div>
                        <button type="submit" class="eb-btn-primary w-100 justify-content-center">Lưu phòng học</button>
                    </form>
                </div>
            </div>
            <div class="col-md-8">
                <div class="eb-card p-0 overflow-hidden">
                    <table class="eb-table">
                        <thead>
                            <tr>
                                <th class="text-center" style="width: 60px;">STT</th>
                                <th>Tên phòng</th>
                                <th class="text-center">Sức chứa</th>
                                <th>Thiết bị hiện có</th>
                                <th class="text-center">Trạng thái</th>
                                <th class="text-center" style="width: 100px;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int rIdx = 1; }
                            @foreach (var r in Model.Rooms)
                            {
                                <tr>
                                    <td class="text-center text-muted fw-semibold">@rIdx</td>
                                    <td class="fw-bold">@r.RoomName</td>
                                    <td class="text-center">@r.Capacity chỗ</td>
                                    <td class="small text-muted">@r.Equipment</td>
                                    <td class="text-center">
                                        <span class="badge bg-success-subtle text-success border rounded-pill px-3 py-1">Hoạt động</span>
                                    </td>
                                    <td class="text-center">
                                        <form method="post" asp-page-handler="DeleteRoom" asp-route-id="@r.Id" onsubmit="return confirm('Bạn có chắc muốn xóa phòng này?');">
                                            <button type="submit" class="eb-action-btn delete" title="Xóa phòng học">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                rIdx++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- TAB 3: SLOTS MANAGEMENT -->
    <div id="slots-tab" class="tab-content" style="display: none;">
        <div class="row">
            <div class="col-md-4">
                <div class="eb-card">
                    <h5 class="fw-bold mb-3">Thêm ca học mới</h5>
                    <form method="post" asp-page-handler="CreateSlot">
                        <div class="mb-3">
                            <label class="form-label fw-semibold small text-muted">Tên ca học</label>
                            <input name="SlotInput.SlotName" class="form-control" placeholder="Ví dụ: Ca 1 (Sáng)" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold small text-muted">Giờ bắt đầu</label>
                            <input name="SlotInput.StartTime" type="time" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold small text-muted">Giờ kết thúc</label>
                            <input name="SlotInput.EndTime" type="time" class="form-control" required />
                        </div>
                        <button type="submit" class="eb-btn-primary w-100 justify-content-center">Lưu ca học</button>
                    </form>
                </div>
            </div>
            <div class="col-md-8">
                <div class="eb-card p-0 overflow-hidden">
                    <table class="eb-table">
                        <thead>
                            <tr>
                                <th class="text-center" style="width: 60px;">STT</th>
                                <th>Tên ca học</th>
                                <th>Giờ học</th>
                                <th class="text-center" style="width: 100px;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int sIdx = 1; }
                            @foreach (var s in Model.Slots)
                            {
                                <tr>
                                    <td class="text-center text-muted fw-semibold">@sIdx</td>
                                    <td class="fw-bold">@s.SlotName</td>
                                    <td>
                                        <span class="badge bg-light text-dark border px-3 py-1 font-monospace">
                                            @s.StartTime.ToString(@"hh\:mm") - @s.EndTime.ToString(@"hh\:mm")
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <form method="post" asp-page-handler="DeleteSlot" asp-route-id="@s.Id" onsubmit="return confirm('Bạn có chắc muốn xóa ca học này?');">
                                            <button type="submit" class="eb-action-btn delete" title="Xóa ca học">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                sIdx++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- CREATE CLASS MODAL -->
<div class="modal fade" id="createClassModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header border-bottom px-4 py-3">
                <h5 class="modal-title fw-bold text-dark" style="font-size: 1.35rem;">📝 Thêm lớp học</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="createClassForm">
                <div class="modal-body px-4 py-4" style="background-color: #F8FAFC;">
                    <div class="create-error-container"></div>
                    
                    <!-- Section: Thông tin lớp học -->
                    <div class="bg-white rounded-3 p-4 border mb-4">
                        <h6 class="fw-bold text-dark border-bottom pb-2 mb-3">Thông tin lớp học</h6>
                        
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small mb-1">Mã lớp</label>
                                <input class="form-control bg-light" type="text" value="CLS-1-@DateTime.Now.ToString("yyyyMM")-xxxx" readonly disabled style="cursor: not-allowed;" />
                                <span class="text-muted small d-block mt-1">Hệ thống cấp mã chính thức khi lưu lớp.</span>
                            </div>
                            
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small mb-1">Tên lớp (*)</label>
                                <input id="createClassName" class="form-control" placeholder="Nhập tên lớp..." required />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small mb-1">Môn học (*)</label>
                                <select class="form-select" id="createClassSubject" required onchange="updateCreateTotalLessons()">
                                    <option value="" selected disabled>Chọn môn học</option>
                                    @foreach (var s in Model.Subjects)
                                    {
                                        <option value="@s.SubjectCode" data-sessions="@s.NumberOfSessions">@s.SubjectName (@s.SubjectCode)</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small mb-1">Giáo viên</label>
                                <select class="form-select" id="createClassTeacher">
                                    <option value="" selected>Chưa phân công</option>
                                    @foreach (var t in Model.Teachers)
                                    {
                                        <option value="@t.Id">@t.FullName (@t.Username)</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small mb-1">Tổng số buổi (*)</label>
                                <input class="form-control" type="number" id="createTotalLessons" placeholder="Ví dụ: 24" value="24" required />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small mb-1">Phòng học (*)</label>
                                <select class="form-select" id="createRoomId" required>
                                    <option value="" selected disabled>Chọn phòng học</option>
                                    @foreach (var r in Model.Rooms)
                                    {
                                        <option value="@r.Id">@r.RoomName (Sức chứa: @r.Capacity)</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small mb-1">Sĩ số tối đa (*)</label>
                                <input id="createMaxCapacity" class="form-control" type="number" value="30" required />
                            </div>
                        </div>
                    </div>

                    <!-- Section: Lịch học -->
                    <div class="bg-white rounded-3 p-4 border">
                        <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-3">
                            <h6 class="fw-bold text-dark mb-0">Lịch học</h6>
                            <button type="button" class="btn btn-primary btn-sm rounded-3 px-3 d-inline-flex align-items-center gap-1" id="btnAddScheduleRow">
                                <i class="bi bi-plus-lg"></i> Thêm lịch
                            </button>
                        </div>

                        <!-- Schedule Rows Container -->
                        <div id="scheduleRowsContainer">
                            <div class="row g-2 align-items-center schedule-row-item mb-2 pb-2 border-bottom">
                                <div class="col-md-3">
                                    <label class="small text-muted fw-semibold d-block mb-1">Thứ (*)</label>
                                    <select class="form-select form-select-sm" name="CreateDayOfWeek[]" required>
                                        <option value="Thứ 2">Thứ 2</option>
                                        <option value="Thứ 3">Thứ 3</option>
                                        <option value="Thứ 4">Thứ 4</option>
                                        <option value="Thứ 5">Thứ 5</option>
                                        <option value="Thứ 6">Thứ 6</option>
                                        <option value="Thứ 7">Thứ 7</option>
                                        <option value="Chủ nhật">Chủ nhật</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="small text-muted fw-semibold d-block mb-1">Ca học gợi ý</label>
                                    <select class="form-select form-select-sm slot-suggestion-select" name="CreateSlotId[]" onchange="onSlotSuggestionChanged(this)">
                                        <option value="" selected>Tự chọn giờ</option>
                                        @foreach (var s in Model.Slots)
                                        {
                                            <option value="@s.Id" data-start="@s.StartTime.ToString(@"hh\:mm")" data-end="@s.EndTime.ToString(@"hh\:mm")">@s.SlotName (@s.StartTime.ToString(@"hh\:mm") - @s.EndTime.ToString(@"hh\:mm"))</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <label class="small text-muted fw-semibold d-block mb-1">Giờ bắt đầu (*)</label>
                                    <input type="time" class="form-control form-control-sm start-time-input" required />
                                </div>
                                <div class="col-md-2">
                                    <label class="small text-muted fw-semibold d-block mb-1">Giờ kết thúc (*)</label>
                                    <input type="time" class="form-control form-control-sm end-time-input" required />
                                </div>
                                <div class="col-md-1 text-end">
                                    <label class="small text-muted fw-semibold d-block mb-1" style="visibility: hidden;">Xóa</label>
                                    <button type="button" class="btn btn-outline-danger btn-sm border-0 mt-1" onclick="removeScheduleRow(this)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
                <div class="modal-footer border-top px-4 py-3" style="background-color: #F8FAFC;">
                    <button type="button" class="btn btn-light rounded-3 border px-4 py-2 fw-semibold" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary rounded-3 px-4 py-2 fw-semibold" style="background: var(--eb-indigo-gradient); border: none;">Lưu lớp học</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- EDIT CLASS MODAL -->
<div class="modal fade" id="editClassModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header border-bottom px-4 py-3">
                <h5 class="modal-title fw-bold text-dark" style="font-size: 1.35rem;">✏️ Sửa lớp học</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="editClassForm">
                <input type="hidden" id="editClassId" />
                <div class="modal-body px-4 py-4" style="background-color: #F8FAFC;">
                    <div class="edit-error-container"></div>
                    
                    <!-- Section: Thông tin lớp học -->
                    <div class="bg-white rounded-3 p-4 border mb-4">
                        <h6 class="fw-bold text-dark border-bottom pb-2 mb-3">Thông tin lớp học</h6>
                        
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small mb-1">Mã lớp</label>
                                <input class="form-control bg-light" type="text" id="editClassCode" readonly disabled style="cursor: not-allowed;" />
                            </div>
                            
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small mb-1">Tên lớp (*)</label>
                                <input class="form-control" id="editClassName" required />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small mb-1">Môn học (*)</label>
                                <select class="form-select" id="editClassSubject" required onchange="updateEditTotalLessons()">
                                    @foreach (var s in Model.Subjects)
                                    {
                                        <option value="@s.SubjectCode" data-sessions="@s.NumberOfSessions">@s.SubjectName (@s.SubjectCode)</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small mb-1">Giáo viên</label>
                                <select class="form-select" id="editClassTeacher">
                                    <option value="" selected>Chưa phân công</option>
                                    @foreach (var t in Model.Teachers)
                                    {
                                        <option value="@t.Id">@t.FullName (@t.Username)</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small mb-1">Tổng số buổi (*)</label>
                                <input class="form-control" type="number" id="editTotalLessons" value="24" required />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small mb-1">Phòng học (*)</label>
                                <select class="form-select" id="editClassRoom" required>
                                    @foreach (var r in Model.Rooms)
                                    {
                                        <option value="@r.Id">@r.RoomName (Sức chứa: @r.Capacity)</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small mb-1">Sĩ số tối đa (*)</label>
                                <input class="form-control" type="number" id="editMaxCapacity" required />
                            </div>
                        </div>
                    </div>

                    <!-- Section: Lịch học -->
                    <div class="bg-white rounded-3 p-4 border">
                        <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-3">
                            <h6 class="fw-bold text-dark mb-0">Lịch học</h6>
                            <button type="button" class="btn btn-primary btn-sm rounded-3 px-3 d-inline-flex align-items-center gap-1" id="btnEditAddScheduleRow">
                                <i class="bi bi-plus-lg"></i> Thêm lịch
                            </button>
                        </div>

                        <!-- Schedule Rows Container -->
                        <div id="editScheduleRowsContainer">
                            <div class="row g-2 align-items-center edit-schedule-row-item mb-2 pb-2 border-bottom">
                                <div class="col-md-3">
                                    <label class="small text-muted fw-semibold d-block mb-1">Thứ (*)</label>
                                    <select class="form-select form-select-sm" name="UpdateDayOfWeek[]" required>
                                        <option value="Thứ 2">Thứ 2</option>
                                        <option value="Thứ 3">Thứ 3</option>
                                        <option value="Thứ 4">Thứ 4</option>
                                        <option value="Thứ 5">Thứ 5</option>
                                        <option value="Thứ 6">Thứ 6</option>
                                        <option value="Thứ 7">Thứ 7</option>
                                        <option value="Chủ nhật">Chủ nhật</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="small text-muted fw-semibold d-block mb-1">Ca học gợi ý</label>
                                    <select class="form-select form-select-sm slot-suggestion-select" name="UpdateSlotId[]" onchange="onSlotSuggestionChanged(this)">
                                        <option value="" selected>Tự chọn giờ</option>
                                        @foreach (var s in Model.Slots)
                                        {
                                            <option value="@s.Id" data-start="@s.StartTime.ToString(@"hh\:mm")" data-end="@s.EndTime.ToString(@"hh\:mm")">@s.SlotName (@s.StartTime.ToString(@"hh\:mm") - @s.EndTime.ToString(@"hh\:mm"))</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <label class="small text-muted fw-semibold d-block mb-1">Giờ bắt đầu (*)</label>
                                    <input type="time" class="form-control form-control-sm start-time-input" required />
                                </div>
                                <div class="col-md-2">
                                    <label class="small text-muted fw-semibold d-block mb-1">Giờ kết thúc (*)</label>
                                    <input type="time" class="form-control form-control-sm end-time-input" required />
                                </div>
                                <div class="col-md-1 text-end">
                                    <label class="small text-muted fw-semibold d-block mb-1" style="visibility: hidden;">Xóa</label>
                                    <button type="button" class="btn btn-outline-danger btn-sm border-0 mt-1" onclick="removeEditScheduleRow(this)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
                <div class="modal-footer border-top px-4 py-3" style="background-color: #F8FAFC;">
                    <button type="button" class="btn btn-light rounded-3 border px-4 py-2 fw-semibold" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary rounded-3 px-4 py-2 fw-semibold" style="background: var(--eb-indigo-gradient); border: none;">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // Danh sách môn học và phòng học để tra cứu trên client
        const subjectsData = [
            @foreach(var s in Model.Subjects) {
                <text>{ code: "@s.SubjectCode", name: "@s.SubjectName" },</text>
            }
        ];

        const globalSlotsOptions = `
            <option value="">Tự chọn giờ</option>
            @foreach (var s in Model.Slots)
            {
                <option value="@s.Id" data-start="@s.StartTime.ToString(@"hh\:mm")" data-end="@s.EndTime.ToString(@"hh\:mm")">@s.SlotName (@s.StartTime.ToString(@"hh\:mm") - @s.EndTime.ToString(@"hh\:mm"))</option>
            }
        `;

        let allClasses = [];

        function switchTab(tabId, el) {
            $('.tab-content').hide();
            $('#' + tabId).show();
            $('.eb-nav-tab').removeClass('active');
            $(el).addClass('active');
        }

        // Tải danh sách lớp từ API
        function loadClasses() {
            fetch('/api/center/classes')
                .then(res => res.json())
                .then(data => {
                    allClasses = data;
                    renderClassesTable(data);
                })
                .catch(err => {
                    console.error("Lỗi tải lớp học:", err);
                    $('#classesTableBody').html('<tr><td colspan="9" class="text-center text-danger py-4">Không thể tải danh sách lớp học.</td></tr>');
                });
        }

        function renderClassesTable(classes) {
            const tbody = document.getElementById('classesTableBody');
            if (classes.length === 0) {
                tbody.innerHTML = '<tr><td colspan="9" class="text-center text-muted py-4">Chưa có lớp học nào được tạo.</td></tr>';
                return;
            }

            let html = '';
            classes.forEach((c, idx) => {
                const classCode = `CLS${c.id.toString().padStart(4, '0')}`;
                const subjectObj = subjectsData.find(s => s.code === c.subject);
                const subjectDisplay = subjectObj ? subjectObj.name : (c.subject || '—');
                
                const statusBadge = c.status === 'Active' 
                    ? '<span class="badge-active">Đang hoạt động</span>'
                    : '<span class="badge-closed">Đã đóng</span>';

                html += `
                    <tr class="class-row" data-class-name="${c.className}" data-class-id="${c.id}" data-status="${c.status}">
                        <td class="text-center fw-semibold text-muted">${idx + 1}</td>
                        <td class="fw-semibold">${c.id}</td>
                        <td><span class="text-primary fw-bold">${classCode}</span></td>
                        <td class="fw-bold" style="color: var(--eb-text-dark);">${c.className}</td>
                        <td class="text-center">
                            <span class="badge bg-light text-dark border px-2 py-1"><i class="bi bi-people me-1"></i>${c.studentCount}</span>
                        </td>
                        <td class="small">
                            <span class="badge bg-primary-subtle text-primary border rounded-pill px-2 py-1">${subjectDisplay}</span>
                        </td>
                        <td class="fw-semibold text-secondary">${c.teacherName || '<span class="text-muted fst-italic">Chưa có</span>'}</td>
                        <td class="text-center">
                            <span class="badge bg-info-subtle text-info border px-2 py-1"><i class="bi bi-book me-1"></i>${c.totalLessons} buổi</span>
                        </td>
                        <td>${statusBadge}</td>
                        <td class="text-center">
                            <div class="d-inline-flex gap-2">
                                <a href="/Center/Lessons/Lesson/${c.id}" class="eb-action-btn view" title="Xếp lịch học & Quản lý buổi học">
                                    <i class="bi bi-calendar-event"></i>
                                </a>
                                <a href="/Center/Classes/Students?classId=${c.id}" class="eb-action-btn view" title="Học viên">
                                    <i class="bi bi-people"></i>
                                </a>
                                <button class="eb-action-btn edit" onclick="openEditModal(${c.id})" data-bs-toggle="modal" data-bs-target="#editClassModal" title="Sửa">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                                <button class="eb-action-btn delete" onclick="deleteClass(${c.id})" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
        }

        // Tạo lớp học mới bằng Rest API
        document.getElementById('createClassForm').addEventListener('submit', function(e) {
            e.preventDefault();
            $('.create-error-container').html('');

            // Thu thập dữ liệu Lịch học
            const dayOfWeeks = [];
            const slotIds = [];
            document.querySelectorAll('#scheduleRowsContainer select[name="CreateDayOfWeek[]"]').forEach(el => {
                dayOfWeeks.push(el.value);
            });
            document.querySelectorAll('#scheduleRowsContainer select[name="CreateSlotId[]"]').forEach(el => {
                if (el.value) slotIds.push(parseInt(el.value));
            });

            const bodyData = {
                createDto: {
                    className: document.getElementById('createClassName').value,
                    subject: document.getElementById('createClassSubject').value,
                    totalLessons: parseInt(document.getElementById('createTotalLessons').value),
                    maxCapacity: parseInt(document.getElementById('createMaxCapacity').value),
                    centerId: 1,
                    teacherId: document.getElementById('createClassTeacher').value ? parseInt(document.getElementById('createClassTeacher').value) : null
                },
                createRoomId: parseInt(document.getElementById('createRoomId').value),
                dayOfWeek: dayOfWeeks,
                slotId: slotIds
            };

            fetch('/api/center/classes', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(bodyData)
            })
            .then(async res => {
                if (!res.ok) {
                    const errData = await res.json();
                    throw new Error(errData.message || "Tạo lớp học thất bại.");
                }
                return res.json();
            })
            .then(data => {
                bootstrap.Modal.getInstance(document.getElementById('createClassModal')).hide();
                showAlert("Tạo lớp học thành công!", "success");
                loadClasses();
                document.getElementById('createClassForm').reset();
            })
            .catch(err => {
                console.error("Lỗi khi tạo lớp:", err);
                $('.create-error-container').html(`
                    <div class="alert alert-danger alert-dismissible fade show rounded-3 border-0" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> ${err.message}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                `);
            });
        });

        // Xóa lớp học
        function deleteClass(classId) {
            if (!confirm('Bạn có chắc chắn muốn xóa lớp học này?')) return;

            fetch(`/api/center/classes/${classId}`, {
                method: 'DELETE'
            })
            .then(res => {
                if (!res.ok) throw new Error("Xóa lớp học thất bại.");
                showAlert("Xóa lớp học thành công!", "success");
                loadClasses();
            })
            .catch(err => {
                console.error("Lỗi xóa lớp:", err);
                showAlert(err.message, "danger");
            });
        }

        // Mở popup Sửa lớp học & gọi API
        function openEditModal(id) {
            $('.edit-error-container').html('');
            document.getElementById('editClassId').value = id;
            
            document.getElementById('editClassName').value = '';
            document.getElementById('editMaxCapacity').value = 30;
            document.getElementById('editClassSubject').value = '';
            document.getElementById('editTotalLessons').value = 24;
            document.getElementById('editClassCode').value = '';

            const container = document.getElementById('editScheduleRowsContainer');
            container.innerHTML = '<div class="text-center py-3"><div class="spinner-border spinner-border-sm text-primary" role="status"></div> Loading schedule...</div>';

            fetch(`/api/center/classes/${id}/schedules`)
                .then(res => res.json())
                .then(data => {
                    container.innerHTML = '';
                    
                    document.getElementById('editClassName').value = data.className || '';
                    document.getElementById('editMaxCapacity').value = data.maxCapacity || 30;
                    document.getElementById('editClassSubject').value = data.subject || '';
                    document.getElementById('editTotalLessons').value = data.totalLessons || 24;
                    document.getElementById('editClassTeacher').value = data.teacherId || '';

                    const formattedId = ("0000" + id).slice(-4);
                    document.getElementById('editClassCode').value = `CLS-${data.centerId || 1}-${new Date().getFullYear()}${("0" + (new Date().getMonth() + 1)).slice(-2)}-${formattedId}`;

                    const roomEl = document.getElementById('editClassRoom');
                    if (roomEl) {
                        if (data.roomId) {
                            roomEl.value = data.roomId;
                        } else {
                            roomEl.selectedIndex = 0;
                        }
                    }

                    const lessons = data.lessons;
                    const slotsOptionsRef = globalSlotsOptions;

                    if (!lessons || lessons.length === 0) {
                        container.innerHTML = `
                            <div class="row g-2 align-items-center edit-schedule-row-item mb-2 pb-2 border-bottom">
                                <div class="col-md-3">
                                    <select class="form-select form-select-sm edit-day-select" name="UpdateDayOfWeek[]" required>
                                        <option value="Thứ 2" selected>Thứ 2</option>
                                        <option value="Thứ 3">Thứ 3</option>
                                        <option value="Thứ 4">Thứ 4</option>
                                        <option value="Thứ 5">Thứ 5</option>
                                        <option value="Thứ 6">Thứ 6</option>
                                        <option value="Thứ 7">Thứ 7</option>
                                        <option value="Chủ nhật">Chủ nhật</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <select class="form-select form-select-sm slot-suggestion-select" name="UpdateSlotId[]" onchange="onSlotSuggestionChanged(this)">
                                        ${slotsOptionsRef}
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <input type="time" class="form-control form-control-sm start-time-input" required />
                                </div>
                                <div class="col-md-2">
                                    <input type="time" class="form-control form-control-sm end-time-input" required />
                                </div>
                                <div class="col-md-1 text-end">
                                    <button type="button" class="btn btn-outline-danger btn-sm border-0 mt-1" onclick="removeEditScheduleRow(this)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        `;
                        return;
                    }

                    lessons.forEach((l, idx) => {
                        const newRow = document.createElement('div');
                        newRow.className = 'row g-2 align-items-center edit-schedule-row-item mb-2 pb-2 border-bottom';
                        
                        const daysMap = { 0: "Chủ nhật", 1: "Thứ 2", 2: "Thứ 3", 3: "Thứ 4", 4: "Thứ 5", 5: "Thứ 6", 6: "Thứ 7" };
                        const vnDay = daysMap[l.dayOfWeek] || "Thứ 2";

                        newRow.innerHTML = `
                            <div class="col-md-3">
                                <select class="form-select form-select-sm edit-day-select" name="UpdateDayOfWeek[]" required>
                                    <option value="Thứ 2" ${vnDay === "Thứ 2" ? "selected" : ""}>Thứ 2</option>
                                    <option value="Thứ 3" ${vnDay === "Thứ 3" ? "selected" : ""}>Thứ 3</option>
                                    <option value="Thứ 4" ${vnDay === "Thứ 4" ? "selected" : ""}>Thứ 4</option>
                                    <option value="Thứ 5" ${vnDay === "Thứ 5" ? "selected" : ""}>Thứ 5</option>
                                    <option value="Thứ 6" ${vnDay === "Thứ 6" ? "selected" : ""}>Thứ 6</option>
                                    <option value="Thứ 7" ${vnDay === "Thứ 7" ? "selected" : ""}>Thứ 7</option>
                                    <option value="Chủ nhật" ${vnDay === "Chủ nhật" ? "selected" : ""}>Chủ nhật</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <select class="form-select form-select-sm slot-suggestion-select" name="UpdateSlotId[]" onchange="onSlotSuggestionChanged(this)">
                                    ${slotsOptionsRef}
                                </select>
                            </div>
                            <div class="col-md-2">
                                <input type="time" class="form-control form-control-sm start-time-input" required />
                            </div>
                            <div class="col-md-2">
                                <input type="time" class="form-control form-control-sm end-time-input" required />
                            </div>
                            <div class="col-md-1 text-end">
                                <button type="button" class="btn btn-outline-danger btn-sm border-0 mt-1" onclick="removeEditScheduleRow(this)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        `;

                        container.appendChild(newRow);

                        const selectElement = newRow.querySelector('.slot-suggestion-select');
                        if (l.slotId && selectElement) {
                            selectElement.value = l.slotId;
                            onSlotSuggestionChanged(selectElement);
                        }
                    });
                })
                .catch(err => {
                    console.error("Lỗi lấy lịch học:", err);
                    container.innerHTML = '<div class="text-danger small text-center py-2">Không thể tải lịch học.</div>';
                });
        }

        // Lưu cập nhật lớp học bằng Rest API
        document.getElementById('editClassForm').addEventListener('submit', function(e) {
            e.preventDefault();
            $('.edit-error-container').html('');

            const classId = parseInt(document.getElementById('editClassId').value);
            const dayOfWeeks = [];
            const slotIds = [];
            document.querySelectorAll('#editScheduleRowsContainer select[name="UpdateDayOfWeek[]"]').forEach(el => {
                dayOfWeeks.push(el.value);
            });
            document.querySelectorAll('#editScheduleRowsContainer select[name="UpdateSlotId[]"]').forEach(el => {
                if (el.value) slotIds.push(parseInt(el.value));
            });

            const bodyData = {
                updateDto: {
                    id: classId,
                    className: document.getElementById('editClassName').value,
                    subject: document.getElementById('editClassSubject').value,
                    totalLessons: parseInt(document.getElementById('editTotalLessons').value),
                    maxCapacity: parseInt(document.getElementById('editMaxCapacity').value),
                    centerId: 1,
                    teacherId: document.getElementById('editClassTeacher').value ? parseInt(document.getElementById('editClassTeacher').value) : null
                },
                updateRoomId: parseInt(document.getElementById('editClassRoom').value),
                dayOfWeek: dayOfWeeks,
                slotId: slotIds
            };

            fetch(`/api/center/classes/${classId}`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(bodyData)
            })
            .then(async res => {
                if (!res.ok) {
                    const errData = await res.json();
                    throw new Error(errData.message || "Cập nhật lớp học thất bại.");
                }
            })
            .then(() => {
                bootstrap.Modal.getInstance(document.getElementById('editClassModal')).hide();
                showAlert("Cập nhật lớp học thành công!", "success");
                loadClasses();
            })
            .catch(err => {
                console.error("Lỗi cập nhật lớp:", err);
                $('.edit-error-container').html(`
                    <div class="alert alert-danger alert-dismissible fade show rounded-3 border-0" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> ${err.message}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                `);
            });
        });

        // Hộp thông báo top-page
        function showAlert(message, type) {
            const container = document.getElementById('alertContainer');
            container.innerHTML = `
                <div class="alert alert-${type} alert-dismissible fade show rounded-3 shadow-sm border-0" role="alert">
                    <i class="bi ${type === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-triangle-fill'} me-2"></i> ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;
            setTimeout(() => {
                $(`.alert`).alert('close');
            }, 5000);
        }

        // Lọc trên Client-side nhanh hơn
        function applyFilters() {
            const filterName = document.getElementById('filterClassName').value.toLowerCase().trim();
            const filterStatus = document.getElementById('filterStatus').value;

            const filtered = allClasses.filter(c => {
                const matchesName = !filterName || c.className.toLowerCase().includes(filterName) || c.id.toString().includes(filterName);
                const matchesStatus = !filterStatus || c.status === filterStatus;
                return matchesName && matchesStatus;
            });
            renderClassesTable(filtered);
        }

        function resetFilters() {
            document.getElementById('filterClassName').value = '';
            document.getElementById('filterStatus').value = '';
            renderClassesTable(allClasses);
        }

        // --- SCRIPTS THÊM HÀNG LỊCH ĐỘNG ---
        document.getElementById('btnAddScheduleRow').addEventListener('click', function() {
            const container = document.getElementById('scheduleRowsContainer');
            const newRow = document.createElement('div');
            newRow.className = 'row g-2 align-items-center schedule-row-item mb-2 pb-2 border-bottom';
            const slotsOptions = globalSlotsOptions;

            newRow.innerHTML = `
                <div class="col-md-3">
                    <select class="form-select form-select-sm" name="CreateDayOfWeek[]" required>
                        <option value="Thứ 2">Thứ 2</option>
                        <option value="Thứ 3">Thứ 3</option>
                        <option value="Thứ 4">Thứ 4</option>
                        <option value="Thứ 5">Thứ 5</option>
                        <option value="Thứ 6">Thứ 6</option>
                        <option value="Thứ 7">Thứ 7</option>
                        <option value="Chủ nhật">Chủ nhật</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <select class="form-select form-select-sm slot-suggestion-select" name="CreateSlotId[]" onchange="onSlotSuggestionChanged(this)">
                        ${slotsOptions}
                    </select>
                </div>
                <div class="col-md-2">
                    <input type="time" class="form-control form-control-sm start-time-input" required />
                </div>
                <div class="col-md-2">
                    <input type="time" class="form-control form-control-sm end-time-input" required />
                </div>
                <div class="col-md-1 text-end">
                    <button type="button" class="btn btn-outline-danger btn-sm border-0 mt-1" onclick="removeScheduleRow(this)">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            `;
            container.appendChild(newRow);
        });

        function removeScheduleRow(button) {
            const rows = document.querySelectorAll('.schedule-row-item');
            if (rows.length > 1) {
                button.closest('.schedule-row-item').remove();
            } else {
                alert("Lớp học phải đăng ký tối thiểu một lịch học!");
            }
        }

        function onSlotSuggestionChanged(selectElement) {
            const selectedOption = selectElement.options[selectElement.selectedIndex];
            const row = selectElement.closest('.schedule-row-item, .edit-schedule-row-item');
            const startTimeInput = row.querySelector('.start-time-input');
            const endTimeInput = row.querySelector('.end-time-input');

            if (selectedOption && selectedOption.value !== "") {
                startTimeInput.value = selectedOption.getAttribute('data-start');
                endTimeInput.value = selectedOption.getAttribute('data-end');
            } else {
                startTimeInput.value = "";
                endTimeInput.value = "";
            }
        }

        document.getElementById('btnEditAddScheduleRow').addEventListener('click', function() {
            const container = document.getElementById('editScheduleRowsContainer');
            const newRow = document.createElement('div');
            newRow.className = 'row g-2 align-items-center edit-schedule-row-item mb-2 pb-2 border-bottom';
            const slotsOptions = globalSlotsOptions;

            newRow.innerHTML = `
                <div class="col-md-3">
                    <select class="form-select form-select-sm" name="UpdateDayOfWeek[]" required>
                        <option value="Thứ 2">Thứ 2</option>
                        <option value="Thứ 3">Thứ 3</option>
                        <option value="Thứ 4">Thứ 4</option>
                        <option value="Thứ 5">Thứ 5</option>
                        <option value="Thứ 6">Thứ 6</option>
                        <option value="Thứ 7">Thứ 7</option>
                        <option value="Chủ nhật">Chủ nhật</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <select class="form-select form-select-sm slot-suggestion-select" name="UpdateSlotId[]" onchange="onSlotSuggestionChanged(this)">
                        ${slotsOptions}
                    </select>
                </div>
                <div class="col-md-2">
                    <input type="time" class="form-control form-control-sm start-time-input" required />
                </div>
                <div class="col-md-2">
                    <input type="time" class="form-control form-control-sm end-time-input" required />
                </div>
                <div class="col-md-1 text-end">
                    <button type="button" class="btn btn-outline-danger btn-sm border-0 mt-1" onclick="removeEditScheduleRow(this)">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            `;
            container.appendChild(newRow);
        });

        function removeEditScheduleRow(button) {
            const rows = document.querySelectorAll('.edit-schedule-row-item');
            if (rows.length > 1) {
                button.closest('.edit-schedule-row-item').remove();
            } else {
                alert("Lớp học phải đăng ký tối thiểu một lịch học!");
            }
        }

        function updateCreateTotalLessons() {
            const subjectSelect = document.getElementById('createClassSubject');
            const totalLessonsInput = document.getElementById('createTotalLessons');
            if (subjectSelect && totalLessonsInput) {
                const selectedOption = subjectSelect.options[subjectSelect.selectedIndex];
                const sessions = selectedOption.getAttribute('data-sessions');
                if (sessions) totalLessonsInput.value = sessions;
            }
        }

        function updateEditTotalLessons() {
            const subjectSelect = document.getElementById('editClassSubject');
            const totalLessonsInput = document.getElementById('editTotalLessons');
            if (subjectSelect && totalLessonsInput) {
                const selectedOption = subjectSelect.options[subjectSelect.selectedIndex];
                const sessions = selectedOption.getAttribute('data-sessions');
                if (sessions) totalLessonsInput.value = sessions;
            }
        }

        $(document).ready(function () {
            loadClasses();
        });
    </script>
}
