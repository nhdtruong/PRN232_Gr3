@page
@model PROJECT_PRN232_.WebApp.Pages.Center.Classes.IndexModel
@{
    ViewData["Title"] = "Quản lý Lớp học - EduBridge";
}

<!-- Custom Styles for Premium Indigo Design -->
<style>
    :root {
        --eb-indigo-gradient: linear-gradient(135deg, #4F46E5, #7C3AED);
        --eb-indigo-hover: #4338CA;
        --eb-indigo-light: #EEF2FF;
        --eb-indigo-border: #E0E7FF;
        --eb-text-dark: #1E293B;
        --eb-text-muted: #64748B;
        --eb-bg-light: #F8FAFC;
    }

    .eb-card {
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid var(--eb-indigo-border);
        box-shadow: 0 4px 20px rgba(79, 70, 229, 0.04);
        padding: 24px;
        margin-bottom: 24px;
    }

    .eb-nav-tabs {
        border-bottom: 2px solid #E2E8F0;
        margin-bottom: 24px;
        display: flex;
        gap: 8px;
    }

    .eb-nav-tab {
        font-weight: 600;
        font-size: 0.95rem;
        color: var(--eb-text-muted);
        padding: 12px 16px;
        text-decoration: none;
        border-bottom: 3px solid transparent;
        transition: all 0.25s ease;
        cursor: pointer;
    }

    .eb-nav-tab:hover, .eb-nav-tab.active {
        color: #4F46E5;
        border-bottom-color: #4F46E5;
    }

    .form-control, .form-select {
        border: 1px solid #CBD5E1;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 0.9rem;
        transition: all 0.2s ease;
    }

    .form-control:focus, .form-select:focus {
        border-color: #6366F1;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
    }

    .eb-btn-primary {
        background: var(--eb-indigo-gradient);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 600;
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 12px rgba(79, 70, 229, 0.2);
        transition: all 0.25s ease;
        text-decoration: none;
    }

    .eb-btn-primary:hover {
        background: var(--eb-indigo-hover);
        color: #fff;
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(79, 70, 229, 0.3);
    }

    .eb-btn-outline {
        border: 1px solid #CBD5E1;
        background: #fff;
        color: var(--eb-text-dark);
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.25s ease;
    }

    .eb-btn-outline:hover {
        background: var(--eb-bg-light);
        border-color: #94A3B8;
    }

    .eb-table {
        width: 100%;
        margin-bottom: 0;
        border-collapse: separate;
        border-spacing: 0;
    }

    .eb-table th {
        background: #F1F5F9;
        color: var(--eb-text-dark);
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 14px 16px;
        border-bottom: 2px solid #E2E8F0;
    }

    .eb-table td {
        padding: 16px;
        vertical-align: middle;
        border-bottom: 1px solid #F1F5F9;
        color: var(--eb-text-dark);
        font-size: 0.92rem;
    }

    .eb-table tr:hover td {
        background-color: #F8FAFC;
    }

    .badge-active {
        background-color: #DCFCE7;
        color: #15803D;
        font-weight: 600;
        font-size: 0.8rem;
        padding: 6px 12px;
        border-radius: 20px;
        border: 1px solid #BBF7D0;
    }

    .badge-closed {
        background-color: #FEE2E2;
        color: #B91C1C;
        font-weight: 600;
        font-size: 0.8rem;
        padding: 6px 12px;
        border-radius: 20px;
        border: 1px solid #FCA5A5;
    }

    .eb-action-btn {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #E2E8F0;
        background: #fff;
        color: var(--eb-text-muted);
        transition: all 0.25s ease;
        text-decoration: none;
    }

    .eb-action-btn:hover {
        transform: scale(1.08);
    }

    .eb-action-btn.view:hover {
        background-color: #EFF6FF;
        color: #2563EB;
        border-color: #BFDBFE;
    }

    .eb-action-btn.edit:hover {
        background-color: #FFFBEB;
        color: #D97706;
        border-color: #FDE68A;
    }

    .eb-action-btn.delete:hover {
        background-color: #FEF2F2;
        color: #DC2626;
        border-color: #FECACA;
    }

    .pagination-wrapper {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 24px;
        border-top: 1px solid #E2E8F0;
        padding-top: 16px;
    }
</style>

<div class="container-fluid py-4" style="max-width: 1400px;">
    <!-- Title Section -->
    <div class="mb-4">
        <h1 class="fw-bold text-dark mb-1" style="font-size: 1.85rem;">Quản lý lớp học</h1>
        <p class="text-muted mb-0">Thiết lập và đồng bộ thông tin phòng học, ca học và lịch học trung tâm.</p>
    </div>

    <!-- Navigation Tabs -->
    <div class="eb-nav-tabs">
        <span onclick="switchTab('classes-tab', this)" class="eb-nav-tab active">Danh sách lớp học</span>
        <span onclick="switchTab('rooms-tab', this)" class="eb-nav-tab">Quản lý phòng học</span>
        <span onclick="switchTab('slots-tab', this)" class="eb-nav-tab">Quản lý ca học</span>
    </div>

    <!-- Alert Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm border-0" role="alert" style="background-color: #DCFCE7; color: #15803D;">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm border-0" role="alert" style="background-color: #FEE2E2; color: #B91C1C;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- TAB 1: CLASSES MANAGEMENT -->
    <div id="classes-tab" class="tab-content">
        <!-- Filter Card -->
        <div class="eb-card">
            <h5 class="fw-bold mb-3" style="color: var(--eb-text-dark);">Danh sách lớp học</h5>
            <div class="row g-3">
                <div class="col-md-3">
                    <input type="text" id="filterClassName" class="form-control" placeholder="Tìm tên/mã lớp...">
                </div>
                <div class="col-md-3">
                    <select id="filterStatus" class="form-select">
                        <option value="">Trạng thái lớp</option>
                        <option value="Active">Đang hoạt động</option>
                        <option value="Closed">Đã đóng</option>
                    </select>
                </div>
                <div class="col-md-6 d-flex justify-content-between align-items-center">
                    <button class="eb-btn-primary" data-bs-toggle="modal" data-bs-target="#createClassModal">
                        <i class="bi bi-plus-lg"></i> Thêm lớp mới
                    </button>
                    <div class="d-flex gap-2">
                        <button class="eb-btn-outline" onclick="resetFilters()">Làm mới bộ lọc</button>
                        <button class="eb-btn-primary" onclick="applyFilters()">
                            <i class="bi bi-search"></i> Tìm kiếm
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Table Card -->
        <div class="eb-card p-0 overflow-hidden" style="border-radius: 12px;">
            <div class="table-responsive">
                <table class="eb-table table-hover">
                    <thead>
                        <tr>
                            <th class="text-center" style="width: 60px;">STT</th>
                            <th style="width: 80px;">ID</th>
                            <th style="width: 120px;">Mã lớp</th>
                            <th>Tên lớp</th>
                            <th class="text-center" style="width: 100px;">Sĩ số</th>
                            <th>Ngày khai giảng</th>
                            <th>Ngày bế giảng</th>
                            <th style="width: 180px;">Trạng thái</th>
                            <th class="text-center" style="width: 180px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int classIdx = 1; }
                        @foreach (var c in Model.Classes)
                        {
                            var classCode = $"CLS{c.Id:D4}";
                            <tr class="class-row" data-class-name="@c.ClassName" data-class-id="@c.Id" data-status="@c.Status">
                                <td class="text-center fw-semibold text-muted">@classIdx</td>
                                <td class="fw-semibold">@c.Id</td>
                                <td><span class="text-primary fw-bold">@classCode</span></td>
                                <td class="fw-bold" style="color: var(--eb-text-dark);">@c.ClassName</td>
                                <td class="text-center">
                                    <span class="badge bg-light text-dark border px-2 py-1"><i class="bi bi-people me-1"></i>@c.StudentCount</span>
                                </td>
                                <td class="small text-muted">@(c.StartDate?.ToString("dd/MM/yyyy") ?? "01/05/2026")</td>
                                <td class="small text-muted">@(c.EndDate?.ToString("dd/MM/yyyy") ?? "01/08/2026")</td>
                                <td>
                                    @if (c.Status == "Active")
                                    {
                                        <span class="badge-active">Đang hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge-closed">Đã đóng</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-inline-flex gap-2">
                                        <a href="/Center/Lessons/@c.Id" class="eb-action-btn view" title="Xếp lịch học & Quản lý buổi học">
                                            <i class="bi bi-calendar-event"></i>
                                        </a>
                                        <a asp-page="/Center/Classes/Students" asp-route-classId="@c.Id" class="eb-action-btn view" title="Học viên">
                                            <i class="bi bi-people"></i>
                                        </a>
                                        <button class="eb-action-btn edit" onclick="openEditModal(@c.Id, '@c.ClassName', @c.CenterId, @c.MaxCapacity)" data-bs-toggle="modal" data-bs-target="#editClassModal" title="Sửa">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@c.Id" onsubmit="return confirm('Bạn có chắc chắn muốn xóa lớp học này?');" style="display:inline;">
                                            <button type="submit" class="eb-action-btn delete" title="Xóa">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            classIdx++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- TAB 2: ROOMS MANAGEMENT -->
    <div id="rooms-tab" class="tab-content" style="display: none;">
        <div class="row">
            <div class="col-md-4">
                <div class="eb-card">
                    <h5 class="fw-bold mb-3">Thêm phòng học mới</h5>
                    <form method="post" asp-page-handler="CreateRoom">
                        <div class="mb-3">
                            <label class="form-label fw-semibold small text-muted">Tên phòng học</label>
                            <input asp-for="RoomInput.RoomName" class="form-control" placeholder="Ví dụ: Phòng 101" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold small text-muted">Sức chứa tối đa</label>
                            <input asp-for="RoomInput.Capacity" type="number" class="form-control" value="30" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold small text-muted">Trang thiết bị</label>
                            <input asp-for="RoomInput.Equipment" class="form-control" placeholder="Ví dụ: Điều hòa, Máy chiếu..." />
                        </div>
                        <button type="submit" class="eb-btn-primary w-100 justify-content-center">Lưu phòng học</button>
                    </form>
                </div>
            </div>
            <div class="col-md-8">
                <div class="eb-card p-0 overflow-hidden">
                    <table class="eb-table">
                        <thead>
                            <tr>
                                <th class="text-center" style="width: 60px;">STT</th>
                                <th>Tên phòng</th>
                                <th class="text-center">Sức chứa</th>
                                <th>Thiết bị hiện có</th>
                                <th class="text-center">Trạng thái</th>
                                <th class="text-center" style="width: 100px;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int rIdx = 1; }
                            @foreach (var r in Model.Rooms)
                            {
                                <tr>
                                    <td class="text-center text-muted fw-semibold">@rIdx</td>
                                    <td class="fw-bold">@r.RoomName</td>
                                    <td class="text-center">@r.Capacity chỗ</td>
                                    <td class="small text-muted">@r.Equipment</td>
                                    <td class="text-center">
                                        <span class="badge bg-success-subtle text-success border rounded-pill px-3 py-1">Hoạt động</span>
                                    </td>
                                    <td class="text-center">
                                        <form method="post" asp-page-handler="DeleteRoom" asp-route-id="@r.Id" onsubmit="return confirm('Bạn có chắc muốn xóa phòng này?');">
                                            <button type="submit" class="eb-action-btn delete" title="Xóa phòng học">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                rIdx++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- TAB 3: SLOTS MANAGEMENT -->
    <div id="slots-tab" class="tab-content" style="display: none;">
        <div class="row">
            <div class="col-md-4">
                <div class="eb-card">
                    <h5 class="fw-bold mb-3">Thêm ca học mới</h5>
                    <form method="post" asp-page-handler="CreateSlot">
                        <div class="mb-3">
                            <label class="form-label fw-semibold small text-muted">Tên ca học</label>
                            <input asp-for="SlotInput.SlotName" class="form-control" placeholder="Ví dụ: Ca 1 (Sáng)" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold small text-muted">Giờ bắt đầu</label>
                            <input asp-for="SlotInput.StartTime" type="time" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold small text-muted">Giờ kết thúc</label>
                            <input asp-for="SlotInput.EndTime" type="time" class="form-control" required />
                        </div>
                        <button type="submit" class="eb-btn-primary w-100 justify-content-center">Lưu ca học</button>
                    </form>
                </div>
            </div>
            <div class="col-md-8">
                <div class="eb-card p-0 overflow-hidden">
                    <table class="eb-table">
                        <thead>
                            <tr>
                                <th class="text-center" style="width: 60px;">STT</th>
                                <th>Tên ca học</th>
                                <th>Giờ học</th>
                                <th class="text-center" style="width: 100px;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int sIdx = 1; }
                            @foreach (var s in Model.Slots)
                            {
                                <tr>
                                    <td class="text-center text-muted fw-semibold">@sIdx</td>
                                    <td class="fw-bold">@s.SlotName</td>
                                    <td>
                                        <span class="badge bg-light text-dark border px-3 py-1 font-monospace">
                                            @s.StartTime.ToString(@"hh\:mm") - @s.EndTime.ToString(@"hh\:mm")
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <form method="post" asp-page-handler="DeleteSlot" asp-route-id="@s.Id" onsubmit="return confirm('Bạn có chắc muốn xóa ca học này?');">
                                            <button type="submit" class="eb-action-btn delete" title="Xóa ca học">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                sIdx++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- CREATE CLASS MODAL -->
<div class="modal fade" id="createClassModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header border-bottom px-4 py-3">
                <h5 class="modal-title fw-bold text-dark" style="font-size: 1.35rem;">📝 Thêm lớp học</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="Create">
                <div class="modal-body px-4 py-4" style="background-color: #F8FAFC;">
                    
                    <!-- Section: Thông tin lớp học -->
                    <div class="bg-white rounded-3 p-4 border mb-4">
                        <h6 class="fw-bold text-dark border-bottom pb-2 mb-3">Thông tin lớp học</h6>
                        
                        <div class="row g-3">
                            <!-- Mã lớp -->
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small mb-1">Mã lớp</label>
                                <input class="form-control bg-light" type="text" value="CLS-1-@DateTime.Now.ToString("yyyyMM")-xxxx" readonly disabled style="cursor: not-allowed;" />
                                <span class="text-muted small d-block mt-1">Hệ thống cấp mã chính thức khi lưu lớp.</span>
                            </div>
                            
                            <!-- Tên lớp -->
                            <div class="col-md-6">
                                <label asp-for="CreateDto.ClassName" class="form-label fw-semibold text-muted small mb-1">Tên lớp (*)</label>
                                <input asp-for="CreateDto.ClassName" class="form-control" placeholder="Nhập tên lớp..." required />
                                <span asp-validation-for="CreateDto.ClassName" class="text-danger small"></span>
                            </div>

                            <!-- Môn học -->
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small mb-1">Môn học (*)</label>
                                <select class="form-select" required>
                                    <option value="" selected disabled>Chọn môn học</option>
                                    <option value="ielts">IELTS General</option>
                                    <option value="toeic">TOEIC Intensive</option>
                                    <option value="comm">Tiếng Anh Giao Tiếp</option>
                                </select>
                            </div>

                            <!-- Tổng số buổi -->
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small mb-1">Tổng số buổi (*)</label>
                                <input class="form-control" type="number" placeholder="Ví dụ: 24" value="24" required />
                            </div>

                            <!-- Phòng học -->
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small mb-1">Phòng học (*)</label>
                                <select class="form-select" required>
                                    <option value="" selected disabled>Chọn phòng học</option>
                                    @foreach (var r in Model.Rooms)
                                    {
                                        <option value="@r.Id">@r.RoomName (Sức chứa: @r.Capacity)</option>
                                    }
                                </select>
                            </div>

                            <!-- Sĩ số tối đa -->
                            <div class="col-md-6">
                                <label asp-for="CreateDto.MaxCapacity" class="form-label fw-semibold text-muted small mb-1">Sĩ số tối đa (*)</label>
                                <input asp-for="CreateDto.MaxCapacity" class="form-control" type="number" value="30" required />
                                <span asp-validation-for="CreateDto.MaxCapacity" class="text-danger small"></span>
                            </div>
                            
                            <input asp-for="CreateDto.CenterId" type="hidden" value="1" />
                        </div>
                    </div>

                    <!-- Section: Lịch học -->
                    <div class="bg-white rounded-3 p-4 border">
                        <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-3">
                            <h6 class="fw-bold text-dark mb-0">Lịch học</h6>
                            <button type="button" class="btn btn-primary btn-sm rounded-3 px-3 d-inline-flex align-items-center gap-1" id="btnAddScheduleRow">
                                <i class="bi bi-plus-lg"></i> Thêm lịch
                            </button>
                        </div>

                        <!-- Schedule Rows Container -->
                        <div id="scheduleRowsContainer">
                            <div class="row g-2 align-items-center schedule-row-item mb-2 pb-2 border-bottom">
                                <div class="col-md-3">
                                    <label class="small text-muted fw-semibold d-block mb-1">Thứ (*)</label>
                                    <select class="form-select form-select-sm" required>
                                        <option value="Thứ 2">Thứ 2</option>
                                        <option value="Thứ 3">Thứ 3</option>
                                        <option value="Thứ 4">Thứ 4</option>
                                        <option value="Thứ 5">Thứ 5</option>
                                        <option value="Thứ 6">Thứ 6</option>
                                        <option value="Thứ 7">Thứ 7</option>
                                        <option value="Chủ nhật">Chủ nhật</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="small text-muted fw-semibold d-block mb-1">Ca học gợi ý</label>
                                    <select class="form-select form-select-sm slot-suggestion-select" onchange="onSlotSuggestionChanged(this)">
                                        <option value="" selected>Tự chọn giờ</option>
                                        @foreach (var s in Model.Slots)
                                        {
                                            <option value="@s.Id" data-start="@s.StartTime.ToString(@"hh\:mm")" data-end="@s.EndTime.ToString(@"hh\:mm")">@s.SlotName (@s.StartTime.ToString(@"hh\:mm") - @s.EndTime.ToString(@"hh\:mm"))</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <label class="small text-muted fw-semibold d-block mb-1">Giờ bắt đầu (*)</label>
                                    <input type="time" class="form-control form-control-sm start-time-input" required />
                                </div>
                                <div class="col-md-2">
                                    <label class="small text-muted fw-semibold d-block mb-1">Giờ kết thúc (*)</label>
                                    <input type="time" class="form-control form-control-sm end-time-input" required />
                                </div>
                                <div class="col-md-1 text-end">
                                    <label class="small text-muted fw-semibold d-block mb-1" style="visibility: hidden;">Xóa</label>
                                    <button type="button" class="btn btn-outline-danger btn-sm border-0 mt-1" onclick="removeScheduleRow(this)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
                <div class="modal-footer border-top px-4 py-3" style="background-color: #F8FAFC;">
                    <button type="button" class="btn btn-light rounded-3 border px-4 py-2 fw-semibold" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary rounded-3 px-4 py-2 fw-semibold" style="background: var(--eb-indigo-gradient); border: none;">Lưu lớp học</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- EDIT CLASS MODAL -->
<div class="modal fade" id="editClassModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header border-bottom px-4 py-3">
                <h5 class="modal-title fw-bold text-dark" style="font-size: 1.35rem;">✏️ Sửa lớp học</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="Update">
                <input type="hidden" asp-for="UpdateDto.Id" id="editClassId" />
                <div class="modal-body px-4 py-4" style="background-color: #F8FAFC;">
                    
                    <!-- Section: Thông tin lớp học -->
                    <div class="bg-white rounded-3 p-4 border mb-4">
                        <h6 class="fw-bold text-dark border-bottom pb-2 mb-3">Thông tin lớp học</h6>
                        
                        <div class="row g-3">
                            <!-- Mã lớp -->
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small mb-1">Mã lớp</label>
                                <input class="form-control bg-light" type="text" id="editClassCode" readonly disabled style="cursor: not-allowed;" />
                            </div>
                            
                            <!-- Tên lớp -->
                            <div class="col-md-6">
                                <label asp-for="UpdateDto.ClassName" class="form-label fw-semibold text-muted small mb-1">Tên lớp (*)</label>
                                <input asp-for="UpdateDto.ClassName" class="form-control" id="editClassName" required />
                                <span asp-validation-for="UpdateDto.ClassName" class="text-danger small"></span>
                            </div>

                            <!-- Môn học -->
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small mb-1">Môn học (*)</label>
                                <select class="form-select" id="editClassSubject" required>
                                    <option value="ielts">IELTS General</option>
                                    <option value="toeic">TOEIC Intensive</option>
                                    <option value="comm" selected>Tiếng Anh Giao Tiếp</option>
                                </select>
                            </div>

                            <!-- Tổng số buổi -->
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small mb-1">Tổng số buổi (*)</label>
                                <input class="form-control" type="number" id="editTotalLessons" value="24" required />
                            </div>

                            <!-- Phòng học -->
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted small mb-1">Phòng học (*)</label>
                                <select class="form-select" id="editClassRoom" required>
                                    @foreach (var r in Model.Rooms)
                                    {
                                        <option value="@r.Id">@r.RoomName (Sức chứa: @r.Capacity)</option>
                                    }
                                </select>
                            </div>

                            <!-- Sĩ số tối đa -->
                            <div class="col-md-6">
                                <label asp-for="UpdateDto.MaxCapacity" class="form-label fw-semibold text-muted small mb-1">Sĩ số tối đa (*)</label>
                                <input asp-for="UpdateDto.MaxCapacity" class="form-control" type="number" id="editMaxCapacity" required />
                                <span asp-validation-for="UpdateDto.MaxCapacity" class="text-danger small"></span>
                            </div>
                            
                            <input asp-for="UpdateDto.CenterId" type="hidden" id="editCenterId" value="1" />
                        </div>
                    </div>

                    <!-- Section: Lịch học -->
                    <div class="bg-white rounded-3 p-4 border">
                        <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-3">
                            <h6 class="fw-bold text-dark mb-0">Lịch học</h6>
                            <button type="button" class="btn btn-primary btn-sm rounded-3 px-3 d-inline-flex align-items-center gap-1" id="btnEditAddScheduleRow">
                                <i class="bi bi-plus-lg"></i> Thêm lịch
                            </button>
                        </div>

                        <!-- Schedule Rows Container -->
                        <div id="editScheduleRowsContainer">
                            <div class="row g-2 align-items-center edit-schedule-row-item mb-2 pb-2 border-bottom">
                                <div class="col-md-3">
                                    <label class="small text-muted fw-semibold d-block mb-1">Thứ (*)</label>
                                    <select class="form-select form-select-sm" required>
                                        <option value="Thứ 2">Thứ 2</option>
                                        <option value="Thứ 3">Thứ 3</option>
                                        <option value="Thứ 4">Thứ 4</option>
                                        <option value="Thứ 5">Thứ 5</option>
                                        <option value="Thứ 6">Thứ 6</option>
                                        <option value="Thứ 7">Thứ 7</option>
                                        <option value="Chủ nhật">Chủ nhật</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="small text-muted fw-semibold d-block mb-1">Ca học gợi ý</label>
                                    <select class="form-select form-select-sm slot-suggestion-select" onchange="onSlotSuggestionChanged(this)">
                                        <option value="" selected>Tự chọn giờ</option>
                                        @foreach (var s in Model.Slots)
                                        {
                                            <option value="@s.Id" data-start="@s.StartTime.ToString(@"hh\:mm")" data-end="@s.EndTime.ToString(@"hh\:mm")">@s.SlotName (@s.StartTime.ToString(@"hh\:mm") - @s.EndTime.ToString(@"hh\:mm"))</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <label class="small text-muted fw-semibold d-block mb-1">Giờ bắt đầu (*)</label>
                                    <input type="time" class="form-control form-control-sm start-time-input" required />
                                </div>
                                <div class="col-md-2">
                                    <label class="small text-muted fw-semibold d-block mb-1">Giờ kết thúc (*)</label>
                                    <input type="time" class="form-control form-control-sm end-time-input" required />
                                </div>
                                <div class="col-md-1 text-end">
                                    <label class="small text-muted fw-semibold d-block mb-1" style="visibility: hidden;">Xóa</label>
                                    <button type="button" class="btn btn-outline-danger btn-sm border-0 mt-1" onclick="removeEditScheduleRow(this)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
                <div class="modal-footer border-top px-4 py-3" style="background-color: #F8FAFC;">
                    <button type="button" class="btn btn-light rounded-3 border px-4 py-2 fw-semibold" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary rounded-3 px-4 py-2 fw-semibold" style="background: var(--eb-indigo-gradient); border: none;">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        function switchTab(tabId, el) {
            $('.tab-content').hide();
            $('#' + tabId).show();
            $('.eb-nav-tab').removeClass('active');
            $(el).addClass('active');
        }

        function openEditModal(id, name, centerId, maxCapacity) {
            document.getElementById('editClassId').value = id;
            document.getElementById('editClassName').value = name;
            document.getElementById('editCenterId').value = centerId;
            document.getElementById('editMaxCapacity').value = maxCapacity;

            // Generate class code representation
            const formattedId = ("0000" + id).slice(-4);
            document.getElementById('editClassCode').value = `CLS-${centerId}-${new Date().getFullYear()}${("0" + (new Date().getMonth() + 1)).slice(-2)}-${formattedId}`;

            // Fetch dynamic schedule and slots
            const container = document.getElementById('editScheduleRowsContainer');
            container.innerHTML = '<div class="text-center py-3"><div class="spinner-border spinner-border-sm text-primary" role="status"></div> Loading schedule...</div>';

            fetch(`${window.location.pathname}?handler=ClassLessons&classId=${id}`)
                .then(res => res.json())
                .then(lessons => {
                    console.log("Lessons retrieved:", lessons);
                    container.innerHTML = '';
                    if (!lessons || lessons.length === 0) {
                        container.innerHTML = '<div class="text-muted small text-center py-2">Chưa thiết lập lịch học cho lớp này. Hãy bấm Thêm lịch để tạo!</div>';
                        return;
                    }

                    const slotsOptions = document.querySelector('.slot-suggestion-select').innerHTML;

                    lessons.forEach((l, idx) => {
                        const newRow = document.createElement('div');
                        newRow.className = 'row g-2 align-items-center edit-schedule-row-item mb-2 pb-2 border-bottom';
                        
                        // Map DayOfWeek number to Vietnam Day String
                        const daysMap = { 0: "Chủ nhật", 1: "Thứ 2", 2: "Thứ 3", 3: "Thứ 4", 4: "Thứ 5", 5: "Thứ 6", 6: "Thứ 7" };
                        const vnDay = daysMap[l.dayOfWeek] || "Thứ 2";

                        newRow.innerHTML = `
                            <div class="col-md-3">
                                <select class="form-select form-select-sm edit-day-select" required>
                                    <option value="Thứ 2" ${vnDay === "Thứ 2" ? "selected" : ""}>Thứ 2</option>
                                    <option value="Thứ 3" ${vnDay === "Thứ 3" ? "selected" : ""}>Thứ 3</option>
                                    <option value="Thứ 4" ${vnDay === "Thứ 4" ? "selected" : ""}>Thứ 4</option>
                                    <option value="Thứ 5" ${vnDay === "Thứ 5" ? "selected" : ""}>Thứ 5</option>
                                    <option value="Thứ 6" ${vnDay === "Thứ 6" ? "selected" : ""}>Thứ 6</option>
                                    <option value="Thứ 7" ${vnDay === "Thứ 7" ? "selected" : ""}>Thứ 7</option>
                                    <option value="Chủ nhật" ${vnDay === "Chủ nhật" ? "selected" : ""}>Chủ nhật</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <select class="form-select form-select-sm slot-suggestion-select" onchange="onSlotSuggestionChanged(this)">
                                    ${slotsOptions}
                                </select>
                            </div>
                            <div class="col-md-2">
                                <input type="time" class="form-control form-control-sm start-time-input" required />
                            </div>
                            <div class="col-md-2">
                                <input type="time" class="form-control form-control-sm end-time-input" required />
                            </div>
                            <div class="col-md-1 text-end">
                                <button type="button" class="btn btn-outline-danger btn-sm border-0 mt-1" onclick="removeEditScheduleRow(this)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        `;

                        container.appendChild(newRow);

                        // If slot ID is present, trigger automatic slot value population AFTER append
                        const selectElement = newRow.querySelector('.slot-suggestion-select');
                        if (l.slotId && selectElement) {
                            selectElement.value = l.slotId;
                            onSlotSuggestionChanged(selectElement);
                        }

                        // Update edit room select based on the first lesson room
                        if (idx === 0 && l.roomId) {
                            document.getElementById('editClassRoom').value = l.roomId;
                        }
                    });
                })
                .catch(err => {
                    console.error("Fetch schedule error:", err);
                    container.innerHTML = '<div class="text-danger small text-center py-2">Không thể tải lịch học.</div>';
                });
        }

        function applyFilters() {
            var classNameFilter = $('#filterClassName').val().toLowerCase().trim();
            var statusFilter = $('#filterStatus').val();

            $('.class-row').each(function() {
                var row = $(this);
                var cName = row.data('class-name').toLowerCase();
                var cId = row.data('class-id').toString();
                var status = row.data('status');

                var matches = true;

                if (classNameFilter && !cName.includes(classNameFilter) && !cId.includes(classNameFilter)) {
                    matches = false;
                }
                if (statusFilter && status !== statusFilter) {
                    matches = false;
                }

                if (matches) {
                    row.show();
                } else {
                    row.hide();
                }
            });
        }

        function resetFilters() {
            $('#filterClassName').val('');
            $('#filterStatus').val('');
            $('.class-row').show();
        }

        // --- DYNAMIC SCHEDULING INTERACTION SCRIPTS ---
        document.getElementById('btnAddScheduleRow').addEventListener('click', function() {
            const container = document.getElementById('scheduleRowsContainer');
            
            // Clone first row structure
            const newRow = document.createElement('div');
            newRow.className = 'row g-2 align-items-center schedule-row-item mb-2 pb-2 border-bottom';
            
            // Get slots dropdown options dynamically
            const slotsOptions = document.querySelector('.slot-suggestion-select').innerHTML;

            newRow.innerHTML = `
                <div class="col-md-3">
                    <select class="form-select form-select-sm" required>
                        <option value="Thứ 2">Thứ 2</option>
                        <option value="Thứ 3">Thứ 3</option>
                        <option value="Thứ 4">Thứ 4</option>
                        <option value="Thứ 5">Thứ 5</option>
                        <option value="Thứ 6">Thứ 6</option>
                        <option value="Thứ 7">Thứ 7</option>
                        <option value="Chủ nhật">Chủ nhật</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <select class="form-select form-select-sm slot-suggestion-select" onchange="onSlotSuggestionChanged(this)">
                        ${slotsOptions}
                    </select>
                </div>
                <div class="col-md-2">
                    <input type="time" class="form-control form-control-sm start-time-input" required />
                </div>
                <div class="col-md-2">
                    <input type="time" class="form-control form-control-sm end-time-input" required />
                </div>
                <div class="col-md-1 text-end">
                    <button type="button" class="btn btn-outline-danger btn-sm border-0 mt-1" onclick="removeScheduleRow(this)">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            `;
            container.appendChild(newRow);
        });

        function removeScheduleRow(button) {
            const rows = document.querySelectorAll('.schedule-row-item');
            if (rows.length > 1) {
                button.closest('.schedule-row-item').remove();
            } else {
                alert("Lớp học phải đăng ký tối thiểu một lịch học!");
            }
        }

        function onSlotSuggestionChanged(selectElement) {
            const selectedOption = selectElement.options[selectElement.selectedIndex];
            const row = selectElement.closest('.schedule-row-item, .edit-schedule-row-item');
            const startTimeInput = row.querySelector('.start-time-input');
            const endTimeInput = row.querySelector('.end-time-input');

            if (selectedOption && selectedOption.value !== "") {
                const startVal = selectedOption.getAttribute('data-start');
                const endVal = selectedOption.getAttribute('data-end');
                startTimeInput.value = startVal;
                endTimeInput.value = endVal;
            } else {
                startTimeInput.value = "";
                endTimeInput.value = "";
            }
        }

        // --- EDIT MODAL DYNAMIC SCHEDULING SCRIPTS ---
        const btnEditAdd = document.getElementById('btnEditAddScheduleRow');
        if (btnEditAdd) {
            btnEditAdd.addEventListener('click', function() {
                const container = document.getElementById('editScheduleRowsContainer');
                const newRow = document.createElement('div');
                newRow.className = 'row g-2 align-items-center edit-schedule-row-item mb-2 pb-2 border-bottom';
                
                // Reuse slot options
                const slotsOptions = document.querySelector('.slot-suggestion-select').innerHTML;

                newRow.innerHTML = `
                    <div class="col-md-3">
                        <select class="form-select form-select-sm" required>
                            <option value="Thứ 2">Thứ 2</option>
                            <option value="Thứ 3">Thứ 3</option>
                            <option value="Thứ 4">Thứ 4</option>
                            <option value="Thứ 5">Thứ 5</option>
                            <option value="Thứ 6">Thứ 6</option>
                            <option value="Thứ 7">Thứ 7</option>
                            <option value="Chủ nhật">Chủ nhật</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <select class="form-select form-select-sm slot-suggestion-select" onchange="onSlotSuggestionChanged(this)">
                            ${slotsOptions}
                        </select>
                    </div>
                    <div class="col-md-2">
                        <input type="time" class="form-control form-control-sm start-time-input" required />
                    </div>
                    <div class="col-md-2">
                        <input type="time" class="form-control form-control-sm end-time-input" required />
                    </div>
                    <div class="col-md-1 text-end">
                        <button type="button" class="btn btn-outline-danger btn-sm border-0 mt-1" onclick="removeEditScheduleRow(this)">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                `;
                container.appendChild(newRow);
            });
        }

        function removeEditScheduleRow(button) {
            const rows = document.querySelectorAll('.edit-schedule-row-item');
            if (rows.length > 1) {
                button.closest('.edit-schedule-row-item').remove();
            } else {
                alert("Lớp học phải đăng ký tối thiểu một lịch học!");
            }
        }
    </script>
}
