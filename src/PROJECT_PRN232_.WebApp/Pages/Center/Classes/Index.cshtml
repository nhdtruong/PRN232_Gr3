@page
@model PROJECT_PRN232_.WebApp.Pages.Center.Classes.IndexModel
@{
    ViewData["Title"] = "Quản lý Lớp học";
}

<!-- Custom Styles for Premium Indigo Table Design -->
<style>
    :root {
        --eb-indigo-gradient: linear-gradient(135deg, #4F46E5, #7C3AED);
        --eb-indigo-hover: #4338CA;
        --eb-indigo-light: #EEF2FF;
        --eb-indigo-border: #E0E7FF;
        --eb-text-dark: #1E293B;
        --eb-text-muted: #64748B;
        --eb-bg-light: #F8FAFC;
    }

    .eb-card {
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid var(--eb-indigo-border);
        box-shadow: 0 4px 20px rgba(79, 70, 229, 0.04);
        padding: 24px;
        margin-bottom: 24px;
    }

    .eb-nav-tabs {
        border-bottom: 2px solid #E2E8F0;
        margin-bottom: 24px;
        display: flex;
        gap: 8px;
    }

    .eb-nav-tab {
        font-weight: 600;
        font-size: 0.95rem;
        color: var(--eb-text-muted);
        padding: 12px 16px;
        text-decoration: none;
        border-bottom: 3px solid transparent;
        transition: all 0.25s ease;
    }

    .eb-nav-tab:hover, .eb-nav-tab.active {
        color: #4F46E5;
        border-bottom-color: #4F46E5;
    }

    .form-control, .form-select {
        border: 1px solid #CBD5E1;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 0.9rem;
        transition: all 0.2s ease;
    }

    .form-control:focus, .form-select:focus {
        border-color: #6366F1;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
    }

    .eb-btn-primary {
        background: var(--eb-indigo-gradient);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 600;
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 12px rgba(79, 70, 229, 0.2);
        transition: all 0.25s ease;
        text-decoration: none;
    }

    .eb-btn-primary:hover {
        background: var(--eb-indigo-hover);
        color: #fff;
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(79, 70, 229, 0.3);
    }

    .eb-btn-outline {
        border: 1px solid #CBD5E1;
        background: #fff;
        color: var(--eb-text-dark);
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.25s ease;
    }

    .eb-btn-outline:hover {
        background: var(--eb-bg-light);
        border-color: #94A3B8;
    }

    .eb-table {
        width: 100%;
        margin-bottom: 0;
        border-collapse: separate;
        border-spacing: 0;
    }

    .eb-table th {
        background: #F1F5F9;
        color: var(--eb-text-dark);
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 14px 16px;
        border-bottom: 2px solid #E2E8F0;
    }

    .eb-table td {
        padding: 16px;
        vertical-align: middle;
        border-bottom: 1px solid #F1F5F9;
        color: var(--eb-text-dark);
        font-size: 0.92rem;
    }

    .eb-table tr:hover td {
        background-color: #F8FAFC;
    }

    .badge-active {
        background-color: #DCFCE7;
        color: #15803D;
        font-weight: 600;
        font-size: 0.8rem;
        padding: 6px 12px;
        border-radius: 20px;
        border: 1px solid #BBF7D0;
    }

    .badge-closed {
        background-color: #FEE2E2;
        color: #B91C1C;
        font-weight: 600;
        font-size: 0.8rem;
        padding: 6px 12px;
        border-radius: 20px;
        border: 1px solid #FCA5A5;
    }

    .eb-action-btn {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #E2E8F0;
        background: #fff;
        color: var(--eb-text-muted);
        transition: all 0.25s ease;
        text-decoration: none;
    }

    .eb-action-btn:hover {
        transform: scale(1.08);
    }

    .eb-action-btn.view:hover {
        background-color: #EFF6FF;
        color: #2563EB;
        border-color: #BFDBFE;
    }

    .eb-action-btn.edit:hover {
        background-color: #FFFBEB;
        color: #D97706;
        border-color: #FDE68A;
    }

    .eb-action-btn.delete:hover {
        background-color: #FEF2F2;
        color: #DC2626;
        border-color: #FECACA;
    }

    .pagination-wrapper {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 24px;
        border-top: 1px solid #E2E8F0;
        padding-top: 16px;
    }
</style>

<div class="container-fluid py-4" style="max-width: 1400px;">
    <!-- Title Section -->
    <div class="mb-4">
        <h1 class="fw-bold text-dark mb-1" style="font-size: 1.85rem;">Quản lý lớp học</h1>
        <p class="text-muted mb-0">Quản lý thông tin các lớp học</p>
    </div>

    <!-- Navigation Tabs -->
    <div class="eb-nav-tabs">
        <a href="/Center/Classes/Index" class="eb-nav-tab active">Danh sách lớp học</a>
        <a href="#" class="eb-nav-tab">Quản lý phòng học</a>
        <a href="#" class="eb-nav-tab">Quản lý ca học</a>
    </div>

    <!-- Filter Card -->
    <div class="eb-card">
        <h5 class="fw-bold mb-3" style="color: var(--eb-text-dark);">Danh sách lớp học</h5>
        <div class="row g-3">
            <div class="col-md-3">
                <input type="text" id="filterClassName" class="form-control" placeholder="Tìm tên/mã lớp...">
            </div>
            <div class="col-md-3">
                <input type="text" id="filterTeacher" class="form-control" placeholder="Tên giáo viên">
            </div>
            <div class="col-md-2">
                <select id="filterSubject" class="form-select">
                    <option value="">Môn học</option>
                    <option value="Kids English A1">Kids English A1</option>
                </select>
            </div>
            <div class="col-md-2">
                <select id="filterRoom" class="form-select">
                    <option value="">Phòng học</option>
                    <option value="Phòng Test 01">Phòng Test 01</option>
                    <option value="Phòng Test 02">Phòng Test 02</option>
                    <option value="Phòng 101">Phòng 101</option>
                </select>
            </div>
            <div class="col-md-2">
                <select id="filterStatus" class="form-select">
                    <option value="">Trạng thái</option>
                    <option value="Active">Đang hoạt động</option>
                    <option value="Closed">Đã đóng</option>
                </select>
            </div>
            <div class="col-md-3">
                <div class="input-group">
                    <input type="text" id="filterStartDate" class="form-control" placeholder="Ngày khai giảng" onfocus="(this.type='date')" onblur="(this.type='text')">
                    <span class="input-group-text bg-white border-start-0" style="border-radius: 0 10px 10px 0;"><i class="bi bi-calendar3" style="color: #4F46E5;"></i></span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="input-group">
                    <input type="text" id="filterEndDate" class="form-control" placeholder="Ngày kết thúc" onfocus="(this.type='date')" onblur="(this.type='text')">
                    <span class="input-group-text bg-white border-start-0" style="border-radius: 0 10px 10px 0;"><i class="bi bi-calendar3" style="color: #4F46E5;"></i></span>
                </div>
            </div>
            <div class="col-md-6 d-flex justify-content-between align-items-center">
                <button class="eb-btn-primary" data-bs-toggle="modal" data-bs-target="#createClassModal">
                    <i class="bi bi-plus-lg"></i> Thêm lớp mới
                </button>
                <div class="d-flex gap-2">
                    <button class="eb-btn-outline" onclick="resetFilters()">Làm mới bộ lọc</button>
                    <button class="eb-btn-primary" onclick="applyFilters()">
                        <i class="bi bi-search"></i> Tìm kiếm
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Alert Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm border-0" role="alert" style="background-color: #DCFCE7; color: #15803D;">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm border-0" role="alert" style="background-color: #FEE2E2; color: #B91C1C;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Table Card -->
    <div class="eb-card p-0 overflow-hidden" style="border-radius: 12px;">
        <div class="table-responsive">
            <table class="eb-table table-hover">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 60px;">STT</th>
                        <th style="width: 80px;">ID</th>
                        <th style="width: 120px;">Mã lớp</th>
                        <th>Tên lớp</th>
                        <th>Môn học</th>
                        <th>Giáo viên</th>
                        <th class="text-center" style="width: 85px;">Sĩ số</th>
                        <th>Lịch học</th>
                        <th>Thời gian học</th>
                        <th>Phòng</th>
                        <th style="width: 150px;">Trạng thái</th>
                        <th class="text-center" style="width: 140px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="classTableBody">
                    @{
                        int index = 1;
                    }
                    @foreach (var c in Model.Classes)
                    {
                        var classCode = $"CLS{c.Id:D4}";
                        var startDateStr = c.StartDate?.ToString("dd/MM/yyyy") ?? "01/05/2026";
                        var endDateStr = c.EndDate?.ToString("dd/MM/yyyy") ?? "01/08/2026";
                        var displayTeacher = "Phạm Quốc Huy";
                        var displaySubject = "Kids English A1";
                        var displaySchedule = c.Id % 2 == 0 ? "Thứ 2, Thứ 4 - 18:00" : "Thứ 4 18:00-20:00";
                        var displayRoom = $"Phòng Test {c.Id:D2}";
                        
                        <tr class="class-row" 
                            data-class-name="@c.ClassName" 
                            data-class-id="@c.Id"
                            data-teacher="@displayTeacher"
                            data-subject="@displaySubject"
                            data-room="@displayRoom"
                            data-status="@c.Status"
                            data-start-date="@(c.StartDate?.ToString("yyyy-MM-dd") ?? "2026-05-01")"
                            data-end-date="@(c.EndDate?.ToString("yyyy-MM-dd") ?? "2026-08-01")">
                            
                            <td class="text-center fw-semibold text-muted">@index</td>
                            <td class="fw-semibold">@c.Id</td>
                            <td><span class="text-primary fw-bold">@classCode</span></td>
                            <td class="fw-bold" style="color: var(--eb-text-dark);">@c.ClassName</td>
                            <td><span class="text-muted small fw-semibold">@displaySubject</span></td>
                            <td class="fw-semibold">@displayTeacher</td>
                            <td class="text-center">
                                <span class="text-muted fw-semibold"><i class="bi bi-people me-1"></i>@c.StudentCount</span>
                            </td>
                            <td class="small fw-semibold text-muted">@displaySchedule</td>
                            <td class="small text-muted">
                                @startDateStr - <br>@endDateStr
                            </td>
                            <td><span class="badge bg-light text-dark border px-2 py-1 small">@displayRoom</span></td>
                            <td>
                                @if (c.Status == "Active")
                                {
                                    <span class="badge-active">Đang hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge-closed">Đã đóng</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-inline-flex gap-2">
                                    <a asp-page="/Center/Classes/Students" asp-route-classId="@c.Id" class="eb-action-btn view" title="Xem danh sách học viên">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    
                                    <button class="eb-action-btn edit" onclick="openEditModal(@c.Id, '@c.ClassName', @c.CenterId)" data-bs-toggle="modal" data-bs-target="#editClassModal" title="Sửa thông tin lớp">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@c.Id" onsubmit="return confirm('Bạn có chắc chắn muốn xóa lớp học này?');" style="display:inline;">
                                        <button type="submit" class="eb-action-btn delete" title="Xóa lớp học">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        index++;
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination Section -->
        <div class="px-4 pb-3">
            <div class="pagination-wrapper">
                <div class="text-muted small">
                    Tổng số: <strong id="totalCount">@Model.Classes.Count()</strong> bản ghi
                </div>
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item disabled"><a class="page-link" href="#"><i class="bi bi-chevron-double-left"></i></a></li>
                        <li class="page-item disabled"><a class="page-link" href="#"><i class="bi bi-chevron-left"></i></a></li>
                        <li class="page-item active"><a class="page-link" href="#">1</a></li>
                        <li class="page-item disabled"><a class="page-link" href="#"><i class="bi bi-chevron-right"></i></a></li>
                        <li class="page-item disabled"><a class="page-link" href="#"><i class="bi bi-chevron-double-right"></i></a></li>
                    </ul>
                </nav>
                <div>
                    <select class="form-select form-select-sm" style="width: 70px;">
                        <option value="20">20</option>
                        <option value="50">50</option>
                    </select>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- CREATE CLASS MODAL -->
<div class="modal fade" id="createClassModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" style="color: var(--eb-text-dark); font-size: 1.25rem;">Tạo Lớp Học Mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="Create">
                <div class="modal-body py-3">
                    <div class="mb-3">
                        <label asp-for="CreateDto.ClassName" class="form-label fw-semibold text-muted small">Tên lớp học</label>
                        <input asp-for="CreateDto.ClassName" class="form-control" placeholder="Nhập tên lớp..." required>
                        <span asp-validation-for="CreateDto.ClassName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="CreateDto.CenterId" class="form-label fw-semibold text-muted small">Mã Trung Tâm</label>
                        <input asp-for="CreateDto.CenterId" class="form-control" type="number" value="1" readonly required>
                        <span asp-validation-for="CreateDto.CenterId" class="text-danger small"></span>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="eb-btn-outline py-2" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="eb-btn-primary py-2">Tạo Lớp</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- EDIT CLASS MODAL -->
<div class="modal fade" id="editClassModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" style="color: var(--eb-text-dark); font-size: 1.25rem;">Sửa Lớp Học</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="Update">
                <input type="hidden" asp-for="UpdateDto.Id" id="editClassId" />
                <div class="modal-body py-3">
                    <div class="mb-3">
                        <label asp-for="UpdateDto.ClassName" class="form-label fw-semibold text-muted small">Tên lớp học</label>
                        <input asp-for="UpdateDto.ClassName" class="form-control" id="editClassName" required>
                        <span asp-validation-for="UpdateDto.ClassName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="UpdateDto.CenterId" class="form-label fw-semibold text-muted small">Mã Trung Tâm</label>
                        <input asp-for="UpdateDto.CenterId" class="form-control" type="number" id="editCenterId" readonly required>
                        <span asp-validation-for="UpdateDto.CenterId" class="text-danger small"></span>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="eb-btn-outline py-2" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="eb-btn-primary py-2">Lưu Thay Đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        function openEditModal(id, name, centerId) {
            document.getElementById('editClassId').value = id;
            document.getElementById('editClassName').value = name;
            document.getElementById('editCenterId').value = centerId;
        }

        function applyFilters() {
            var classNameFilter = $('#filterClassName').val().toLowerCase().trim();
            var teacherFilter = $('#filterTeacher').val().toLowerCase().trim();
            var subjectFilter = $('#filterSubject').val();
            var roomFilter = $('#filterRoom').val();
            var statusFilter = $('#filterStatus').val();
            var startDateFilter = $('#filterStartDate').val();
            var endDateFilter = $('#filterEndDate').val();

            var visibleCount = 0;

            $('.class-row').each(function() {
                var row = $(this);
                var cName = row.data('class-name').toLowerCase();
                var cId = row.data('class-id').toString();
                var teacher = row.data('teacher').toLowerCase();
                var subject = row.data('subject');
                var room = row.data('room');
                var status = row.data('status');
                var sDate = row.data('start-date');
                var eDate = row.data('end-date');

                var matches = true;

                if (classNameFilter && !cName.includes(classNameFilter) && !cId.includes(classNameFilter)) {
                    matches = false;
                }
                if (teacherFilter && !teacher.includes(teacherFilter)) {
                    matches = false;
                }
                if (subjectFilter && subject !== subjectFilter) {
                    matches = false;
                }
                if (roomFilter && room !== roomFilter) {
                    matches = false;
                }
                if (statusFilter && status !== statusFilter) {
                    matches = false;
                }
                if (startDateFilter && sDate < startDateFilter) {
                    matches = false;
                }
                if (endDateFilter && eDate > endDateFilter) {
                    matches = false;
                }

                if (matches) {
                    row.show();
                    visibleCount++;
                } else {
                    row.hide();
                }
            });

            $('#totalCount').text(visibleCount);
        }

        function resetFilters() {
            $('#filterClassName').val('');
            $('#filterTeacher').val('');
            $('#filterSubject').val('');
            $('#filterRoom').val('');
            $('#filterStatus').val('');
            $('#filterStartDate').val('');
            $('#filterEndDate').val('');
            $('.class-row').show();
            $('#totalCount').text($('.class-row').length);
        }
    </script>
}
