@page
@model PROJECT_PRN232_.WebApp.Pages.Center.Parents.IndexModel

@{
    ViewData["Title"] = "Danh sách Phụ huynh";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Danh sách Phụ huynh</h2>
        <a asp-page="./Create" class="btn btn-primary">Thêm phụ huynh mới</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover table-bordered mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Họ và Tên</th>
                        <th>Tên đăng nhập</th>
                        <th>Email</th>
                        <th>Số điện thoại</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var parent in Model.ParentUsers)
                    {
                        <tr>
                            <td>@parent.Id</td>
                            <td>@parent.FullName</td>
                            <td>@parent.Username</td>
                            <td>@parent.Email</td>
                            <td>@parent.Phone</td>
                            <td>
                                @if(parent.IsActive)
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Khóa</span>
                                }
                            </td>
                            <td>@parent.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-page="./Details" asp-route-id="@parent.Id" class="btn btn-sm btn-info text-white">Chi tiết</a>
                                    <a asp-page="./Edit" asp-route-id="@parent.Id" class="btn btn-sm btn-warning text-white">Sửa</a>
                                    <a href="/Center/Chat/Index?parentId=@parent.Id" class="btn btn-sm btn-success" title="Nhắn tin"><i class="bi bi-chat-dots"></i> Nhắn tin</a>
                                    <form method="post" asp-page-handler="ToggleStatus" asp-route-id="@parent.Id" onsubmit="return confirm('Bạn có chắc chắn muốn @(parent.IsActive ? "khóa" : "mở khóa") tài khoản này?');" style="display:inline;">
                                        <button type="submit" class="btn btn-sm @(parent.IsActive ? "btn-danger" : "btn-success")">
                                            @(parent.IsActive ? "Khóa" : "Mở khóa")
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if(!Model.ParentUsers.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center">Chưa có dữ liệu phụ huynh.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
