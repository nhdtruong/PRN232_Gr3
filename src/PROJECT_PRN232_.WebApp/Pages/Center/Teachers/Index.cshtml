@page
@model PROJECT_PRN232_.WebApp.Pages.Center.Teachers.IndexModel
@{
    ViewData["Title"] = "Quản lý Giáo viên - REST API";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold text-dark">👨‍🏫 Quản lý Giáo viên</h2>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createTeacherModal">
            <i class="bi bi-plus-lg me-1"></i> Thêm giáo viên mới
        </button>
    </div>

    <div id="alertContainer"></div>

    <!-- Thanh lọc -->
    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body py-3">
            <div class="row g-2 align-items-end">
                <div class="col-md-7">
                    <label class="form-label small fw-semibold text-muted mb-1">🔍 Tìm kiếm theo ID hoặc Tên</label>
                    <input type="text" id="searchInput" class="form-control" placeholder="Nhập ID hoặc tên giáo viên..." />
                </div>
                <div class="col-md-5 d-flex gap-2">
                    <button class="btn btn-secondary flex-fill" onclick="filterTeachers()">
                        <i class="bi bi-search me-1"></i> Tìm kiếm
                    </button>
                    <button class="btn btn-outline-secondary flex-fill" onclick="resetFilter()">
                        <i class="bi bi-arrow-clockwise me-1"></i> Làm mới
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light text-uppercase font-semibold" style="font-size: 0.85rem;">
                        <tr>
                            <th class="ps-3">ID</th>
                            <th>Họ và Tên</th>
                            <th>Tên đăng nhập</th>
                            <th>Email</th>
                            <th>Số điện thoại</th>
                            <th>Trạng thái</th>
                            <th>Ngày tạo</th>
                            <th class="text-center" style="width: 250px;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody id="teachersTableBody">
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <span class="spinner-border spinner-border-sm text-primary me-2" role="status"></span> Đang tải dữ liệu giáo viên...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="d-flex justify-content-center mt-4" id="teachersPagination"></div>
</div>

<!-- CREATE TEACHER MODAL -->
<div class="modal fade" id="createTeacherModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-3 border-0 shadow-lg">
            <div class="modal-header px-4 py-3">
                <h5 class="modal-title fw-bold text-dark">📝 Tạo tài khoản giáo viên</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="createTeacherForm" novalidate>
                <div class="modal-body px-4 py-3" style="background-color: #F8FAFC;">
                    <div class="create-error-container"></div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Họ và Tên (*)</label>
                        <input id="createFullName" class="form-control" placeholder="Họ và tên..." required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Tên đăng nhập (*)</label>
                        <input id="createUsername" class="form-control" placeholder="Tên đăng nhập..." required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Mật khẩu (*)</label>
                        <input id="createPassword" type="password" class="form-control" placeholder="Mật khẩu..." required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Email</label>
                        <input id="createEmail" type="email" class="form-control" placeholder="example@gmail.com" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Số điện thoại</label>
                        <input id="createPhone" class="form-control" placeholder="Số điện thoại..." />
                    </div>
                </div>
                <div class="modal-footer border-top px-4 py-3" style="background-color: #F8FAFC;">
                    <button type="button" class="btn btn-light border px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary px-4">Lưu giáo viên</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- EDIT TEACHER MODAL -->
<div class="modal fade" id="editTeacherModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-3 border-0 shadow-lg">
            <div class="modal-header px-4 py-3">
                <h5 class="modal-title fw-bold text-dark">✏️ Cập nhật thông tin giáo viên</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="editTeacherForm" novalidate>
                <input type="hidden" id="editTeacherId" />
                <div class="modal-body px-4 py-3" style="background-color: #F8FAFC;">
                    <div class="edit-error-container"></div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Họ và Tên (*)</label>
                        <input id="editFullName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Email</label>
                        <input id="editEmail" type="email" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Số điện thoại</label>
                        <input id="editPhone" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer border-top px-4 py-3" style="background-color: #F8FAFC;">
                    <button type="button" class="btn btn-light border px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary px-4">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        let currentTeachers = [];
        let filteredTeachers = [];
        let currentPage = 1;
        const pageSize = 10;

        function filterTeachers() {
            const query = document.getElementById('searchInput').value.toLowerCase().trim();
            filteredTeachers = currentTeachers.filter(t =>
                t.id.toString().includes(query) ||
                t.fullName.toLowerCase().includes(query)
            );
            currentPage = 1;
            renderTeachers();
        }

        // Đảm bảo escape chuỗi đặc biệt trong JS
        function escapeJs(str) {
            if (!str) return '';
            return str.replace(/\\/g, '\\\\').replace(/'/g, "\\'");
        }

        function resetFilter() {
            document.getElementById('searchInput').value = '';
            currentPage = 1;
            loadTeachers();
        }

        function loadTeachers() {
            $('#teachersTableBody').html('<tr><td colspan="8" class="text-center text-muted py-4"><span class="spinner-border spinner-border-sm text-primary me-2"></span> Đang tải...</td></tr>');

            fetch('/api/center/teachers')
                .then(res => res.json())
                .then(data => {
                    currentTeachers = data;
                    filteredTeachers = data;
                    currentPage = 1;
                    renderTeachers();
                })
                .catch(err => {
                    console.error("Lỗi tải giáo viên:", err);
                    $('#teachersTableBody').html('<tr><td colspan="8" class="text-center text-danger py-4">Không thể kết nối đến máy chủ.</td></tr>');
                });
        }

        function renderTeachers() {
            const tbody = document.getElementById('teachersTableBody');
            if (filteredTeachers.length === 0) {
                tbody.innerHTML = '<tr><td colspan="8" class="text-center text-muted py-4">Chưa có giáo viên nào.</td></tr>';
                document.getElementById('teachersPagination').innerHTML = '';
                return;
            }

            const totalPages = Math.ceil(filteredTeachers.length / pageSize);
            if (currentPage > totalPages) currentPage = totalPages;
            if (currentPage < 1) currentPage = 1;

            const start = (currentPage - 1) * pageSize;
            const end = start + pageSize;
            const pageItems = filteredTeachers.slice(start, end);

            let html = '';
            pageItems.forEach(t => {
                const statusBadge = t.isActive
                    ? '<span class="badge bg-success-subtle text-success border px-2 py-1 rounded-pill">Hoạt động</span>'
                    : '<span class="badge bg-danger-subtle text-danger border px-2 py-1 rounded-pill">Khóa</span>';

                const toggleBtn = t.isActive
                    ? `<button class="btn btn-sm btn-danger px-2" onclick="toggleStatus(${t.id})">Khóa</button>`
                    : `<button class="btn btn-sm btn-success px-2" onclick="toggleStatus(${t.id})">Mở khóa</button>`;

                html += `
                    <tr>
                        <td class="ps-3 fw-bold">${t.id}</td>
                        <td class="fw-bold text-dark">${t.fullName}</td>
                        <td>${t.username}</td>
                        <td>${t.email || '—'}</td>
                        <td>${t.phone || '—'}</td>
                        <td>${statusBadge}</td>
                        <td class="small text-muted">${new Date(t.createdAt).toLocaleDateString('vi-VN')}</td>
                        <td class="text-center">
                            <div class="d-inline-flex gap-1">
                                <button class="btn btn-sm btn-warning text-white px-2" onclick="openEditModal(${t.id}, '${escapeJs(t.fullName)}', '${escapeJs(t.email || '')}', '${escapeJs(t.phone || '')}')" data-bs-toggle="modal" data-bs-target="#editTeacherModal">Sửa</button>
                                ${toggleBtn}
                            </div>
                        </td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;

            renderPaginationControls(totalPages);
        }

        function renderPaginationControls(totalPages) {
            const container = document.getElementById('teachersPagination');
            if (!container) return;
            if (totalPages < 1) {
                container.innerHTML = '';
                return;
            }

            let html = `<nav aria-label="Page navigation"><ul class="pagination pagination-sm mb-0 gap-1">`;

            // Trang đầu
            html += `<li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                <a class="page-link rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;" href="#" onclick="goToPage(1); return false;" title="Trang đầu">
                    <i class="bi bi-chevron-double-left"></i>
                </a>
            </li>`;

            // Trang trước
            html += `<li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                <a class="page-link rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;" href="#" onclick="goToPage(${currentPage - 1}); return false;" title="Trang trước">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>`;

            // Các trang số
            const maxVisiblePages = 5;
            let startPage = Math.max(1, currentPage - Math.floor(maxVisiblePages / 2));
            let endPage = startPage + maxVisiblePages - 1;
            if (endPage > totalPages) {
                endPage = totalPages;
                startPage = Math.max(1, endPage - maxVisiblePages + 1);
            }

            for (let p = startPage; p <= endPage; p++) {
                html += `<li class="page-item ${p === currentPage ? 'active' : ''}">
                    <a class="page-link rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;" href="#" onclick="goToPage(${p}); return false;">${p}</a>
                </li>`;
            }

            // Trang sau
            html += `<li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                <a class="page-link rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;" href="#" onclick="goToPage(${currentPage + 1}); return false;" title="Trang sau">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>`;

            // Trang cuối
            html += `<li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                <a class="page-link rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;" href="#" onclick="goToPage(${totalPages}); return false;" title="Trang cuối">
                    <i class="bi bi-chevron-double-right"></i>
                </a>
            </li>`;

            html += `</ul></nav>`;
            container.innerHTML = html;
        }

        function goToPage(page) {
            const totalPages = Math.ceil(filteredTeachers.length / pageSize);
            if (page < 1 || page > totalPages) return;
            currentPage = page;
            renderTeachers();
        }

        // Tạo tài khoản
        document.getElementById('createTeacherForm').addEventListener('submit', function(e) {
            e.preventDefault();
            $('.create-error-container').html('');

            // Client-side validations
            const fullName = document.getElementById('createFullName').value.trim();
            const username = document.getElementById('createUsername').value.trim();
            const password = document.getElementById('createPassword').value.trim();
            const email = document.getElementById('createEmail').value.trim();
            let phone = document.getElementById('createPhone').value.trim();

            if (phone) {
                phone = phone.replace(/[\s\-\(\)]/g, "");
                if (phone.startsWith("+84")) {
                    phone = "0" + phone.substring(3);
                } else if (phone.startsWith("84") && phone.length > 9) {
                    phone = "0" + phone.substring(2);
                }
            }

            const clientErrors = [];

            if (!fullName && !username && !password && !email && !phone) {
                $('.create-error-container').html(`
                    <div class="alert alert-danger border-0 py-2 rounded-3" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>Vui lòng điền thông tin giáo viên trước khi lưu.
                    </div>
                `);
                return;
            }

            if (!fullName) {
                clientErrors.push("Họ và tên không được để trống.");
            } else if (fullName.length < 2 || fullName.length > 100) {
                clientErrors.push("Họ và tên phải từ 2 đến 100 ký tự.");
            } else if (!/^[a-zA-ZÀÁÂÃÈÉÊÌÍÒÓÔÕÙÚĂĐĨŨƠàáâãèéêìíòóôõùúăđĩũơƯĂÂÊÔƠƯưăâêôơưẠẢẤẦẨẪẬẮẰẲẴẶẸẺẼẾỀỂỄỆỈỊỌỎỐỒỔỖỘỚỜỞỠỢỤỦỨỪỬỮỰỲÝỶỸỴạảấầẩẫậắằẳẵặẹẻẽếềểễệỉịọỏốồổỗộớờởỡợụủứừửữựỳýỷỹỵ\s]+$/.test(fullName)) {
                clientErrors.push("Họ và tên chỉ được chứa chữ cái và khoảng trắng.");
            }

            if (!username) {
                clientErrors.push("Tên đăng nhập không được để trống.");
            } else if (username.length < 3 || username.length > 50) {
                clientErrors.push("Tên đăng nhập phải từ 3 đến 50 ký tự.");
            } else if (!/^[a-zA-Z0-9]+$/.test(username)) {
                clientErrors.push("Tên đăng nhập chỉ được gồm chữ cái và chữ số, không chứa dấu cách.");
            }

            if (!password) {
                clientErrors.push("Mật khẩu không được để trống.");
            } else if (password.length < 6) {
                clientErrors.push("Mật khẩu phải có ít nhất 6 ký tự.");
            }

            if (email && !/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)) {
                clientErrors.push("Địa chỉ email không đúng định dạng.");
            }

            if (phone && !/^(0[3|5|7|8|9])[0-9]{8}$/.test(phone)) {
                clientErrors.push("Số điện thoại không hợp lệ (phải gồm 10 chữ số và bắt đầu bằng đầu số di động VN như 03, 05, 07, 08, 09).");
            }

            if (clientErrors.length > 0) {
                $('.create-error-container').html(`
                    <div class="alert alert-danger border-0 py-2 rounded-3" role="alert">
                        <ul class="mb-0 ps-3">
                            ${clientErrors.map(err => `<li>${err}</li>`).join('')}
                        </ul>
                    </div>
                `);
                return;
            }

            const bodyData = {
                fullName: fullName,
                username: username,
                password: password,
                email: email || null,
                phone: phone || null
            };

            fetch('/api/center/teachers', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(bodyData)
            })
            .then(async res => {
                if (!res.ok) {
                    const errData = await res.json();
                    let errMsg = "";
                    if (errData.message) {
                        errMsg = `<li>${errData.message}</li>`;
                    } else if (errData.errors) {
                        const errorList = [];
                        for (const key in errData.errors) {
                            if (errData.errors.hasOwnProperty(key)) {
                                errorList.push(...errData.errors[key]);
                            }
                        }
                        errMsg = errorList.map(err => `<li>${err}</li>`).join('');
                    } else {
                        errMsg = "<li>Tạo giáo viên thất bại.</li>";
                    }
                    throw new Error(errMsg);
                }
                return res.json();
            })
            .then(() => {
                bootstrap.Modal.getInstance(document.getElementById('createTeacherModal')).hide();
                showAlert("Tạo giáo viên thành công!", "success");
                loadTeachers();
                document.getElementById('createTeacherForm').reset();
            })
            .catch(err => {
                $('.create-error-container').html(`
                    <div class="alert alert-danger border-0 py-2 rounded-3" role="alert">
                        <ul class="mb-0 ps-3">
                            ${err.message.startsWith('<li>') ? err.message : `<li>${err.message}</li>`}
                        </ul>
                    </div>
                `);
            });
        });

        // Toggle Status
        function toggleStatus(id) {
            if (!confirm("Bạn có chắc muốn thực hiện thay đổi trạng thái tài khoản này?")) return;

            fetch(`/api/center/teachers/${id}/toggle-status`, { method: 'POST' })
                .then(res => res.json())
                .then(data => {
                    showAlert(data.message, "success");
                    loadTeachers();
                })
                .catch(err => {
                    showAlert("Thay đổi trạng thái thất bại.", "danger");
                });
        }

        // Mở popup Edit
        function openEditModal(id, fullName, email, phone) {
            $('.edit-error-container').html('');
            document.getElementById('editTeacherId').value = id;
            document.getElementById('editFullName').value = fullName;
            document.getElementById('editEmail').value = email;
            document.getElementById('editPhone').value = phone;
        }

        // Cập nhật tài khoản
        document.getElementById('editTeacherForm').addEventListener('submit', function(e) {
            e.preventDefault();
            $('.edit-error-container').html('');

            const id = document.getElementById('editTeacherId').value;
            const fullName = document.getElementById('editFullName').value.trim();
            const email = document.getElementById('editEmail').value.trim();
            let phone = document.getElementById('editPhone').value.trim();

            if (phone) {
                phone = phone.replace(/[\s\-\(\)]/g, "");
                if (phone.startsWith("+84")) {
                    phone = "0" + phone.substring(3);
                } else if (phone.startsWith("84") && phone.length > 9) {
                    phone = "0" + phone.substring(2);
                }
            }

            const clientErrors = [];

            if (!fullName && !email && !phone) {
                $('.edit-error-container').html(`
                    <div class="alert alert-danger border-0 py-2 rounded-3" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>Vui lòng điền đầy đủ thông tin trước khi lưu.
                    </div>
                `);
                return;
            }

            if (!fullName) {
                clientErrors.push("Họ và tên không được để trống.");
            } else if (fullName.length < 2 || fullName.length > 100) {
                clientErrors.push("Họ và tên phải từ 2 đến 100 ký tự.");
            } else if (!/^[a-zA-ZÀÁÂÃÈÉÊÌÍÒÓÔÕÙÚĂĐĨŨƠàáâãèéêìíòóôõùúăđĩũơƯĂÂÊÔƠƯưăâêôơưẠẢẤẦẨẪẬẮẰẲẴẶẸẺẼẾỀỂỄỆỈỊỌỎỐỒỔỖỘỚỜỞỠỢỤỦỨỪỬỮỰỲÝỶỸỴạảấầẩẫậắằẳẵặẹẻẽếềểễệỉịọỏốồổỗộớờởỡợụủứừửữựỳýỷỹỵ\s]+$/.test(fullName)) {
                clientErrors.push("Họ và tên chỉ được chứa chữ cái và khoảng trắng.");
            }

            if (email && !/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)) {
                clientErrors.push("Địa chỉ email không đúng định dạng.");
            }

            if (phone && !/^(0[3|5|7|8|9])[0-9]{8}$/.test(phone)) {
                clientErrors.push("Số điện thoại không hợp lệ (phải gồm 10 chữ số và bắt đầu bằng đầu số di động VN như 03, 05, 07, 08, 09).");
            }

            if (clientErrors.length > 0) {
                $('.edit-error-container').html(`
                    <div class="alert alert-danger border-0 py-2 rounded-3" role="alert">
                        <ul class="mb-0 ps-3">
                            ${clientErrors.map(err => `<li>${err}</li>`).join('')}
                        </ul>
                    </div>
                `);
                return;
            }

            const bodyData = {
                fullName: fullName,
                email: email || null,
                phone: phone || null
            };

            fetch(`/api/center/teachers/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(bodyData)
            })
            .then(async res => {
                if (!res.ok) {
                    const errData = await res.json();
                    let errMsg = "";
                    if (errData.message) {
                        errMsg = `<li>${errData.message}</li>`;
                    } else if (errData.errors) {
                        const errorList = [];
                        for (const key in errData.errors) {
                            if (errData.errors.hasOwnProperty(key)) {
                                errorList.push(...errData.errors[key]);
                            }
                        }
                        errMsg = errorList.map(err => `<li>${err}</li>`).join('');
                    } else {
                        errMsg = "<li>Cập nhật giáo viên thất bại.</li>";
                    }
                    throw new Error(errMsg);
                }
            })
            .then(() => {
                bootstrap.Modal.getInstance(document.getElementById('editTeacherModal')).hide();
                showAlert("Cập nhật giáo viên thành công!", "success");
                loadTeachers();
            })
            .catch(err => {
                $('.edit-error-container').html(`
                    <div class="alert alert-danger border-0 py-2 rounded-3" role="alert">
                        <ul class="mb-0 ps-3">
                            ${err.message.startsWith('<li>') ? err.message : `<li>${err.message}</li>`}
                        </ul>
                    </div>
                `);
            });
        });

        function showAlert(message, type) {
            const container = document.getElementById('alertContainer');
            container.innerHTML = `
                <div class="alert alert-${type} alert-dismissible fade show border-0 rounded-3 shadow-sm" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;
        }

        $(document).ready(function () {
            loadTeachers();

            document.getElementById('searchInput').addEventListener('keypress', function (e) {
                if (e.key === 'Enter') {
                    filterTeachers();
                }
            });
        });
    </script>
}
