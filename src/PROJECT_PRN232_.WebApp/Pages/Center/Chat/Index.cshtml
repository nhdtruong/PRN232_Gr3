@page
@model PROJECT_PRN232_.WebApp.Pages.Center.Chat.IndexModel
@{
    ViewData["Title"] = "Trung tâm - Trò chuyện với Phụ huynh";
}

<!-- Truyền UserId và Role hiện tại sang cho JS -->
<div id="chat-page-metadata" 
     data-current-user-id="@Model.CurrentUserId" 
     data-current-role="Center"
     data-target-parent-id="@Model.TargetParentId"
     style="display: none;">
</div>

<div class="container py-2">
    <div class="row">
        <!-- Cột trái: Danh sách phụ huynh -->
        <div class="col-md-4 mb-4 animate-message">
            <div class="card chat-card shadow-sm border-0 animate-card" style="height: 600px; display: flex; flex-direction: column;">
                <div class="card-header chat-header-gradient text-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-people-fill me-2"></i> Danh sách Phụ huynh</h5>
                </div>
                <div class="p-3 border-bottom bg-light" style="display: flex; flex-direction: column; gap: 8px;">
                    <input type="text" id="search-contacts" class="form-control form-control-sm" placeholder="Tìm kiếm phụ huynh..." style="border-radius: 20px; padding: 6px 15px;">
                    <select id="filter-class" class="form-select form-select-sm" style="border-radius: 20px; padding: 5px 15px; border: 1px solid rgba(79,70,229,0.2); font-size: 0.82rem; color: #374151;">
                        <option value="">📚 Tất cả lớp học</option>
                        @foreach (var cls in Model.AvailableClasses)
                        {
                            <option value="@cls">@cls</option>
                        }
                    </select>
                </div>
                <div class="list-group list-group-flush overflow-auto flex-grow-1" id="contacts-list" style="height: 480px;">
                    @if (Model.Parents.Count == 0)
                    {
                        <div class="p-4 text-center text-muted small">Không tìm thấy tài khoản Phụ huynh nào.</div>
                    }
                    else
                    {
                        @foreach (var parent in Model.Parents)
                        {
                            var hasUnread = parent.UnreadCount > 0;
                            <a href="#" class="list-group-item list-group-item-action contact-item @(hasUnread ? "has-unread" : "")" 
                               data-parent-id="@parent.Id" 
                               data-parent-name="@parent.FullName"
                               data-class-names="@parent.ClassNames">
                                <div class="d-flex align-items-center">
                                    <div class="contact-avatar me-3">
                                        @parent.FullName.Substring(0, 1).ToUpper()
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex align-items-center justify-content-between">
                                            <h6 class="mb-0 text-dark fw-bold small contact-name">@parent.FullName</h6>
                                            <span class="badge bg-danger rounded-pill unread-chat-badge @(hasUnread ? "" : "d-none")" style="font-size: 0.7rem; padding: 4px 8px;">@parent.UnreadCount</span>
                                        </div>
                                        @if (!string.IsNullOrEmpty(parent.StudentNames))
                                        {
                                            <span class="text-muted small d-block" style="font-size: 0.72rem;">
                                                <i class="bi bi-person-fill me-1" style="color: #818cf8; font-size: 0.65rem;"></i>Con: @parent.StudentNames
                                            </span>
                                        }
                                        @if (!string.IsNullOrEmpty(parent.ClassNames))
                                        {
                                            <span class="text-muted small d-block" style="font-size: 0.72rem;">
                                                <i class="bi bi-mortarboard-fill me-1" style="color: #a78bfa; font-size: 0.65rem;"></i>Lớp: @parent.ClassNames
                                            </span>
                                        }
                                        @if (string.IsNullOrEmpty(parent.StudentNames))
                                        {
                                            <span class="text-muted small" style="font-size: 0.72rem; font-style: italic;">Chưa có học sinh</span>
                                        }
                                    </div>
                                </div>
                            </a>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Cột phải: Khung chát -->
        <div class="col-md-8 mb-4">
            <div class="card chat-card shadow-sm border-0" id="chat-window-card" style="height: 600px; display: flex; flex-direction: column;">
                <!-- Trạng thái chưa chọn cuộc trò chuyện -->
                <div class="card-body d-flex flex-column align-items-center justify-content-center text-muted" id="chat-placeholder">
                    <i class="bi bi-chat-left-dots-fill text-primary opacity-25 mb-3" style="font-size: 4.5rem;"></i>
                    <h5 class="fw-bold text-dark">Chọn một cuộc trò chuyện để bắt đầu</h5>
                    <p class="small text-muted">Hệ thống nhắn tin thời gian thực EduBridge</p>
                </div>

                <!-- Khung chát đang hoạt động -->
                <div class="d-flex flex-column h-100" id="chat-active-window" style="display: none !important;">
                    <div class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center">
                            <div class="active-avatar me-3" id="active-chat-avatar">
                                U
                            </div>
                            <div>
                                <h6 class="mb-0 text-dark fw-bold" id="active-chat-name">Tên phụ huynh</h6>
                                <span class="badge bg-success rounded-pill" style="font-size: 0.65rem; background-color: rgba(16, 185, 129, 0.15) !important; color: #047857 !important;">Đang kết nối</span>
                            </div>
                        </div>
                        <span class="text-muted small" id="active-channel-info" style="font-size: 0.75rem;">Channel #0</span>
                    </div>

                    <!-- Vùng tin nhắn -->
                    <div class="card-body p-4 overflow-auto flex-grow-1" id="chat-messages-container" style="height: 420px;">
                        <!-- Các tin nhắn được nạp động -->
                    </div>

                    <!-- Ô nhập liệu -->
                    <div class="card-footer bg-white border-top p-3">
                        <!-- Hidden file input nhận tất cả loại file được phép -->
                        <input type="file" id="chat-file-input" style="display: none;"
                               accept="image/*,video/*,.pdf,.doc,.docx,.xls,.xlsx" />

                        <!-- Khu vực preview file đã chọn (ẩn ban đầu) -->
                        <div id="file-preview-bar" class="d-flex align-items-center gap-2 mb-2 p-2 bg-light rounded border d-none">
                            <i class="bi bi-paperclip text-primary"></i>
                            <span id="file-preview-name" class="small text-truncate flex-grow-1 text-dark"></span>
                            <span id="file-preview-size" class="small text-muted"></span>
                            <button type="button" id="file-preview-cancel" class="btn-close btn-close-sm" style="font-size: 0.6rem;"></button>
                        </div>

                        <form id="chat-form" class="d-flex align-items-center gap-2 w-100">
                            <!-- Nút đính kèm file -->
                            <button type="button" id="attach-file-btn" class="btn btn-outline-secondary chat-round-btn flex-shrink-0"
                                    title="Đính kèm ảnh, video hoặc tài liệu" style="border: 1px solid rgba(79, 70, 229, 0.15);">
                                <i class="bi bi-paperclip fs-5"></i>
                            </button>
                            <input type="text" id="chat-input" class="form-control chat-input-bar" placeholder="Nhập tin nhắn..." autocomplete="off">
                            <button class="btn btn-primary chat-round-btn flex-shrink-0" type="submit" id="chat-send-btn" style="background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%); border: none;">
                                <i class="bi bi-send-fill text-white"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Custom layout styling */
    .chat-card {
        border-radius: 20px !important;
        overflow: hidden;
        border: 1px solid rgba(79, 70, 229, 0.08) !important;
        box-shadow: 0 10px 30px rgba(30, 27, 75, 0.08) !important;
        background: #fff;
    }

    .chat-header-gradient {
        background: linear-gradient(135deg, var(--eb-primary-dark) 0%, var(--eb-primary) 100%) !important;
        border: none !important;
    }

    .contact-item {
        border-radius: 12px !important;
        margin: 0.35rem 0.75rem !important;
        border: none !important;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        padding: 0.75rem 1rem !important;
    }
    .contact-item:hover {
        background-color: rgba(79, 70, 229, 0.05) !important;
        transform: translateX(4px);
    }
    .contact-item.has-unread {
        background-color: rgba(239, 68, 68, 0.05) !important;
        border-left: 4px solid var(--eb-danger) !important;
    }
    .contact-item.has-unread:hover {
        background-color: rgba(239, 68, 68, 0.08) !important;
    }
    .contact-item.active {
        background: linear-gradient(135deg, rgba(79, 70, 229, 0.08) 0%, rgba(124, 58, 237, 0.08) 100%) !important;
        border-left: 4px solid var(--eb-primary) !important;
        box-shadow: 0 4px 15px rgba(79, 70, 229, 0.06);
    }

    .contact-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, #a5b4fc 0%, #818cf8 100%) !important;
        color: #fff !important;
        font-weight: 700;
        font-size: 0.95rem;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 2px 6px rgba(129, 140, 248, 0.2);
    }

    .active-avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: linear-gradient(135deg, #818cf8 0%, #4f46e5 100%) !important;
        color: #fff !important;
        font-weight: 700;
        font-size: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 3px 8px rgba(79, 70, 229, 0.3);
    }

    #chat-messages-container {
        background-color: #f8fafc;
        background-image: radial-gradient(rgba(79, 70, 229, 0.06) 1.2px, transparent 1.2px);
        background-size: 24px 24px;
        padding: 1.5rem !important;
        border-bottom: 1px solid rgba(0,0,0,0.03);
    }

    /* Spring animation for messages */
    @@keyframes slideInUp {
        from {
            opacity: 0;
            transform: translateY(16px) scale(0.96);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }
    .message-bubble-wrapper {
        display: flex;
        margin-bottom: 1rem;
        width: 100%;
        animation: slideInUp 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }
    
    .message-bubble-wrapper.sent {
        justify-content: flex-end;
    }
    .message-bubble-wrapper.received {
        justify-content: flex-start;
    }

    .message-bubble {
        max-width: 68%;
        padding: 0.75rem 1rem;
        border-radius: 16px;
        font-size: 0.9rem;
        word-break: break-word;
        box-shadow: 0 3px 10px rgba(0,0,0,0.03);
        position: relative;
    }

    .message-bubble-wrapper.sent .message-bubble {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        color: white;
        border-bottom-right-radius: 4px;
        box-shadow: 0 4px 12px rgba(79, 70, 229, 0.18);
    }

    .message-bubble-wrapper.received .message-bubble {
        background-color: #ffffff;
        color: #1f2937;
        border-bottom-left-radius: 4px;
        border: 1px solid rgba(0, 0, 0, 0.04);
        box-shadow: 0 3px 8px rgba(0, 0, 0, 0.02);
    }

    .message-meta {
        font-size: 0.68rem;
        margin-top: 5px;
        display: block;
        opacity: 0.7;
    }
    .message-bubble-wrapper.sent .message-meta {
        text-align: right;
        color: rgba(255, 255, 255, 0.85);
    }
    .message-bubble-wrapper.received .message-meta {
        text-align: left;
        color: #6b7280;
    }

    /* Custom chat doc card inside message bubble */
    .chat-doc-card {
        background: rgba(255, 255, 255, 0.95);
        border-radius: 12px;
        border: 1px solid rgba(0,0,0,0.06);
        padding: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        min-width: 220px;
        box-shadow: 0 3px 10px rgba(0,0,0,0.03);
        transition: all 0.2s ease;
    }
    .chat-doc-card:hover {
        box-shadow: 0 5px 15px rgba(0,0,0,0.06);
        transform: translateY(-1px);
    }

    .chat-media {
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        transition: all 0.25s ease;
    }
    .chat-media:hover {
        transform: scale(1.02);
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
    }

    /* Custom form elements input styling */
    .chat-input-bar {
        border-radius: 24px !important;
        padding-left: 1.25rem;
        padding-right: 1.25rem;
        border: 1px solid rgba(79, 70, 229, 0.15) !important;
        transition: all 0.2s ease;
    }
    .chat-input-bar:focus {
        border-color: var(--eb-primary) !important;
        box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.12) !important;
    }

    .chat-round-btn {
        width: 42px;
        height: 42px;
        border-radius: 50% !important;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 !important;
        transition: all 0.2s ease;
    }
</style>

<script>
    // ── Combined filter: text search + class combobox ─────────────────────────
    (function () {
        const searchInput  = document.getElementById('search-contacts');
        const classFilter  = document.getElementById('filter-class');
        const contactsList = document.getElementById('contacts-list');

        function applyFilter() {
            const keyword   = (searchInput?.value ?? '').trim().toLowerCase();
            const className = (classFilter?.value ?? '').trim().toLowerCase();

            let visibleCount = 0;
            document.querySelectorAll('#contacts-list .contact-item').forEach(item => {
                const name       = (item.getAttribute('data-parent-name') ?? '').toLowerCase();
                const classNames = (item.getAttribute('data-class-names') ?? '').toLowerCase();

                const matchName  = keyword === '' || name.includes(keyword);
                const matchClass = className === '' || classNames.includes(className);

                if (matchName && matchClass) {
                    item.style.display = '';
                    visibleCount++;
                } else {
                    item.style.display = 'none';
                }
            });

            // Hiển thị thông báo nếu không có kết quả
            let emptyMsg = document.getElementById('filter-empty-msg');
            if (visibleCount === 0) {
                if (!emptyMsg) {
                    emptyMsg = document.createElement('div');
                    emptyMsg.id = 'filter-empty-msg';
                    emptyMsg.className = 'p-4 text-center text-muted small';
                    emptyMsg.innerHTML = '<i class="bi bi-search fs-4 d-block mb-2 opacity-50"></i>Không tìm thấy phụ huynh phù hợp.';
                    contactsList?.appendChild(emptyMsg);
                }
                emptyMsg.style.display = '';
            } else if (emptyMsg) {
                emptyMsg.style.display = 'none';
            }
        }

        searchInput?.addEventListener('input', applyFilter);
        classFilter?.addEventListener('change', applyFilter);
    })();
</script>


