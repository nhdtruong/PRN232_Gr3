@page
@model PROJECT_PRN232_.WebApp.Pages.Center.Students.IndexModel
@{
    ViewData["Title"] = "Quản lý Học sinh - REST API";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">🎓 Quản lý Học sinh</h2>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createStudentModal">
            <i class="bi bi-plus-lg me-1"></i> Thêm học sinh mới
        </button>
    </div>

    <div id="alertContainer"></div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light text-uppercase font-semibold" style="font-size: 0.85rem;">
                        <tr>
                            <th class="ps-3">ID</th>
                            <th>Họ và Tên</th>
                            <th>Ngày sinh</th>
                            <th>Giới tính</th>
                            <th>Phụ huynh</th>
                            <th>Ngày tạo</th>
                            <th class="text-center" style="width: 200px;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody id="studentsTableBody">
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <span class="spinner-border spinner-border-sm text-primary me-2" role="status"></span> Đang tải dữ liệu học sinh...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- CREATE STUDENT MODAL -->
<div class="modal fade" id="createStudentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-3 border-0 shadow-lg">
            <div class="modal-header px-4 py-3">
                <h5 class="modal-title fw-bold text-dark">📝 Thêm học sinh mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="createStudentForm">
                <div class="modal-body px-4 py-3" style="background-color: #F8FAFC;">
                    <div class="create-error-container"></div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Họ và Tên (*)</label>
                        <input id="createFullName" class="form-control" placeholder="Họ và tên..." required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Ngày sinh</label>
                        <input id="createDateOfBirth" type="date" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Giới tính</label>
                        <select id="createGender" class="form-select">
                            <option value="">Chọn giới tính</option>
                            <option value="Male">Nam</option>
                            <option value="Female">Nữ</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Phụ huynh liên kết (*)</label>
                        <select id="createParentId" class="form-select" required>
                            <option value="" selected disabled>Chọn phụ huynh...</option>
                            @foreach (var p in Model.ParentUsers)
                            {
                                <option value="@p.Id">@p.FullName (@p.Username)</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-top px-4 py-3" style="background-color: #F8FAFC;">
                    <button type="button" class="btn btn-light border px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary px-4">Lưu học sinh</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- EDIT STUDENT MODAL -->
<div class="modal fade" id="editStudentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-3 border-0 shadow-lg">
            <div class="modal-header px-4 py-3">
                <h5 class="modal-title fw-bold text-dark">✏️ Cập nhật thông tin học sinh</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="editStudentForm">
                <input type="hidden" id="editStudentId" />
                <div class="modal-body px-4 py-3" style="background-color: #F8FAFC;">
                    <div class="edit-error-container"></div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Họ và Tên (*)</label>
                        <input id="editFullName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Ngày sinh</label>
                        <input id="editDateOfBirth" type="date" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Giới tính</label>
                        <select id="editGender" class="form-select">
                            <option value="">Chọn giới tính</option>
                            <option value="Male">Nam</option>
                            <option value="Female">Nữ</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Phụ huynh liên kết (*)</label>
                        <select id="editParentId" class="form-select" required>
                            @foreach (var p in Model.ParentUsers)
                            {
                                <option value="@p.Id">@p.FullName (@p.Username)</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-top px-4 py-3" style="background-color: #F8FAFC;">
                    <button type="button" class="btn btn-light border px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary px-4">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        function loadStudents() {
            fetch('/api/center/students')
                .then(res => res.json())
                .then(data => {
                    renderStudents(data);
                })
                .catch(err => {
                    console.error("Lỗi tải học sinh:", err);
                    $('#studentsTableBody').html('<tr><td colspan="7" class="text-center text-danger py-4">Không thể kết nối đến máy chủ.</td></tr>');
                });
        }

        function renderStudents(students) {
            const tbody = document.getElementById('studentsTableBody');
            if (students.length === 0) {
                tbody.innerHTML = '<tr><td colspan="7" class="text-center text-muted py-4">Chưa có học sinh nào.</td></tr>';
                return;
            }

            let html = '';
            students.forEach(s => {
                const birthDisplay = s.dateOfBirth ? new Date(s.dateOfBirth).toLocaleDateString('vi-VN') : '—';
                const genderDisplay = s.gender === 'Male' ? 'Nam' : (s.gender === 'Female' ? 'Nữ' : (s.gender || '—'));
                
                html += `
                    <tr>
                        <td class="ps-3 fw-bold">${s.id}</td>
                        <td class="fw-bold text-dark">${s.fullName}</td>
                        <td>${birthDisplay}</td>
                        <td>${genderDisplay}</td>
                        <td>${s.parentName}</td>
                        <td class="small text-muted">${new Date(s.createdAt).toLocaleDateString('vi-VN')}</td>
                        <td class="text-center">
                            <div class="d-inline-flex gap-1">
                                <button class="btn btn-sm btn-warning text-white px-2" onclick="openEditModal(${s.id}, '${s.fullName}', '${s.dateOfBirth ? s.dateOfBirth.split('T')[0] : ''}', '${s.gender || ''}', ${s.parentId})" data-bs-toggle="modal" data-bs-target="#editStudentModal">Sửa</button>
                                <button class="btn btn-sm btn-danger px-2" onclick="deleteStudent(${s.id})">Xóa</button>
                            </div>
                        </td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
        }

        // Tạo học sinh
        document.getElementById('createStudentForm').addEventListener('submit', function(e) {
            e.preventDefault();
            $('.create-error-container').html('');

            const bodyData = {
                parentId: parseInt(document.getElementById('createParentId').value),
                fullName: document.getElementById('createFullName').value,
                dateOfBirth: document.getElementById('createDateOfBirth').value || null,
                gender: document.getElementById('createGender').value || null
            };

            fetch('/api/center/students', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(bodyData)
            })
            .then(async res => {
                if (!res.ok) {
                    const errData = await res.json();
                    throw new Error(errData.message || "Tạo học sinh thất bại.");
                }
                return res.json();
            })
            .then(() => {
                bootstrap.Modal.getInstance(document.getElementById('createStudentModal')).hide();
                showAlert("Thêm học sinh thành công!", "success");
                loadStudents();
                document.getElementById('createStudentForm').reset();
            })
            .catch(err => {
                $('.create-error-container').html(`
                    <div class="alert alert-danger border-0 py-2 rounded-3" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>${err.message}
                    </div>
                `);
            });
        });

        // Xóa học sinh
        function deleteStudent(id) {
            if (!confirm("Bạn có chắc chắn muốn xóa học sinh này không?")) return;

            fetch(`/api/center/students/${id}`, { method: 'DELETE' })
                .then(res => {
                    if (!res.ok) throw new Error("Xóa học sinh thất bại.");
                    showAlert("Xóa học sinh thành công!", "success");
                    loadStudents();
                })
                .catch(err => {
                    showAlert(err.message, "danger");
                });
        }

        // Mở popup Edit
        function openEditModal(id, fullName, dob, gender, parentId) {
            $('.edit-error-container').html('');
            document.getElementById('editStudentId').value = id;
            document.getElementById('editFullName').value = fullName;
            document.getElementById('editDateOfBirth').value = dob;
            document.getElementById('editGender').value = gender;
            document.getElementById('editParentId').value = parentId;
        }

        // Cập nhật thông tin học sinh
        document.getElementById('editStudentForm').addEventListener('submit', function(e) {
            e.preventDefault();
            $('.edit-error-container').html('');

            const id = document.getElementById('editStudentId').value;
            const bodyData = {
                parentId: parseInt(document.getElementById('editParentId').value),
                fullName: document.getElementById('editFullName').value,
                dateOfBirth: document.getElementById('editDateOfBirth').value || null,
                gender: document.getElementById('editGender').value || null
            };

            fetch(`/api/center/students/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(bodyData)
            })
            .then(async res => {
                if (!res.ok) {
                    const errData = await res.json();
                    throw new Error(errData.message || "Cập nhật học sinh thất bại.");
                }
            })
            .then(() => {
                bootstrap.Modal.getInstance(document.getElementById('editStudentModal')).hide();
                showAlert("Cập nhật học sinh thành công!", "success");
                loadStudents();
            })
            .catch(err => {
                $('.edit-error-container').html(`
                    <div class="alert alert-danger border-0 py-2 rounded-3" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>${err.message}
                    </div>
                `);
            });
        });

        function showAlert(message, type) {
            const container = document.getElementById('alertContainer');
            container.innerHTML = `
                <div class="alert alert-${type} alert-dismissible fade show border-0 rounded-3 shadow-sm" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;
        }

        $(document).ready(function () {
            loadStudents();
        });
    </script>
}
