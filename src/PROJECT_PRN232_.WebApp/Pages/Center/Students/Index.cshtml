@page
@model PROJECT_PRN232_.WebApp.Pages.Center.Students.IndexModel

@{
    ViewData["Title"] = "Danh sách Học sinh";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Danh sách Học sinh</h2>
        <a asp-page="./Create" class="btn btn-primary">Thêm học sinh mới</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover table-bordered mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Họ và Tên</th>
                        <th>Ngày sinh</th>
                        <th>Giới tính</th>
                        <th>Phụ huynh</th>
                        <th>Ngày tạo</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in Model.Students)
                    {
                        <tr>
                            <td>@student.Id</td>
                            <td>@student.FullName</td>
                            <td>@(student.DateOfBirth.HasValue ? student.DateOfBirth.Value.ToString("dd/MM/yyyy") : "")</td>
                            <td>@(student.Gender == "Male" ? "Nam" : (student.Gender == "Female" ? "Nữ" : student.Gender))</td>
                            <td>@student.Parent?.FullName</td>
                            <td>@student.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-page="./Details" asp-route-id="@student.Id" class="btn btn-sm btn-info text-white">Chi tiết</a>
                                    <a asp-page="./Edit" asp-route-id="@student.Id" class="btn btn-sm btn-warning text-white">Sửa</a>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@student.Id" onsubmit="return confirm('Bạn có chắc chắn muốn xóa học sinh này không?');" style="display:inline;">
                                        <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if(!Model.Students.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center">Chưa có dữ liệu học sinh.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
