@page
@model PROJECT_PRN232_.WebApp.Pages.Parent.ChildrenClassesModel
@{
    ViewData["Title"] = "Lớp học của con";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">👨‍👩‍👧 Lớp học của con</h2>
            <p class="text-muted">Theo dõi danh sách các lớp học hiện tại con đang tham gia.</p>
        </div>
        
        @if (Model.Children.Any())
        {
            <form method="get" id="childSelectorForm">
                <div class="d-flex align-items-center gap-2 bg-light border p-2 rounded-3">
                    <label for="studentSelect" class="fw-semibold text-muted mb-0 small text-nowrap">Chọn con:</label>
                    <select name="SelectedStudentId" id="studentSelect" class="form-select form-select-sm border-0 bg-transparent fw-bold" onchange="document.getElementById('childSelectorForm').submit();">
                        @foreach (var child in Model.Children)
                        {
                            <option value="@child.Id" selected="@(Model.SelectedStudentId == child.Id ? "selected" : null)">
                                @child.FullName (ID: @child.Id)
                            </option>
                        }
                    </select>
                </div>
            </form>
        }
    </div>

    @if (!Model.Children.Any())
    {
        <div class="card border-0 shadow-sm rounded-4 text-center py-5">
            <div class="card-body">
                <i class="fa-solid fa-children display-4 text-muted mb-3"></i>
                <h5 class="fw-bold">Không tìm thấy thông tin con học viên</h5>
                <p class="text-muted">Tài khoản phụ huynh của bạn chưa được liên kết với bất kỳ hồ sơ học sinh nào.</p>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @if (!Model.EnrolledClasses.Any())
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-4 text-center py-5">
                        <div class="card-body">
                            <i class="fa-solid fa-calendar-xmark display-4 text-muted mb-3"></i>
                            <h5 class="fw-bold">Con chưa tham gia lớp học nào</h5>
                            <p class="text-muted mb-0">Học viên hiện chưa được xếp lớp trong học kỳ này.</p>
                        </div>
                    </div>
                </div>
            }
            else
            {
                @foreach (var c in Model.EnrolledClasses)
                {
                    <div class="col-md-4">
                        <div class="card h-100 shadow-sm border-0 rounded-4">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h4 class="fw-bold text-dark mb-0">@c.ClassName</h4>
                                    <span class="badge @(c.Status == "Active" ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger") rounded-pill px-3 py-2 border">
                                        @(c.Status == "Active" ? "Đang hoạt động" : "Đã đóng")
                                    </span>
                                </div>
                                <div class="text-muted small pt-3 border-top mt-3">
                                    <div><i class="fa-solid fa-hashtag text-primary me-2"></i>Lớp học ID: <strong>@c.Id</strong></div>
                                    <div><i class="fa-solid fa-building text-info me-2"></i>Mã cơ sở trung tâm: <strong>@c.CenterId</strong></div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    }
</div>
