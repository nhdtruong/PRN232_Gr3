@page
@model PROJECT_PRN232_.WebApp.Pages.Parent.AttendanceModel
@{
    ViewData["Title"] = "Lịch sử chuyên cần & Điểm danh";
}

<div class="container py-4">
    <!-- Header -->
    <div class="row align-items-center mb-4">
        <div class="col">
            <h1 class="h3 fw-bold text-dark mb-1">
                <i class="bi bi-clock-history text-danger me-2"></i>Lịch sử chuyên cần & Điểm danh
            </h1>
            <p class="text-muted mb-0">Theo dõi thông tin điểm danh chi tiết các buổi học của con</p>
        </div>
        <div class="col-md-3 mt-3 mt-md-0">
            <label class="form-label small fw-bold text-muted mb-1">Chọn xem thông tin con:</label>
            <select class="form-select rounded-pill border-0 shadow-sm px-3" id="selectChild">
                <option value="">-- Chọn học sinh --</option>
            </select>
        </div>
    </div>

    <!-- Thống kê tỷ lệ chuyên cần -->
    <div class="row g-3 mb-4" id="statsRow" style="display: none;">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 text-center py-3">
                <div class="text-muted small fw-semibold">TỔNG BUỔI HỌC</div>
                <div class="fs-2 fw-bold text-primary" id="statTotal">0</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 text-center py-3">
                <div class="text-muted small fw-semibold">✅ CÓ MẶT</div>
                <div class="fs-2 fw-bold text-success" id="statPresent">0</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 text-center py-3">
                <div class="text-muted small fw-semibold">❌ VẮNG MẶT</div>
                <div class="fs-2 fw-bold text-danger" id="statAbsent">0</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 text-center py-3">
                <div class="text-muted small fw-semibold">⏰ ĐI TRỄ / PHÉP</div>
                <div class="fs-2 fw-bold text-warning" id="statOther">0</div>
            </div>
        </div>
    </div>

    <!-- Bảng điểm danh -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-bottom py-3 px-4" style="border-top-left-radius: 16px; border-top-right-radius: 16px;">
            <h5 class="mb-0 fw-bold text-dark">
                <i class="bi bi-list-check text-primary me-2"></i>Bảng chi tiết chuyên cần
            </h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="py-3 px-4" style="width: 80px;">STT</th>
                            <th class="py-3">Lớp học</th>
                            <th class="py-3">Buổi học</th>
                            <th class="py-3">Ngày học</th>
                            <th class="py-3 text-center" style="width: 150px;">Trạng thái</th>
                            <th class="py-3">Ghi chú</th>
                        </tr>
                    </thead>
                    <tbody id="attendanceTableBody">
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted" id="noAttendanceMessage">
                                <i class="bi bi-person-exclamation fs-1 d-block mb-2 text-secondary"></i>
                                Vui lòng chọn con ở góc phải để xem lịch sử chuyên cần.
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .status-badge {
        font-size: 0.85rem;
        font-weight: 600;
        padding: 6px 16px;
    }
</style>

@section Scripts {
    <script src="~/js/parent-attendance.js" asp-append-version="true"></script>
}
