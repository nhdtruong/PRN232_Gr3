@page
@model PROJECT_PRN232_.WebApp.Pages.Auth.LoginModel
@{
    Layout = null; // Ẩn layout chung (menu)
    ViewData["Title"] = "Đăng nhập";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduBridge</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        input[type="password"]::-ms-reveal,
        input[type="password"]::-ms-clear {
            display: none;
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center bg-gradient-to-br from-blue-50 via-white to-green-50 p-4 font-sans text-gray-900">
    <div id="login-toast" class="fixed right-6 top-6 z-50 hidden w-[360px] rounded-xl px-5 py-4 text-white shadow-2xl">
        <div id="login-toast-title" class="text-lg font-bold leading-6"></div>
        <div id="login-toast-message" class="mt-1 text-sm font-medium leading-5 text-white/95"></div>
    </div>

    <div class="w-full max-w-md bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden">
        <div class="p-6 text-center">
            <div class="flex justify-center mb-4">
                <div class="size-16 rounded-full bg-gradient-to-br from-blue-600 to-green-600 flex items-center justify-center shadow-md">
                    <svg class="size-8 text-white" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m4 6 8-4 8 4"/><path d="m18 10 4 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-8l4-2"/><path d="M14 22v-4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v4"/><path d="M18 5v17"/><path d="M6 5v17"/><circle cx="12" cy="9" r="2"/></svg>
                </div>
            </div>
            <h2 class="text-2xl font-bold tracking-tight">EduBridge</h2>
            <p class="text-sm text-gray-500 mt-1">Nền tảng quản lý giáo dục toàn diện</p>
        </div>

        <div class="p-6 pt-0">
            <form id="form-login" class="space-y-4">

                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-400">
                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207" />
                        </svg>
                    </div>
                    <input name="Input.Email"
                           type="text"
                           placeholder="Email hoặc số điện thoại"
                           required
                           class="flex h-10 w-full rounded-md border border-gray-300 bg-transparent px-3 py-2 pl-10 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:border-transparent" />
                </div>

                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-400">
                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                        </svg>
                    </div>
                    <input name="Input.Password" id="Input_Password"
                           type="password"
                           placeholder="Nhập mật khẩu"
                           required
                           class="flex h-10 w-full rounded-md border border-gray-300 bg-transparent px-3 py-2 pl-10 pr-10 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:border-transparent" />
                    <div class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 cursor-pointer hover:text-gray-600" onclick="toggleLoginPassword(this)">
                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
                        </svg>
                    </div>
                </div>

                <button type="submit" class="w-full h-10 px-4 py-2 bg-gradient-to-r from-indigo-600 to-violet-600 hover:from-indigo-700 hover:to-violet-700 text-white font-semibold rounded-md shadow hover:shadow-md transition-all duration-200 transform hover:-translate-y-0.5">
                    Đăng nhập
                </button>
            </form>

            <p class="text-xs text-center text-gray-500 mt-6">Sử dụng email hoặc số điện thoại của tài khoản đã được cấp</p>
        </div>
    </div>

    <script>
        function toggleLoginPassword(container) {
            var input = document.getElementById("Input_Password");
            var svgPath = container.querySelector("path");
            if (input.type === "password") {
                input.type = "text";
                svgPath.setAttribute("d", "M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z");
            } else {
                input.type = "password";
                svgPath.setAttribute("d", "M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21");
            }
        }

        const logoutSuccessMessage = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            string.Equals(HttpContext.Request.Query["loggedOut"], "true", StringComparison.OrdinalIgnoreCase)
                ? "Đã đăng xuất."
                : null));

        function showLoginToast(message, isSuccess) {
            if (!message) {
                return;
            }

            const toast = document.getElementById('login-toast');
            document.getElementById('login-toast-title').textContent = isSuccess ? 'Thành công' : 'Thất bại';
            document.getElementById('login-toast-message').textContent = message;
            toast.className = `fixed right-6 top-6 z-50 w-[360px] rounded-xl px-5 py-4 text-white shadow-2xl ${isSuccess ? 'bg-green-600' : 'bg-red-600'}`;

            setTimeout(() => {
                toast.classList.add('hidden');
            }, 3000);
        }

        showLoginToast(logoutSuccessMessage, true);

        document.getElementById('form-login').addEventListener('submit', async function (e) {
            e.preventDefault();
            
            const email = document.querySelector('input[name="Input.Email"]').value;
            const password = document.querySelector('input[name="Input.Password"]').value;
            
            try {
                const response = await fetch('/api/Auth/login', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ username: email, password: password })
                });

                if (response.ok) {
                    const data = await response.json();
                    
                    // Lưu JWT token vào localStorage (tùy chọn cho Mobile/SPA client)
                    if (data.token) {
                        localStorage.setItem('jwtToken', data.token);
                    }
                    
                    showLoginToast('Đăng nhập thành công!', true);
                    
                    setTimeout(() => {
                        if (data.role === 'Parent') {
                            window.location.href = '/Parent/Dashboard';
                        } else if (data.role === 'Center') {
                            window.location.href = '/Center/Dashboard';
                        } else if (data.role === 'Teacher') {
                            window.location.href = '/Teacher/Dashboard';
                        } else {
                            window.location.href = '/Index';
                        }
                    }, 500);
                } else {
                    const errorData = await response.json();
                    showLoginToast(errorData.message || 'Đăng nhập thất bại. Vui lòng kiểm tra lại.', false);
                }
            } catch (error) {
                console.error('Error during login:', error);
                showLoginToast('Lỗi kết nối đến máy chủ.', false);
            }
        });

    </script>
</body>
</html>
