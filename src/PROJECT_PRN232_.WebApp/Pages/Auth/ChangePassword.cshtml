@page
@model PROJECT_PRN232_.WebApp.Pages.Auth.ChangePasswordModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

@section Styles {
<style>
    input[type="password"]::-ms-reveal,
    input[type="password"]::-ms-clear {
        display: none;
    }
    .password-container {
        position: relative;
    }
    .password-container .toggle-password {
        position: absolute;
        top: 50%;
        right: 15px;
        transform: translateY(-50%);
        cursor: pointer;
        color: #6c757d;
    }
</style>
}

<div class="row justify-content-center fade-in">
    <div class="col-md-6">
        <div class="card p-4">
            <h4 class="mb-4" style="color: var(--eb-primary);"><i class="bi bi-shield-lock-fill me-2"></i>Đổi mật khẩu</h4>
            
            <div id="changePasswordMessage" class="alert d-none text-start"></div>

            <form id="formChangePassword">
                <div class="mb-3">
                    <label class="form-label text-muted">Mật khẩu hiện tại</label>
                    <div class="password-container">
                        <input type="password" id="Input_OldPassword" class="form-control" required />
                        <i class="bi bi-eye-slash toggle-password" onclick="togglePassword(this, 'Input_OldPassword')"></i>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted">Mật khẩu mới</label>
                    <div class="password-container">
                        <input type="password" id="Input_NewPassword" class="form-control" required minlength="6" />
                        <i class="bi bi-eye-slash toggle-password" onclick="togglePassword(this, 'Input_NewPassword')"></i>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted">Xác nhận mật khẩu mới</label>
                    <div class="password-container">
                        <input type="password" id="Input_ConfirmPassword" class="form-control" required minlength="6" />
                        <i class="bi bi-eye-slash toggle-password" onclick="togglePassword(this, 'Input_ConfirmPassword')"></i>
                    </div>
                </div>
                <div class="d-grid gap-2 mt-4">
                    <button type="submit" id="btnSubmitChangePassword" class="btn btn-primary"><i class="bi bi-check-circle me-2"></i>Cập Nhật Mật Khẩu</button>
                    <a href="/" class="btn btn-light text-muted">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function togglePassword(icon, inputId) {
        var input = document.getElementById(inputId);
        if (input.type === "password") {
            input.type = "text";
            icon.classList.remove("bi-eye-slash");
            icon.classList.add("bi-eye");
        } else {
            input.type = "password";
            icon.classList.remove("bi-eye");
            icon.classList.add("bi-eye-slash");
        }
    }

    document.addEventListener("DOMContentLoaded", function() {
        const form = document.getElementById('formChangePassword');
        const btnSubmit = document.getElementById('btnSubmitChangePassword');
        const msgBox = document.getElementById('changePasswordMessage');

        form.addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const oldPassword = document.getElementById('Input_OldPassword').value;
            const newPassword = document.getElementById('Input_NewPassword').value;
            const confirmPassword = document.getElementById('Input_ConfirmPassword').value;
            
            if (newPassword !== confirmPassword) {
                msgBox.className = 'alert alert-danger text-start';
                msgBox.innerText = 'Mật khẩu xác nhận không khớp.';
                return;
            }

            msgBox.className = 'alert d-none text-start';
            msgBox.innerText = '';
            
            btnSubmit.disabled = true;
            btnSubmit.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Đang xử lý...';

            try {
                const response = await fetch('/api/auth/change-password', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ oldPassword, newPassword })
                });

                const data = await response.json();

                if (response.ok) {
                    msgBox.className = 'alert alert-success text-start';
                    msgBox.innerText = data.message || 'Đổi mật khẩu thành công! Vui lòng đăng nhập lại.';
                    setTimeout(() => {
                        window.location.href = '/Auth/Login?loggedOut=true';
                    }, 2000);
                } else {
                    msgBox.className = 'alert alert-danger text-start';
                    msgBox.innerText = data.message || 'Đã có lỗi xảy ra.';
                    if (data.errors) {
                        const errs = Object.values(data.errors).flat().join('\n');
                        msgBox.innerText += '\n' + errs;
                    }
                }
            } catch (error) {
                msgBox.className = 'alert alert-danger text-start';
                msgBox.innerText = 'Lỗi kết nối đến máy chủ.';
            } finally {
                btnSubmit.disabled = false;
                btnSubmit.innerHTML = '<i class="bi bi-check-circle me-2"></i>Cập Nhật Mật Khẩu';
            }
        });
    });
</script>
}
