@page
@model PROJECT_PRN232_.Pages.Parent.DashboardModel
@{
    ViewData["Title"] = "Dashboard Phụ Huynh";
}

<div class="row mt-4">
    <div class="col-12">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body text-center p-5">
                <h1 class="display-5 text-primary mb-3 fw-bold">👨‍👩‍👧 Xin chào Phụ huynh!</h1>
                <p class="lead text-muted">Chào mừng bạn đã đăng nhập thành công vào Hệ thống quản lý EduBridge.</p>
                <p class="small text-muted mb-3">Vui lòng sử dụng các thẻ chức năng bên dưới hoặc thanh Menu để bắt đầu theo dõi con em.</p>
                <a asp-page="/Parent/ChildrenClasses" class="btn btn-primary rounded-pill px-4 py-2"><i class="fa-solid fa-graduation-cap me-2"></i>Xem Lớp học của con</a>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-2 mb-5">
    <!-- Xem lịch học -->
    <div class="col-md-6">
        <div class="card h-100 shadow-sm border-0 rounded-4 hover-card">
            <div class="card-body text-center p-4">
                <div class="display-4 text-primary mb-3">
                    📅
                </div>
                <h3 class="card-title fw-bold">Lịch học & Tài liệu</h3>
                <p class="card-text text-muted">Theo dõi lịch học các buổi của con và tải tài liệu slide bài giảng, bài tập về nhà.</p>
                <a href="/Parent/Lessons" class="btn btn-primary rounded-pill px-4 py-2 mt-2">Truy cập lịch học</a>
            </div>
        </div>
    </div>

    <!-- Xem chuyên cần -->
    <div class="col-md-6">
        <div class="card h-100 shadow-sm border-0 rounded-4 hover-card">
            <div class="card-body text-center p-4">
                <div class="display-4 text-danger mb-3">
                    ⏱️
                </div>
                <h3 class="card-title fw-bold">Lịch sử chuyên cần</h3>
                <p class="card-text text-muted">Theo dõi tình hình điểm danh (Có mặt, Đi muộn, Vắng mặt) và lý do chi tiết.</p>
                <a href="/Parent/Attendance" class="btn btn-danger rounded-pill px-4 py-2 mt-2 text-white">Truy cập chuyên cần</a>
            </div>
        </div>
    </div>

    <!-- Đổi mật khẩu -->
    <div class="col-md-6">
        <div class="card h-100 shadow-sm border-0 rounded-4 hover-card">
            <div class="card-body text-center p-4">
                <div class="display-4 text-warning mb-3">
                    🔐
                </div>
                <h3 class="card-title fw-bold">Đổi mật khẩu</h3>
                <p class="card-text text-muted">Bảo vệ tài khoản của bạn bằng cách cập nhật mật khẩu thường xuyên.</p>
                <button type="button" class="btn btn-warning rounded-pill px-4 py-2 mt-2 text-white" data-bs-toggle="modal" data-bs-target="#changePasswordModal">Đổi mật khẩu ngay</button>
            </div>
        </div>
    </div>
    <!-- Hồ sơ phụ huynh -->
    <div class="col-md-6">
        <div class="card h-100 shadow-sm border-0 rounded-4 hover-card">
            <div class="card-body text-center p-4">
                <div class="display-4 text-info mb-3">
                    👤
                </div>
                <h3 class="card-title fw-bold">Hồ sơ cá nhân</h3>
                <p class="card-text text-muted">Xem và cập nhật thông tin cá nhân (Tên, Email, SĐT) của bạn.</p>
                <button type="button" class="btn btn-info rounded-pill px-4 py-2 mt-2 text-white" data-bs-toggle="modal" data-bs-target="#parentProfileModal">Quản lý hồ sơ</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Đổi Mật Khẩu -->
<div class="modal fade" id="changePasswordModal" tabindex="-1" aria-labelledby="changePasswordModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content rounded-4 border-0 shadow">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-bold" id="changePasswordModalLabel">Đổi Mật Khẩu</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body px-4 py-4">
        <form id="formChangePassword">
          <div class="mb-3 text-start">
            <label class="form-label text-muted small fw-bold">MẬT KHẨU CŨ</label>
            <input type="password" class="form-control form-control-lg bg-light border-0" id="oldPassword" required>
          </div>
          <div class="mb-4 text-start">
            <label class="form-label text-muted small fw-bold">MẬT KHẨU MỚI</label>
            <input type="password" class="form-control form-control-lg bg-light border-0" id="newPassword" required minlength="6">
          </div>
          <div id="changePasswordMessage" class="alert d-none text-start"></div>
          <button type="submit" class="btn btn-primary w-100 btn-lg rounded-pill fw-bold" id="btnSubmitChangePassword">Xác nhận đổi mật khẩu</button>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Modal Hồ Sơ Cá Nhân -->
<div class="modal fade" id="parentProfileModal" tabindex="-1" aria-labelledby="parentProfileModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content rounded-4 border-0 shadow">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-bold" id="parentProfileModalLabel">Hồ Sơ Của Tôi</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body px-4 py-4">
        <form id="formParentProfile">
          <div class="mb-3 text-start">
            <label class="form-label text-muted small fw-bold">HỌ VÀ TÊN</label>
            <input type="text" class="form-control form-control-lg bg-light border-0" id="profileFullName" required maxlength="150">
          </div>
          <div class="mb-3 text-start">
            <label class="form-label text-muted small fw-bold">EMAIL</label>
            <input type="email" class="form-control form-control-lg bg-light border-0" id="profileEmail">
          </div>
          <div class="mb-4 text-start">
            <label class="form-label text-muted small fw-bold">SỐ ĐIỆN THOẠI</label>
            <input type="tel" class="form-control form-control-lg bg-light border-0" id="profilePhone">
          </div>
          <div id="profileMessage" class="alert d-none text-start"></div>
          <button type="submit" class="btn btn-info w-100 btn-lg rounded-pill fw-bold text-white" id="btnSubmitProfile">Lưu thay đổi</button>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const form = document.getElementById('formChangePassword');
        if (form) {
            form.addEventListener('submit', async function(e) {
                e.preventDefault();
                
                const oldPassword = document.getElementById('oldPassword').value;
                const newPassword = document.getElementById('newPassword').value;
                const msgBox = document.getElementById('changePasswordMessage');
                const btnSubmit = document.getElementById('btnSubmitChangePassword');
                
                // Xóa thông báo cũ
                msgBox.className = 'alert d-none text-start';
                msgBox.innerText = '';
                
                btnSubmit.disabled = true;
                btnSubmit.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Đang xử lý...';

                try {
                    const response = await fetch('/api/auth/change-password', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ oldPassword, newPassword })
                    });

                    const data = await response.json();

                    if (response.ok) {
                        msgBox.className = 'alert alert-success text-start';
                        msgBox.innerText = data.message || 'Đổi mật khẩu thành công! Vui lòng đăng nhập lại.';
                        setTimeout(() => {
                            handleLogout();
                        }, 2000);
                    } else {
                        msgBox.className = 'alert alert-danger text-start';
                        msgBox.innerText = data.message || 'Đã có lỗi xảy ra.';
                        if (data.errors) {
                            const errs = Object.values(data.errors).flat().join('\n');
                            msgBox.innerText += '\n' + errs;
                        }
                    }
                } catch (error) {
                    msgBox.className = 'alert alert-danger text-start';
                    msgBox.innerText = 'Lỗi kết nối đến máy chủ.';
                } finally {
                    btnSubmit.disabled = false;
                    btnSubmit.innerText = 'Xác nhận đổi mật khẩu';
                }
            });
        }

        // --- Logic Hồ Sơ Cá Nhân ---
        const profileModalEl = document.getElementById('parentProfileModal');
        const formProfile = document.getElementById('formParentProfile');
        
        if (profileModalEl && formProfile) {
            profileModalEl.addEventListener('show.bs.modal', async function () {
                // Fetch profile data when modal opens
                const msgBox = document.getElementById('profileMessage');
                msgBox.className = 'alert d-none text-start';
                
                try {
                    const response = await fetch('/api/parent-profile');
                    if (response.ok) {
                        const data = await response.json();
                        document.getElementById('profileFullName').value = data.fullName || '';
                        document.getElementById('profileEmail').value = data.email || '';
                        document.getElementById('profilePhone').value = data.phone || '';
                    } else {
                        msgBox.className = 'alert alert-danger text-start';
                        msgBox.innerText = 'Không thể tải thông tin hồ sơ.';
                    }
                } catch (error) {
                    msgBox.className = 'alert alert-danger text-start';
                    msgBox.innerText = 'Lỗi kết nối đến máy chủ.';
                }
            });

            formProfile.addEventListener('submit', async function(e) {
                e.preventDefault();
                
                const fullName = document.getElementById('profileFullName').value;
                const email = document.getElementById('profileEmail').value;
                const phone = document.getElementById('profilePhone').value;
                const msgBox = document.getElementById('profileMessage');
                const btnSubmit = document.getElementById('btnSubmitProfile');
                
                msgBox.className = 'alert d-none text-start';
                btnSubmit.disabled = true;
                btnSubmit.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Đang lưu...';

                try {
                    const response = await fetch('/api/parent-profile', {
                        method: 'PUT',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ fullName, email, phone })
                    });

                    const data = await response.json();

                    if (response.ok) {
                        msgBox.className = 'alert alert-success text-start';
                        msgBox.innerText = data.message || 'Cập nhật hồ sơ thành công!';
                        setTimeout(() => {
                            if(typeof bootstrap !== 'undefined'){
                                const modal = bootstrap.Modal.getInstance(profileModalEl);
                                if(modal) modal.hide();
                            }
                            msgBox.className = 'alert d-none text-start';
                        }, 1500);
                    } else {
                        msgBox.className = 'alert alert-danger text-start';
                        msgBox.innerText = data.message || 'Đã có lỗi xảy ra.';
                        if (data.errors) {
                            const errs = Object.values(data.errors).flat().join('\n');
                            msgBox.innerText += '\n' + errs;
                        }
                    }
                } catch (error) {
                    msgBox.className = 'alert alert-danger text-start';
                    msgBox.innerText = 'Lỗi kết nối đến máy chủ.';
                } finally {
                    btnSubmit.disabled = false;
                    btnSubmit.innerText = 'Lưu thay đổi';
                }
            });
        }
    });
</script>

<style>
    .hover-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .hover-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
</style>
