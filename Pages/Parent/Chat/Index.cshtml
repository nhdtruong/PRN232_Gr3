@page
@model PROJECT_PRN232_.Pages.Parent.Chat.IndexModel
@{
    ViewData["Title"] = "Phụ huynh - Trò chuyện với Trung tâm";
}

<!-- Truyền UserId, Role và ChannelId hiện tại sang cho JS -->
<div id="chat-page-metadata" 
     data-current-user-id="@Model.CurrentUserId" 
     data-current-role="Parent"
     data-parent-channel-id="@Model.ChannelId"
     data-parent-center-name="@Model.CenterAdmin.FullName"
     style="display: none;">
</div>

<div class="container py-2">
    <div class="row justify-content-center">
        <div class="col-md-10 mb-4">
            <div class="card shadow-sm border-0" id="chat-window-card" style="height: 600px; display: flex; flex-direction: column;">
                
                <!-- Khung chát đang hoạt động -->
                <div class="d-flex flex-column h-100" id="chat-active-window">
                    <div class="card-header bg-primary text-white py-3 d-flex align-items-center justify-content-between" style="border-top-left-radius: 8px; border-top-right-radius: 8px;">
                        <div class="d-flex align-items-center">
                            <div class="avatar bg-white text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold me-3" style="width: 42px; height: 42px;">
                                C
                            </div>
                            <div>
                                <h6 class="mb-0 text-white fw-bold">@Model.CenterAdmin.FullName</h6>
                                <span class="badge bg-light text-primary rounded-pill" style="font-size: 0.65rem;">Hỗ trợ Trung tâm</span>
                            </div>
                        </div>
                        <span class="text-white-50 small" style="font-size: 0.75rem;">Mã kênh chat: #@Model.ChannelId</span>
                    </div>

                    <!-- Vùng tin nhắn -->
                    <div class="card-body bg-light p-4 overflow-auto flex-grow-1" id="chat-messages-container" style="height: 420px;">
                        <!-- Các tin nhắn được nạp động -->
                    </div>

                    <!-- Ô nhập liệu -->
                    <div class="card-footer bg-white border-top p-3">
                        <!-- Hidden file input -->
                        <input type="file" id="chat-file-input" style="display: none;"
                               accept="image/*,video/*,.pdf,.doc,.docx,.xls,.xlsx" />

                        <!-- Khu vực preview file đã chọn (ẩn ban đầu) -->
                        <div id="file-preview-bar" class="d-flex align-items-center gap-2 mb-2 p-2 bg-light rounded border d-none">
                            <i class="bi bi-paperclip text-primary"></i>
                            <span id="file-preview-name" class="small text-truncate flex-grow-1 text-dark"></span>
                            <span id="file-preview-size" class="small text-muted"></span>
                            <button type="button" id="file-preview-cancel" class="btn-close btn-close-sm" style="font-size: 0.6rem;"></button>
                        </div>

                        <form id="chat-form" class="input-group">
                            <!-- Nút đính kèm file -->
                            <button type="button" id="attach-file-btn" class="btn btn-outline-secondary"
                                    title="Đính kèm ảnh, video hoặc tài liệu">
                                <i class="bi bi-paperclip"></i>
                            </button>
                            <input type="text" id="chat-input" class="form-control" placeholder="Nhập câu hỏi hoặc phản hồi..." autocomplete="off">
                            <button class="btn btn-primary" type="submit" id="chat-send-btn">
                                <i class="bi bi-send-fill me-1"></i> Gửi
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Tin nhắn bong bóng */
    .message-bubble-wrapper {
        display: flex;
        margin-bottom: 15px;
        width: 100%;
    }
    .message-bubble-wrapper.sent {
        justify-content: flex-end;
    }
    .message-bubble-wrapper.received {
        justify-content: flex-start;
    }
    .message-bubble {
        max-width: 70%;
        padding: 10px 14px;
        border-radius: 16px;
        font-size: 0.9rem;
        word-break: break-word;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }
    .message-bubble-wrapper.sent .message-bubble {
        background-color: #0d6efd;
        color: white;
        border-bottom-right-radius: 4px;
    }
    .message-bubble-wrapper.received .message-bubble {
        background-color: #e9ecef;
        color: #212529;
        border-bottom-left-radius: 4px;
    }
    .message-meta {
        font-size: 0.7rem;
        margin-top: 4px;
        display: block;
        opacity: 0.8;
    }
    .message-bubble-wrapper.sent .message-meta {
        text-align: right;
    }
</style>


