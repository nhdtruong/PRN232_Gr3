@page
@model PROJECT_PRN232_.Pages.Parent.LessonsModel
@{
    ViewData["Title"] = "Lịch học & Tài liệu học tập";
}

<div class="container py-4">
    <!-- Header chung -->
    <div class="row align-items-center mb-4 g-3">
        <div class="col-md-9">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1 small">
                    <li class="breadcrumb-item"><a href="/Parent/Dashboard" class="text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Lịch học & Học liệu</li>
                </ol>
            </nav>
            <h1 class="h3 fw-bold text-dark mb-1">
                <i class="bi bi-journal-bookmark-fill text-primary me-2"></i>Lịch học & Tài liệu học tập
            </h1>
            <p class="text-muted mb-0">Theo dõi tiến độ bài học, xem video bài giảng và tải tài liệu ôn tập của các con</p>
        </div>
        <!-- Chọn con -->
        <div class="col-md-3 text-md-end">
            <div class="d-inline-block text-start w-100">
                <label class="form-label small fw-bold text-muted mb-1"><i class="bi bi-person-fill-check me-1"></i>Chọn con em:</label>
                <select class="form-select rounded-pill border-0 shadow-sm px-3 py-2 fw-semibold text-secondary" id="selectChild" style="font-size: 0.9rem;">
                    <option value="">-- Chọn học sinh --</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Khu vực chính -->
    <div class="row g-4">
        <!-- Cột trái: Danh sách buổi học cuộn độc lập -->
        <div class="col-lg-5 col-md-12">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom py-3 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-dark">
                        <i class="bi bi-calendar3 text-primary me-2"></i>Danh sách buổi học
                    </h5>
                    <span id="lessonBadgeCount" class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-1.5 small fw-semibold" style="display: none;">0 buổi</span>
                </div>
                <!-- Container cuộn độc lập -->
                <div class="card-body p-3 scrollable-lessons-container" style="max-height: 580px; overflow-y: auto;">
                    <div class="d-flex flex-column gap-3.5" id="lessonsList">
                        <!-- Trạng thái trống ban đầu -->
                        <div class="text-center py-5 text-muted my-4" id="noLessonsMessage">
                            <i class="bi bi-calendar2-x fs-1 d-block mb-3 text-secondary opacity-50"></i>
                            <p class="mb-0 fw-semibold">Vui lòng chọn con ở góc phải để xem lịch học chi tiết.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Cột phải: Chi tiết tài liệu học tập -->
        <div class="col-lg-7 col-md-12">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden position-sticky" style="top: 24px;">
                <div class="card-header bg-white border-bottom py-3 px-4">
                    <h5 class="mb-0 fw-bold text-dark">
                        <i class="bi bi-box-seam-fill text-success me-2"></i>Chi tiết bài giảng & Học liệu
                    </h5>
                </div>
                <div class="card-body p-4" id="lessonDetailsArea" style="min-height: 350px;">
                    <div class="text-center py-5 text-muted my-5" id="noSelectLessonMessage">
                        <i class="bi bi-info-circle fs-2 d-block mb-3 text-secondary opacity-50"></i>
                        <p class="mb-0 fw-semibold">Chọn một buổi học ở danh sách bên trái để xem tài liệu chi tiết.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Cuộn độc lập sidebar */
    .scrollable-lessons-container::-webkit-scrollbar {
        width: 6px;
    }
    .scrollable-lessons-container::-webkit-scrollbar-track {
        background: transparent;
    }
    .scrollable-lessons-container::-webkit-scrollbar-thumb {
        background: #ced4da;
        border-radius: 10px;
    }
    .scrollable-lessons-container::-webkit-scrollbar-thumb:hover {
        background: #adb5bd;
    }

    /* Thiết kế thẻ buổi học Mini Card */
    .lesson-card {
        cursor: pointer;
        border: 1px solid #f0f2f5;
        background-color: #ffffff;
        border-radius: 16px;
        padding: 16px;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
    }
    .lesson-card::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 0;
        background-color: #0d6efd;
        transition: width 0.2s ease;
    }
    .lesson-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 18px rgba(0, 0, 0, 0.05);
        border-color: #e2e5e9;
    }
    .lesson-card.active {
        background-color: #f4f8ff;
        border-color: #cfe2ff;
    }
    .lesson-card.active::before {
        width: 4px;
    }

    /* Thẻ tài liệu ngang (Horizontal Document Cards) */
    .material-item-card {
        border: 1px solid #f0f2f5;
        border-radius: 16px;
        transition: all 0.2s ease;
        background: #fff;
    }
    .material-item-card:hover {
        transform: scale(1.01);
        border-color: #20c997;
        box-shadow: 0 4px 12px rgba(32, 201, 151, 0.05);
    }
    
    .gap-3.5 {
        gap: 12px !important;
    }
    
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

@section Scripts {
    <script src="~/js/parent-lessons.js" asp-append-version="true"></script>
}
