@inject PROJECT_PRN232_.Repositories.INotificationRepository NotificationRepository
@using System.Security.Claims

@{
    var unreadCount = 0;
    if (User.Identity?.IsAuthenticated == true && User.IsInRole("Parent"))
    {
        var parentIdClaim = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (int.TryParse(parentIdClaim, out var parentId))
        {
            unreadCount = await NotificationRepository.CountUnreadByParentAsync(parentId);
        }
    }
}

    @* Dùng eb-icon-btn để bell hiển thị trắng trên Navbar gradient indigo của EduBridge *@
    <a href="#" class="eb-icon-btn no-arrow dropdown-toggle"
       id="notificationDropdown" role="button"
       data-bs-toggle="dropdown" aria-expanded="false" title="Thông báo">
        <i class="bi bi-bell"></i>
        <span id="notification-badge" class="eb-badge" style="@(unreadCount == 0 ? "display: none;" : "")">
            @unreadCount
        </span>
    </a>
    <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-0 eb-dropdown-menu"
        aria-labelledby="notificationDropdown"
        id="notification-list-container"
        style="width: 340px; max-height: 400px; overflow-y: auto;">
        <li class="p-2 border-bottom d-flex justify-content-between align-items-center bg-light"
            style="border-top-left-radius: 12px; border-top-right-radius: 12px;">
            <span class="fw-bold small" style="color: var(--eb-text-heading);">
                <i class="bi bi-bell-fill me-1" style="color: var(--eb-primary);"></i> Thông báo
            </span>
            <button id="mark-all-read-btn"
                    class="btn btn-sm btn-link text-decoration-none p-0 small fw-semibold"
                    style="color: var(--eb-primary); @(unreadCount == 0 ? "display: none;" : "")">
                Đọc tất cả
            </button>
        </li>
        <div id="notification-items-list" class="list-group list-group-flush"
             style="max-height: 320px; overflow-y: auto;">
            <div class="p-3 text-center text-muted small" id="no-notifications-placeholder">
                <div class="spinner-border spinner-border-sm text-secondary me-1" role="status"></div>
                Đang tải thông báo...
            </div>
        </div>
        <li class="border-top text-center bg-light p-2"
            style="border-bottom-left-radius: 12px; border-bottom-right-radius: 12px;">
            <span class="text-muted small" style="font-size: 0.72rem;">
                EduBridge Realtime &copy; 2026
            </span>
        </li>
    </ul>
