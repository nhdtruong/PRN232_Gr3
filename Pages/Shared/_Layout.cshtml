@inject PROJECT_PRN232_.Services.IChatService ChatService
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduBridge</title>
    <meta name="description" content="EduBridge — Hệ thống quản lý trung tâm tiếng Anh thông minh, kết nối Trung tâm và Phụ huynh theo thời gian thực." />

    <!-- Google Fonts: Plus Jakarta Sans (Modern EdTech Typography) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Bootstrap 5.3 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons 1.11 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        /* ============================================================
           EDUBRIDGE DESIGN SYSTEM — CSS VARIABLES
           Đây là nguồn màu chính thức. Tất cả trang con PHẢI dùng các
           biến này thay vì hardcode màu. (DO NOT OVERRIDE)
           ============================================================ */
        :root {
            --eb-primary:         #4F46E5;  /* Indigo chủ đạo */
            --eb-primary-dark:    #3730A3;  /* Indigo đậm (hover, gradient trái) */
            --eb-primary-light:   #EEF2FF;  /* Indigo nhạt (highlight, unread bg) */
            --eb-primary-mid:     #6366F1;  /* Indigo trung (accent phụ) */
            --eb-success:         #10B981;  /* Emerald (hoạt động, điểm danh OK) */
            --eb-warning:         #F59E0B;  /* Amber (cảnh báo, chờ xử lý) */
            --eb-danger:          #EF4444;  /* Red (lỗi, badge thông báo) */
            --eb-info:            #06B6D4;  /* Cyan (thông tin phụ) */
            --eb-body-bg:         #F8F9FC;  /* Nền trang tổng */
            --eb-text-heading:    #1E1B4B;  /* Tiêu đề — Indigo đậm gần đen */
            --eb-text-body:       #374151;  /* Văn bản thường */
            --eb-text-muted:      #6B7280;  /* Chú thích, placeholder */
            --eb-card-shadow:     0 4px 20px rgba(79, 70, 229, 0.08);
            --eb-card-shadow-lg:  0 8px 30px rgba(79, 70, 229, 0.12);
            --eb-font:            'Plus Jakarta Sans', 'Segoe UI', sans-serif;
            --eb-radius-card:     14px;
            --eb-radius-btn:      8px;
        }

        /* ============================================================
           GLOBAL BASE
           ============================================================ */
        * { box-sizing: border-box; }

        body {
            font-family: var(--eb-font);
            background-color: var(--eb-body-bg);
            color: var(--eb-text-body);
            -webkit-font-smoothing: antialiased;
            /* Sticky footer: body chiếm toàn bộ chiều cao viewport */
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        h1, h2, h3, h4, h5, h6 {
            font-family: var(--eb-font);
            color: var(--eb-text-heading);
            font-weight: 700;
        }

        .text-muted { color: var(--eb-text-muted) !important; }

        /* ============================================================
           BOOTSTRAP COLOR OVERRIDES — Ép về bộ màu EduBridge
           Các thành viên chỉ cần dùng class Bootstrap tiêu chuẩn,
           màu sắc sẽ tự động áp dụng chuẩn EduBridge.
           ============================================================ */
        .btn-primary        { background-color: var(--eb-primary); border-color: var(--eb-primary); }
        .btn-primary:hover  { background-color: var(--eb-primary-dark); border-color: var(--eb-primary-dark); }
        .btn-outline-primary { color: var(--eb-primary); border-color: var(--eb-primary); }
        .btn-outline-primary:hover { background-color: var(--eb-primary); border-color: var(--eb-primary); }

        .text-primary      { color: var(--eb-primary) !important; }
        .bg-primary        { background-color: var(--eb-primary) !important; }
        .border-primary    { border-color: var(--eb-primary) !important; }
        .badge.bg-primary  { background-color: var(--eb-primary) !important; }

        .text-success      { color: var(--eb-success) !important; }
        .bg-success        { background-color: var(--eb-success) !important; }
        .btn-success       { background-color: var(--eb-success); border-color: var(--eb-success); }
        .btn-success:hover { background-color: #059669; border-color: #059669; }

        .card {
            border-radius: var(--eb-radius-card);
            box-shadow: var(--eb-card-shadow);
            border: 1px solid rgba(79, 70, 229, 0.07);
        }
        .card:hover { box-shadow: var(--eb-card-shadow-lg); }

        /* ============================================================
           NAVBAR — EduBridge Gradient Indigo
           ============================================================ */
        .eb-navbar {
            background: linear-gradient(135deg, var(--eb-primary-dark) 0%, var(--eb-primary) 100%);
            box-shadow: 0 2px 20px rgba(55, 48, 163, 0.4);
            padding: 0.55rem 0;
            position: sticky;
            top: 0;
            z-index: 1030;
        }

        .eb-brand {
            font-weight: 800;
            font-size: 1.3rem;
            color: #fff !important;
            letter-spacing: -0.5px;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            transition: opacity 0.2s;
        }
        .eb-brand:hover { opacity: 0.9; }
        .eb-brand .brand-icon { color: #a5b4fc; font-size: 1.4rem; }
        .eb-brand .brand-dot  { color: #a5b4fc; }

        /* Nav links */
        .eb-nav-link {
            color: rgba(255, 255, 255, 0.82) !important;
            font-weight: 500;
            font-size: 0.875rem;
            padding: 0.4rem 0.7rem !important;
            border-radius: 7px;
            transition: background 0.18s, color 0.18s;
            text-decoration: none;
        }
        .eb-nav-link:hover,
        .eb-nav-link:focus,
        .eb-nav-link.active {
            color: #fff !important;
            background: rgba(255, 255, 255, 0.16);
        }
        .eb-nav-link i { font-size: 0.9rem; }

        /* Dropdown menu */
        .eb-dropdown-menu {
            border: none;
            border-radius: 12px;
            box-shadow: 0 8px 32px rgba(30, 27, 75, 0.14);
            padding: 0.4rem;
            min-width: 210px;
            margin-top: 0.5rem !important;
            animation: dropIn 0.15s ease;
        }
        @@keyframes dropIn {
            from { opacity: 0; transform: translateY(-6px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .eb-dropdown-item {
            border-radius: 8px;
            padding: 0.5rem 0.8rem;
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--eb-text-heading);
            transition: background 0.15s, color 0.15s;
        }
        .eb-dropdown-item:hover { background: var(--eb-primary-light); color: var(--eb-primary); }
        .eb-dropdown-item.logout-item:hover { background: #FEE2E2; color: var(--eb-danger) !important; }

        /* Icon action buttons (Chat, Bell) */
        .eb-icon-btn {
            position: relative;
            color: rgba(255, 255, 255, 0.82) !important;
            padding: 0.4rem 0.55rem !important;
            border-radius: 7px;
            transition: background 0.18s, color 0.18s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        .eb-icon-btn:hover { color: #fff !important; background: rgba(255,255,255,0.16); }
        .eb-icon-btn i { font-size: 1.2rem; }

        /* Badge số đỏ trên Chat & Bell */
        .eb-badge {
            position: absolute;
            top: 1px;
            right: 1px;
            font-size: 0.6rem;
            min-width: 16px;
            height: 16px;
            line-height: 16px;
            padding: 0 4px;
            border-radius: 8px;
            background: var(--eb-danger);
            color: #fff;
            font-weight: 700;
            pointer-events: none;
        }

        /* Avatar tròn (chữ cái đầu tên) */
        .eb-avatar {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.22);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.8rem;
            color: #fff;
            border: 1.5px solid rgba(255, 255, 255, 0.45);
            flex-shrink: 0;
        }

        /* Divider dọc giữa icon và user dropdown */
        .nav-divider {
            width: 1px;
            height: 22px;
            background: rgba(255, 255, 255, 0.22);
            margin: 0 3px;
            align-self: center;
        }

        /* Mobile toggler icon (white lines) */
        .navbar-toggler {
            border: 1px solid rgba(255, 255, 255, 0.3);
            padding: 0.35rem 0.55rem;
        }
        .navbar-toggler:focus { box-shadow: none; }
        .navbar-toggler-icon {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba%28255%2C255%2C255%2C0.88%29' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e");
        }

        /* ============================================================
           CONTENT AREA — flex:1 đẩy footer xuống đáy trang
           ============================================================ */
        .eb-content { flex: 1; padding-top: 2rem; padding-bottom: 3rem; }

        /* ============================================================
           SHARED COMPONENT STYLES (gom từ các trang con)
           Các thành viên KHÔNG cần copy các class này vào trang riêng nữa.
           ============================================================ */

        /* Hover card — dùng trong Dashboard, Classes, Parents... */
        .hover-card {
            transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.28s ease;
        }
        .hover-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--eb-card-shadow-lg) !important;
        }

        /* Ẩn mũi tên dropdown Bootstrap cho bell icon */
        .no-arrow::after  { display: none !important; }
        .no-arrow::before { display: none !important; }

        /* Notification item styles */
        .notification-item {
            transition: background-color 0.18s;
            border-bottom: 1px solid #f0f0f0;
        }
        .notification-item:hover  { background-color: #f8f9fa !important; }
        .notification-unread      { background-color: var(--eb-primary-light) !important; }

        /* ============================================================
           FOOTER
           ============================================================ */
        .eb-footer {
            background: linear-gradient(135deg, var(--eb-primary-dark) 0%, var(--eb-primary) 100%);
            color: rgba(255, 255, 255, 0.65);
            padding: 1.4rem 0;
            margin-top: 4rem;
            font-size: 0.81rem;
        }
        .eb-footer .brand-name { color: #fff; font-weight: 700; font-size: 0.9rem; }
        .eb-footer .brand-icon { color: #a5b4fc; }
        .eb-footer a { color: rgba(255,255,255,0.8); text-decoration: none; }
        .eb-footer a:hover { color: #fff; }
        .eb-footer .footer-sep { margin: 0 0.5rem; opacity: 0.4; }
    </style>
</head>
<body>

@{
    /* ═══════════════════════════════════════════════════════════════════
       SERVER-SIDE LOGIC: Lấy thông tin user một lần duy nhất ở đây.
       Mọi template render bên dưới đều dùng các biến này.
       ═══════════════════════════════════════════════════════════════════ */
    var isAuthenticated = User.Identity != null && User.Identity.IsAuthenticated;
    string? userIdString = null;
    string? role = null;
    string userName = "";
    string avatarLetter = "?";
    int unreadChatCount = 0;

    if (isAuthenticated)
    {
        userIdString = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        role         = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
        userName     = User.Identity!.Name ?? "";
        avatarLetter = userName.Length > 0 ? userName.Substring(0, 1).ToUpper() : "?";

        if (int.TryParse(userIdString, out int currentUserId))
        {
            unreadChatCount = await ChatService.GetUnreadChatCountAsync(currentUserId);
        }
    }
}

@* ═══════════════════════════════════════════════════════════════════
   METADATA ẨN TOÀN CỤC — Đặt ngay sau <body>, TRƯỚC mọi thứ khác.
   Dùng bởi: chat-client.js (Guard 1) và notification-client.js (Guard 1).
   Khi user chưa login, div này KHÔNG render → JS tự thoát sớm (Guard Clause).
   ═══════════════════════════════════════════════════════════════════ *@
@if (isAuthenticated)
{
    <div id="global-chat-metadata"
         data-current-user-id="@userIdString"
         data-current-role="@role"
         style="display:none;" aria-hidden="true"></div>
}

<!-- ═══════════════════════════════════════════════════════════════
     HEADER / NAVBAR
     ═══════════════════════════════════════════════════════════════ -->
<header>
    <nav class="navbar navbar-expand-lg eb-navbar" aria-label="EduBridge main navigation">
        <div class="container">

            <!-- Brand Logo -->
            <a class="eb-brand" href="/">
                <i class="bi bi-mortarboard-fill brand-icon"></i>
                Edu<span class="brand-dot">Bridge</span>
            </a>

            <!-- Mobile Hamburger Toggle -->
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarMain"
                    aria-controls="navbarMain" aria-expanded="false" aria-label="Mở/đóng menu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">

                @if (isAuthenticated)
                {
                    @* ── LEFT SIDE: Navigation links theo Role ── *@
                    <ul class="navbar-nav me-auto align-items-lg-center gap-lg-1">
                        @if (role == "Center")
                        {
                            <li class="nav-item">
                                <a class="eb-nav-link" href="/Center/Dashboard">
                                    <i class="bi bi-speedometer2 me-1"></i>Dashboard
                                </a>
                            </li>

                            <!-- Dropdown: Quản lý (gom Phụ huynh, Học sinh, Lớp học) -->
                            <li class="nav-item dropdown">
                                <a class="eb-nav-link dropdown-toggle" href="#"
                                   role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-grid-3x3-gap me-1"></i>Quản lý
                                </a>
                                <ul class="dropdown-menu eb-dropdown-menu">
                                    <li>
                                        <a class="dropdown-item eb-dropdown-item" href="/Center/Parents/Index">
                                            <i class="bi bi-people-fill me-2" style="color: var(--eb-primary);"></i>Phụ huynh
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item eb-dropdown-item" href="/Center/Students/Index">
                                            <i class="bi bi-mortarboard me-2" style="color: var(--eb-primary);"></i>Học sinh
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item eb-dropdown-item" href="/Center/Classes/Index">
                                            <i class="bi bi-collection-fill me-2" style="color: var(--eb-primary);"></i>Lớp học
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else if (role == "Parent")
                        {
                            <li class="nav-item">
                                <a class="eb-nav-link" href="/Parent/Dashboard">
                                    <i class="bi bi-house me-1"></i>Trang chủ
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="eb-nav-link" href="/Parent/ChildrenClasses">
                                    <i class="bi bi-collection me-1"></i>Lớp của con
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="eb-nav-link" href="/Parent/Lessons">
                                    <i class="bi bi-journal-bookmark me-1"></i>Lịch học &amp; Tài liệu
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="eb-nav-link" href="/Parent/Attendance">
                                    <i class="bi bi-clock-history me-1"></i>Chuyên cần
                                </a>
                            </li>
                        }
                    </ul>

                    @* ── RIGHT SIDE: Icon actions + User dropdown ── *@
                    <ul class="navbar-nav align-items-lg-center gap-lg-1">

                        @* Chat Icon — hiển thị cho CẢ HAI role *@
                        @{
                            var chatUrl      = role == "Parent" ? "/Parent/Chat/Index" : "/Center/Chat/Index";
                            var chatTitle    = role == "Parent" ? "Trò chuyện với Trung tâm" : "Trò chuyện với Phụ huynh";
                            var chatBadgeId  = role == "Parent" ? "chat-badge" : "center-chat-badge";
                        }
                        <li class="nav-item">
                            <a class="eb-icon-btn" href="@chatUrl" title="@chatTitle" aria-label="@chatTitle">
                                <i class="bi bi-chat-left-text"></i>
                                <span id="@chatBadgeId" class="eb-badge @(unreadChatCount == 0 ? "d-none" : "")">
                                    @unreadChatCount
                                </span>
                            </a>
                        </li>

                        @* Bell Icon — CHỈ dành cho Parent (nhận thông báo điểm số) *@
                        @if (role == "Parent")
                        {
                            <li class="nav-item">
                                <partial name="_NotificationBadgePartial" />
                            </li>
                        }

                        <!-- Visual divider -->
                        <li class="nav-item d-none d-lg-flex">
                            <div class="nav-divider"></div>
                        </li>

                        <!-- User Dropdown (Avatar + Tên + Logout) -->
                        <li class="nav-item dropdown">
                            <a class="eb-nav-link d-flex align-items-center gap-2 dropdown-toggle"
                               href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false"
                               aria-label="Menu tài khoản">
                                <span class="eb-avatar" aria-hidden="true">@avatarLetter</span>
                                <span class="d-none d-lg-inline">@userName</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end eb-dropdown-menu">
                                <!-- Header thông tin user -->
                                <li>
                                    <div class="px-3 pt-2 pb-2 mb-1" style="border-bottom: 1px solid rgba(79,70,229,0.1);">
                                        <div class="fw-semibold small" style="color: var(--eb-text-heading);">@userName</div>
                                        <div class="mt-1">
                                            <span class="badge rounded-pill fw-normal"
                                                  style="background: var(--eb-primary-light); color: var(--eb-primary); font-size: 0.7rem;">
                                                @if (role == "Center") { <text><i class="bi bi-building me-1"></i>Trung tâm</text> }
                                                else { <text><i class="bi bi-person-heart me-1"></i>Phụ huynh</text> }
                                            </span>
                                        </div>
                                    </div>
                                </li>
                                <li>
                                    <a class="dropdown-item eb-dropdown-item logout-item" href="/Auth/Logout">
                                        <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                    </a>
                                </li>
                            </ul>
                        </li>

                    </ul>
                }
                else
                {
                    /* ── Chưa đăng nhập: chỉ hiện nút Login ── */
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="eb-nav-link" href="/Auth/Login">
                                <i class="bi bi-person-circle me-1"></i>Đăng nhập
                            </a>
                        </li>
                    </ul>
                }

            </div><!-- /.navbar-collapse -->
        </div><!-- /.container -->
    </nav>
</header>

<!-- ═══════════════════════════════════════════════════════════════
     MAIN CONTENT
     ═══════════════════════════════════════════════════════════════ -->
<div class="container eb-content">
    <main role="main">
        @RenderBody()
    </main>
</div>

<!-- ═══════════════════════════════════════════════════════════════
     FOOTER
     ═══════════════════════════════════════════════════════════════ -->
<footer class="eb-footer" aria-label="Footer">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-7 text-center text-md-start mb-2 mb-md-0">
                <i class="bi bi-mortarboard-fill brand-icon me-1"></i>
                <span class="brand-name">EduBridge</span>
                <span class="ms-2">&copy; 2026</span>
                <span class="footer-sep">|</span>
                <span>Hệ thống quản lý trung tâm tiếng Anh thông minh</span>
            </div>
            <div class="col-md-5 text-center text-md-end">
                <span>PRN232 — Nhóm 3</span>
                <span class="footer-sep">·</span>
                <span><i class="bi bi-lightning-charge-fill" style="color: #a5b4fc;"></i> Realtime by SignalR</span>
            </div>
        </div>
    </div>
</footer>

<!-- ═══════════════════════════════════════════════════════════════
     SCRIPTS
     ═══════════════════════════════════════════════════════════════ -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

@* Realtime: chỉ nhúng khi user đã đăng nhập *@
@if (isAuthenticated)
{
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/notification-client.js" asp-append-version="true"></script>
    <script src="~/js/chat-client.js" asp-append-version="true"></script>
}

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
