@inject PROJECT_PRN232_.Services.IChatService ChatService
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduBridge</title>
    <!-- Nhúng Bootstrap qua CDN cho nhanh và đẹp -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Nhúng Bootstrap Icons để vẽ icon thông báo -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body {
            background-color: #f4f7f6;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .navbar-brand {
            font-weight: bold;
            color: #0d6efd !important;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm mb-4">
            <div class="container">
                <a class="navbar-brand" href="/">EduBridge</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-toggle="target" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            var userIdString = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                            var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
                            var unreadChatCount = 0;
                            if (int.TryParse(userIdString, out int currentUserId))
                            {
                                unreadChatCount = await ChatService.GetUnreadChatCountAsync(currentUserId);
                            }

                            <!-- Metadata ẩn dùng chung cho SignalR chat-client -->
                            <div id="global-chat-metadata"
                                 data-current-user-id="@userIdString"
                                 data-current-role="@role"
                                 style="display: none;">
                            </div>

                            if (role == "Parent")
                            {
                                <li class="nav-item align-self-center me-3">
                                    <a class="nav-link text-dark position-relative" href="/Parent/Chat/Index" title="Trò chuyện với Trung tâm">
                                        <i class="bi bi-chat-left-text fs-5"></i>
                                        <span id="chat-badge" class="position-absolute translate-middle badge rounded-pill bg-danger @(unreadChatCount == 0 ? "d-none" : "")">@unreadChatCount</span>
                                    </a>
                                </li>
                            }
                            else if (role == "Center")
                            {
                                <li class="nav-item align-self-center me-3">
                                    <a class="nav-link text-dark position-relative" href="/Center/Chat/Index" title="Trò chuyện với Phụ huynh">
                                        <i class="bi bi-chat-left-text fs-5"></i>
                                        <span id="center-chat-badge" class="position-absolute translate-middle badge rounded-pill bg-danger @(unreadChatCount == 0 ? "d-none" : "")">@unreadChatCount</span>
                                    </a>
                                </li>
                            }

                            @* Icon Quả chuông: CHỈ dành cho Parent (nhận thông báo điểm số từ hệ thống) *@
                            @if (role == "Parent")
                            {
                                <li class="nav-item align-self-center me-3">
                                    <partial name="_NotificationBadgePartial" />
                                </li>
                            }

                            <li class="nav-item">
                                <span class="nav-link text-dark">Xin chào, @User.Identity.Name!</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-danger" href="/Auth/Logout">Đăng xuất</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Auth/Login">Đăng nhập</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5 py-3">
        <div class="container text-center">
            &copy; 2026 - EduBridge Project
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
        <script src="~/js/notification-client.js" asp-append-version="true"></script>
        <script src="~/js/chat-client.js" asp-append-version="true"></script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
