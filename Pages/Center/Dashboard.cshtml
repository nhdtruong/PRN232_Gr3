@page
@model PROJECT_PRN232_.Pages.Center.DashboardModel
@{
    ViewData["Title"] = "Dashboard Chủ Trung Tâm";
}

<div class="row mt-4 mb-4">
    <div class="col-12">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body text-center p-5">
                <h1 class="display-5 text-success mb-3 fw-bold">👑 Xin chào Chủ Trung Tâm!</h1>
                <p class="lead text-muted">Chào mừng ngài đã đăng nhập thành công vào Hệ thống quản lý EduBridge.</p>
            </div>
        </div>
    </div>
</div>

<!-- Thống kê & Danh sách Lớp học đang quản lý -->
<div class="row mb-4">
    <div class="col-12">
        <h2 class="h4 fw-bold text-dark mb-3">
            <i class="bi bi-collection text-primary me-2"></i>Lớp học đang quản lý & Lịch giảng dạy
        </h2>
    </div>
</div>

<div class="row g-4 mb-5">
    @if (Model.Classes != null && Model.Classes.Any())
    {
        @foreach (var c in Model.Classes)
        {
            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0 rounded-4 hover-card">
                    <div class="card-body p-4 d-flex flex-column">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <span class="badge bg-primary rounded-pill px-3 py-1">Class</span>
                            <span class="text-muted small">ID: #@c.Id</span>
                        </div>
                        <h4 class="fw-bold text-dark mb-2">@c.ClassName</h4>
                        <p class="text-muted small flex-grow-1">Trạng thái: <span class="badge bg-success rounded-pill">@c.Status</span></p>
                        
                        <hr class="text-muted my-3 opacity-25">
                        
                        <div class="d-flex flex-column gap-2">
                            <a href="/Center/Lessons/Lesson/@c.Id" class="btn btn-success btn-sm rounded-pill w-100 py-2 fw-semibold">
                                <i class="bi bi-calendar-event me-1"></i> Quản lý Buổi học & Học liệu
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 bg-white py-5">
                <div class="card-body text-center text-muted">
                    <i class="bi bi-building-add fs-1 d-block mb-3 text-secondary"></i>
                    <h5>Chưa có lớp học nào thuộc quyền quản lý của bạn</h5>
                    <p class="small text-muted">Vui lòng liên hệ bộ phận hỗ trợ hoặc tạo lớp học mới để bắt đầu quản lý lịch học.</p>
                </div>
            </div>
        </div>
    }
</div>

<div class="row g-4 mb-5">
    <!-- Quản lý phụ huynh -->
    <div class="col-md-6">
        <div class="card h-100 shadow-sm border-0 rounded-4 hover-card">
            <div class="card-body text-center p-4">
                <div class="display-4 text-primary mb-3">
                    📚
                </div>
                <h3 class="card-title fw-bold">Quản lý phụ huynh</h3>
                <p class="card-text text-muted">Thêm, sửa, xóa, và theo dõi thông tin học sinh trong trung tâm.</p>
                <a asp-page="/Center/Parents/Index" class="btn btn-primary rounded-pill px-4 py-2 mt-2">Truy cập</a>
            </div>
        </div>
    </div>

    <!-- Quản lý student -->
    <div class="col-md-6">
        <div class="card h-100 shadow-sm border-0 rounded-4 hover-card">
            <div class="card-body text-center p-4">
                <div class="display-4 text-info mb-3">
                    🎓
                </div>
                <h3 class="card-title fw-bold">Quản lý học sinh</h3>
                <p class="card-text text-muted">Quản lý hồ sơ học sinh, kết quả học tập và thông tin cá nhân.</p>
                <a asp-page="/Center/Students/Index" class="btn btn-info text-white rounded-pill px-4 py-2 mt-2">Truy cập</a>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .hover-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
</style>
