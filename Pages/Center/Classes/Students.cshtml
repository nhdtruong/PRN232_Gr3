@page
@model PROJECT_PRN232_.Pages.Center.Classes.StudentsModel
@{
    ViewData["Title"] = "Học viên Lớp học";
}

<div class="container mt-4">
    <div class="mb-4">
        <a asp-page="/Center/Classes/Index" class="btn btn-link text-decoration-none p-0 text-muted mb-2">
            <i class="fa-solid fa-arrow-left me-2"></i>Quay lại danh sách lớp
        </a>
        <h2 class="fw-bold">👥 Thành viên lớp: <span class="text-primary">@Model.ClassInfo.ClassName</span></h2>
        <p class="text-muted">Quản lý danh sách học viên, thêm học viên mới hoặc chuyển lớp.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm" role="alert">
            <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Student List -->
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Danh sách Học viên</h5>
                    
                    @if (!Model.EnrolledStudents.Any())
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="fa-solid fa-users-slash display-6 mb-3"></i>
                            <p class="mb-0">Chưa có học viên nào được xếp vào lớp này.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Mã số (ID)</th>
                                        <th>Họ và Tên</th>
                                        <th>Ngày sinh</th>
                                        <th>Giới tính</th>
                                        <th class="text-end">Hành động</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in Model.EnrolledStudents)
                                    {
                                        <tr>
                                            <td><strong>#@s.Id</strong></td>
                                            <td><span class="fw-semibold">@s.FullName</span></td>
                                            <td>@(s.DateOfBirth?.ToString("dd/MM/yyyy") ?? "-")</td>
                                            <td>@(s.Gender ?? "-")</td>
                                            <td class="text-end">
                                                <div class="d-inline-flex gap-2">
                                                    <button class="btn btn-outline-primary btn-sm rounded-pill px-3" 
                                                            onclick="openTransferModal(@s.Id, '@s.FullName')"
                                                            data-bs-toggle="modal" data-bs-target="#transferModal">
                                                        <i class="fa-solid fa-right-left me-1"></i>Chuyển lớp
                                                    </button>
                                                    <form method="post" asp-page-handler="Remove" asp-route-studentId="@s.Id" 
                                                          onsubmit="return confirm('Bạn có chắc chắn muốn xóa học sinh @s.FullName khỏi lớp này?');">
                                                        <input type="hidden" asp-for="ClassId" />
                                                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                                                            <i class="fa-solid fa-trash me-1"></i>Xóa
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Add Student Form -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Xếp Học viên Mới</h5>
                    
                    <form method="post" asp-page-handler="Enroll">
                        <input type="hidden" asp-for="ClassId" />
                        <div class="mb-3">
                            <label asp-for="StudentId" class="form-label fw-semibold">ID Học sinh</label>
                            <input asp-for="StudentId" class="form-control rounded-3" type="number" required placeholder="Nhập mã học sinh...">
                            <span asp-validation-for="StudentId" class="text-danger small"></span>
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100 rounded-pill py-2">
                            <i class="fa-solid fa-user-plus me-2"></i>Thêm vào lớp
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- TRANSFER MODAL -->
<div class="modal fade" id="transferModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title fw-bold" id="transferTitle">Chuyển Lớp</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="Transfer" id="transferForm">
                <input type="hidden" asp-for="ClassId" />
                <input type="hidden" asp-for="StudentId" id="transferStudentId" />
                
                <div class="modal-body">
                    <div class="mb-3">
                        <label asp-for="TargetClassId" class="form-label fw-semibold">Chọn lớp học mới (Đang hoạt động)</label>
                        <select asp-for="TargetClassId" class="form-select rounded-3" required>
                            @foreach (var c in Model.ActiveClasses)
                            {
                                <option value="@c.Id">@c.ClassName (ID: @c.Id)</option>
                            }
                        </select>
                        <span asp-validation-for="TargetClassId" class="text-danger small"></span>
                    </div>
                </div>
                
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Xác nhận chuyển</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openTransferModal(studentId, studentName) {
            document.getElementById('transferStudentId').value = studentId;
            document.getElementById('transferTitle').textContent = `Chuyển lớp cho học viên: ${studentName}`;
        }
    </script>
}
