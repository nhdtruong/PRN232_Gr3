@page
@model PROJECT_PRN232_.Pages.Center.Classes.IndexModel
@{
    ViewData["Title"] = "Quản lý Lớp học";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">🏫 Quản lý Lớp học</h2>
            <p class="text-muted">Danh sách và các thiết lập trạng thái lớp học tại trung tâm.</p>
        </div>
        <button class="btn btn-primary rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#createClassModal">
            <i class="fa-solid fa-plus me-2"></i>Tạo Lớp Mới
        </button>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm" role="alert">
            <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div asp-validation-summary="All" class="text-danger mb-3"></div>


    <div class="row g-4">
        @foreach (var c in Model.Classes)
        {
            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0 rounded-4">
                    <div class="card-body p-4 d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h4 class="fw-bold text-dark mb-0">@c.ClassName</h4>
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge @(c.Status == "Active" ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger") rounded-pill px-3 py-2 border">
                                    @(c.Status == "Active" ? "Đang hoạt động" : "Đã đóng")
                                </span>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@c.Id" onsubmit="return confirm('Bạn có chắc chắn muốn xóa lớp học này?');">
                                    <button type="submit" class="btn btn-link text-danger p-0 border-0 bg-transparent" title="Xóa lớp học">
                                        <i class="fa-solid fa-trash-can fs-5"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                        <div class="text-muted mb-4 small">
                            <div><i class="fa-solid fa-hashtag text-primary me-2"></i>Mã lớp: <strong>@c.Id</strong></div>
                            <div><i class="fa-solid fa-building text-info me-2"></i>Mã trung tâm: <strong>@c.CenterId</strong></div>
                            <div><i class="fa-solid fa-users text-success me-2"></i>Sĩ số: <strong>@c.StudentCount</strong> học viên</div>
                        </div>
                        <div class="mt-auto d-flex gap-2 pt-3 border-top">
                            <button class="btn btn-outline-secondary btn-sm rounded-pill flex-grow-1" 
                                    onclick="openEditModal(@c.Id, '@c.ClassName', @c.CenterId)"
                                    data-bs-toggle="modal" data-bs-target="#editClassModal">
                                <i class="fa-solid fa-pen me-1"></i>Sửa
                            </button>
                            
                            <form method="post" asp-page-handler="ToggleStatus" asp-route-id="@c.Id" asp-route-currentStatus="@c.Status" class="flex-grow-1">
                                <button type="submit" class="btn @(c.Status == "Active" ? "btn-outline-danger" : "btn-outline-success") btn-sm rounded-pill w-100">
                                    <i class="fa-solid @(c.Status == "Active" ? "fa-ban" : "fa-check-circle") me-1"></i>@(c.Status == "Active" ? "Đóng" : "Mở")
                                </button>
                            </form>
                            
                            <a asp-page="/Center/Classes/Students" asp-route-classId="@c.Id" class="btn btn-primary btn-sm rounded-pill flex-grow-1">
                                <i class="fa-solid fa-users me-1"></i>Học viên
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- CREATE CLASS MODAL -->
<div class="modal fade" id="createClassModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Tạo Lớp Học Mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="Create">
                <div class="modal-body">
                    <div class="mb-3">
                        <label asp-for="CreateDto.ClassName" class="form-label fw-semibold">Tên lớp học</label>
                        <input asp-for="CreateDto.ClassName" class="form-control rounded-3" placeholder="Nhập tên lớp..." required>
                        <span asp-validation-for="CreateDto.ClassName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="CreateDto.CenterId" class="form-label fw-semibold">Mã Trung Tâm</label>
                        <input asp-for="CreateDto.CenterId" class="form-control rounded-3" type="number" value="1" required>
                        <span asp-validation-for="CreateDto.CenterId" class="text-danger small"></span>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Tạo Lớp</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- EDIT CLASS MODAL -->
<div class="modal fade" id="editClassModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Sửa Lớp Học</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="Update">
                <input type="hidden" asp-for="UpdateDto.Id" id="editClassId" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label asp-for="UpdateDto.ClassName" class="form-label fw-semibold">Tên lớp học</label>
                        <input asp-for="UpdateDto.ClassName" class="form-control rounded-3" id="editClassName" required>
                        <span asp-validation-for="UpdateDto.ClassName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="UpdateDto.CenterId" class="form-label fw-semibold">Mã Trung Tâm</label>
                        <input asp-for="UpdateDto.CenterId" class="form-control rounded-3" type="number" id="editCenterId" required>
                        <span asp-validation-for="UpdateDto.CenterId" class="text-danger small"></span>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Lưu Thay Đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
    <script>
        function openEditModal(id, name, centerId) {
            document.getElementById('editClassId').value = id;
            document.getElementById('editClassName').value = name;
            document.getElementById('editCenterId').value = centerId;
        }
    </script>
}
