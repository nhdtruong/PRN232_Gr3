@page
@model PROJECT_PRN232_.Pages.Center.Chat.IndexModel
@{
    ViewData["Title"] = "Trung tâm - Trò chuyện với Phụ huynh";
}

<!-- Truyền UserId và Role hiện tại sang cho JS -->
<div id="chat-page-metadata" 
     data-current-user-id="@Model.CurrentUserId" 
     data-current-role="Center"
     data-target-parent-id="@Model.TargetParentId"
     style="display: none;">
</div>

<div class="container py-2">
    <div class="row">
        <!-- Cột trái: Danh sách phụ huynh -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0" style="height: 600px; display: flex; flex-direction: column;">
                <div class="card-header bg-primary text-white py-3" style="border-top-left-radius: 8px; border-top-right-radius: 8px;">
                    <h5 class="mb-0"><i class="bi bi-people-fill me-2"></i> Danh sách Phụ huynh</h5>
                </div>
                <div class="p-3 border-bottom bg-light">
                    <input type="text" id="search-contacts" class="form-control form-control-sm" placeholder="Tìm kiếm phụ huynh...">
                </div>
                <div class="list-group list-group-flush overflow-auto flex-grow-1" id="contacts-list" style="height: 480px;">
                    @if (Model.Parents.Count == 0)
                    {
                        <div class="p-4 text-center text-muted small">Không tìm thấy tài khoản Phụ huynh nào.</div>
                    }
                    else
                    {
                        @foreach (var parent in Model.Parents)
                        {
                            <a href="#" class="list-group-item list-group-item-action contact-item py-3 px-3 border-bottom border-0" 
                               data-parent-id="@parent.Id" 
                               data-parent-name="@parent.FullName">
                                <div class="d-flex align-items-center">
                                    <div class="avatar bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold me-3" style="width: 40px; height: 40px;">
                                        @parent.FullName.Substring(0, 1).ToUpper()
                                    </div>
                                    <div class="flex-grow-1">
                                        <h6 class="mb-0 text-dark fw-bold small contact-name">@parent.FullName</h6>
                                        <span class="text-muted small" style="font-size: 0.75rem;">Phụ huynh học sinh</span>
                                    </div>
                                </div>
                            </a>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Cột phải: Khung chát -->
        <div class="col-md-8 mb-4">
            <div class="card shadow-sm border-0" id="chat-window-card" style="height: 600px; display: flex; flex-direction: column;">
                <!-- Trạng thái chưa chọn cuộc trò chuyện -->
                <div class="card-body d-flex flex-column align-items-center justify-content-center text-muted" id="chat-placeholder">
                    <i class="bi bi-chat-left-dots text-secondary mb-3" style="font-size: 4rem;"></i>
                    <h5>Chọn một Phụ huynh bên trái để bắt đầu trò chuyện</h5>
                    <p class="small text-muted">Hệ thống nhắn tin thời gian thực EduBridge</p>
                </div>

                <!-- Khung chát đang hoạt động -->
                <div class="d-flex flex-column h-100" id="chat-active-window" style="display: none !important;">
                    <div class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between" style="border-top-left-radius: 8px; border-top-right-radius: 8px;">
                        <div class="d-flex align-items-center">
                            <div class="avatar bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold me-3" id="active-chat-avatar" style="width: 42px; height: 42px;">
                                U
                            </div>
                            <div>
                                <h6 class="mb-0 text-dark fw-bold" id="active-chat-name">Tên phụ huynh</h6>
                                <span class="badge bg-success rounded-pill" style="font-size: 0.65rem;">Đang kết nối</span>
                            </div>
                        </div>
                        <span class="text-muted small" id="active-channel-info" style="font-size: 0.75rem;">Channel #0</span>
                    </div>

                    <!-- Vùng tin nhắn -->
                    <div class="card-body bg-light p-4 overflow-auto flex-grow-1" id="chat-messages-container" style="height: 420px;">
                        <!-- Các tin nhắn được nạp động -->
                    </div>

                    <!-- Ô nhập liệu -->
                    <div class="card-footer bg-white border-top p-3">
                        <!-- Hidden file input nhận tất cả loại file được phép -->
                        <input type="file" id="chat-file-input" style="display: none;"
                               accept="image/*,video/*,.pdf,.doc,.docx,.xls,.xlsx" />

                        <!-- Khu vực preview file đã chọn (ẩn ban đầu) -->
                        <div id="file-preview-bar" class="d-flex align-items-center gap-2 mb-2 p-2 bg-light rounded border d-none">
                            <i class="bi bi-paperclip text-primary"></i>
                            <span id="file-preview-name" class="small text-truncate flex-grow-1 text-dark"></span>
                            <span id="file-preview-size" class="small text-muted"></span>
                            <button type="button" id="file-preview-cancel" class="btn-close btn-close-sm" style="font-size: 0.6rem;"></button>
                        </div>

                        <form id="chat-form" class="input-group">
                            <!-- Nút đính kèm file -->
                            <button type="button" id="attach-file-btn" class="btn btn-outline-secondary"
                                    title="Đính kèm ảnh, video hoặc tài liệu">
                                <i class="bi bi-paperclip"></i>
                            </button>
                            <input type="text" id="chat-input" class="form-control" placeholder="Nhập tin nhắn..." autocomplete="off">
                            <button class="btn btn-primary" type="submit" id="chat-send-btn">
                                <i class="bi bi-send-fill me-1"></i> Gửi
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .contact-item {
        transition: background-color 0.2s;
    }
    .contact-item:hover {
        background-color: #f1f3f5 !important;
    }
    .contact-item.active {
        background-color: #e8f0fe !important;
        border-left: 4px solid #0d6efd !important;
    }
    
    /* Tin nhắn bong bóng */
    .message-bubble-wrapper {
        display: flex;
        margin-bottom: 15px;
        width: 100%;
    }
    .message-bubble-wrapper.sent {
        justify-content: flex-end;
    }
    .message-bubble-wrapper.received {
        justify-content: flex-start;
    }
    .message-bubble {
        max-width: 70%;
        padding: 10px 14px;
        border-radius: 16px;
        font-size: 0.9rem;
        word-break: break-word;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }
    .message-bubble-wrapper.sent .message-bubble {
        background-color: #0d6efd;
        color: white;
        border-bottom-right-radius: 4px;
    }
    .message-bubble-wrapper.received .message-bubble {
        background-color: #e9ecef;
        color: #212529;
        border-bottom-left-radius: 4px;
    }
    .message-meta {
        font-size: 0.7rem;
        margin-top: 4px;
        display: block;
        opacity: 0.8;
    }
    .message-bubble-wrapper.sent .message-meta {
        text-align: right;
    }
</style>


