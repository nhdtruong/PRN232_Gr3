@page "{classId:int}"
@model PROJECT_PRN232_.Pages.Center.Lessons.LessonModel
@{
    ViewData["Title"] = "Quản lý buổi học";
}

<!-- Metadata ẩn truyền ClassId xuống cho JavaScript -->
<div id="lesson-metadata"
     data-class-id="@Model.ClassId"
     style="display: none;"></div>

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1 small">
            <li class="breadcrumb-item"><a href="/Center/Dashboard" class="text-decoration-none">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Quản lý buổi học</li>
        </ol>
    </nav>

    <!-- Header & Nút tạo -->
    <div class="row align-items-center mb-4 g-3">
        <div class="col-md-8">
            <h1 class="h3 fw-bold text-dark mb-1">
                <i class="bi bi-calendar2-week-fill text-primary me-2"></i>Quản lý buổi học
            </h1>
            <p class="text-muted mb-0">Thiết lập thời gian học, quản lý học liệu và điểm danh lớp học</p>
        </div>
        <div class="col-md-4 text-md-end">
            <button class="btn btn-primary rounded-pill px-4 py-2 shadow-sm fw-semibold" data-bs-toggle="modal" data-bs-target="#createLessonModal">
                <i class="bi bi-plus-lg me-1"></i> Thêm buổi học mới
            </button>
        </div>
    </div>

    <!-- Thanh tìm kiếm & đếm buổi học -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <div class="row align-items-center g-3">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0 rounded-start-pill text-muted px-3"><i class="bi bi-search"></i></span>
                        <input type="text" id="searchLessonInput" class="form-control bg-light border-0 rounded-end-pill py-2" placeholder="Tìm kiếm nhanh chủ đề hoặc nội dung buổi học..." style="font-size: 0.9rem;" />
                    </div>
                </div>
                <div class="col-md-4 text-md-end text-muted small">
                    <span class="badge bg-light text-dark border px-3 py-2 rounded-pill"><i class="bi bi-collection me-1"></i>Tổng số: <strong class="text-primary" id="lessonsCount">0</strong> buổi</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Khu vực hiển thị dạng Lưới Card (Grid of Cards) -->
    <div class="row g-4" id="lessonsGridContainer">
        <!-- Trạng thái trống hoặc loading (JS tự động render) -->
        <div class="col-12 text-center py-5 text-muted">
            <span class="spinner-border spinner-border-sm text-primary me-2" role="status"></span> Đang tải danh sách buổi học...
        </div>
    </div>

    <!-- Thanh phân trang cho Buổi học -->
    <div class="d-flex justify-content-center mt-4 mb-5" id="lessonsPagination">
        <!-- JS tự động tạo nút -->
    </div>
</div>

<!-- Modal Thêm buổi học -->
<div class="modal fade" id="createLessonModal" tabindex="-1" aria-labelledby="createLessonModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold" id="createLessonModalLabel">Thêm buổi học mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="createLessonForm">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Chủ đề buổi học</label>
                        <input type="text" class="form-control rounded-3" placeholder="Ví dụ: Buổi 1 - Giới thiệu về OOP" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mô tả ngắn</label>
                        <textarea class="form-control rounded-3" rows="3" placeholder="Nội dung chính của buổi học..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Ngày học & Giờ học</label>
                        <input type="datetime-local" class="form-control rounded-3" required />
                    </div>
                    <div class="text-end mt-4">
                        <button type="button" class="btn btn-light rounded-pill px-4 me-2" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-4">Tạo buổi học</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Style tùy chỉnh nâng cao -->
<style>
    .admin-lesson-card {
        background-color: #ffffff;
        border-radius: 20px;
        border: 1px solid #f0f2f5;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        display: flex;
        flex-direction: column;
        height: 100%;
        overflow: hidden;
    }
    .admin-lesson-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.06) !important;
        border-color: #e2e5e9;
    }
    .card-footer-buttons {
        border-top: 1px dashed #f0f2f5;
        padding-top: 15px;
    }
    .btn-action-circle {
        width: 36px;
        height: 36px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 50% !important;
    }
    .text-truncate-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    #searchLessonInput:focus {
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1);
        background-color: #fff !important;
        border-color: #86b7fe;
    }
</style>

@section Scripts {
    <script src="~/js/lessons.js" asp-append-version="true"></script>
}
