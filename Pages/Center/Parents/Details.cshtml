@page
@model PROJECT_PRN232_.Pages.Center.Parents.DetailsModel

@{
    ViewData["Title"] = "Chi tiết Phụ huynh";
}

<div class="container mt-4">
    <h2>Chi tiết Phụ huynh</h2>
    <hr />

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h5 class="card-title text-primary mb-3">Thông tin cá nhân</h5>
            <dl class="row">
                <dt class="col-sm-3">Họ và Tên</dt>
                <dd class="col-sm-9">@Model.ParentUser.FullName</dd>

                <dt class="col-sm-3">Tên đăng nhập</dt>
                <dd class="col-sm-9">@Model.ParentUser.Username</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@(Model.ParentUser.Email ?? "Chưa cập nhật")</dd>

                <dt class="col-sm-3">Số điện thoại</dt>
                <dd class="col-sm-9">@(Model.ParentUser.Phone ?? "Chưa cập nhật")</dd>

                <dt class="col-sm-3">Trạng thái</dt>
                <dd class="col-sm-9">
                    @if(Model.ParentUser.IsActive)
                    {
                        <span class="badge bg-success">Hoạt động</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Khóa</span>
                    }
                </dd>

                <dt class="col-sm-3">Ngày tham gia</dt>
                <dd class="col-sm-9">@Model.ParentUser.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
            </dl>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Danh sách học sinh (Con)</h5>
        </div>
        <div class="card-body">
            @if (Model.ParentUser.Students != null && Model.ParentUser.Students.Any())
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Họ Tên Học Sinh</th>
                            <th>Ngày Sinh</th>
                            <th>Giới Tính</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var student in Model.ParentUser.Students)
                        {
                            <tr>
                                <td>@student.Id</td>
                                <td>@student.FullName</td>
                                <td>@(student.DateOfBirth?.ToString("dd/MM/yyyy") ?? "N/A")</td>
                                <td>@student.Gender</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted">Chưa có thông tin học sinh nào được liên kết với phụ huynh này.</p>
            }
        </div>
    </div>

    <div class="mt-3">
        <a asp-page="./Index" class="btn btn-secondary">Quay lại danh sách</a>
    </div>
</div>
