@page
@model PROJECT_PRN232_.Pages.Center.Students.CreateModel

@{
    ViewData["Title"] = "Thêm Học Sinh";
}

<div class="container mt-4">
    <h2>Thêm Học sinh mới</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group mb-3">
                    <label asp-for="Input.ParentId" class="form-label"></label>
                    <select asp-for="Input.ParentId" class="form-select" asp-items="Model.ParentList">
                        <option value="">-- Chọn phụ huynh --</option>
                    </select>
                    <span asp-validation-for="Input.ParentId" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Input.FullName" class="form-label"></label>
                    <input asp-for="Input.FullName" class="form-control" />
                    <span asp-validation-for="Input.FullName" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Input.DateOfBirth" class="form-label"></label>
                    <input asp-for="Input.DateOfBirth" class="form-control" type="date" />
                    <span asp-validation-for="Input.DateOfBirth" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Input.Gender" class="form-label"></label>
                    <select asp-for="Input.Gender" class="form-select">
                        <option value="">-- Chọn giới tính --</option>
                        <option value="Male">Nam</option>
                        <option value="Female">Nữ</option>
                        <option value="Other">Khác</option>
                    </select>
                    <span asp-validation-for="Input.Gender" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">Tạo học sinh</button>
                <a asp-page="./Index" class="btn btn-secondary ms-2">Trở về</a>
            </form>
        </div>
    </div>
</div>
