@page "{id:int}"
@model PROJECT_PRN232_.Pages.Center.Students.DetailsModel

@{
    ViewData["Title"] = "Hồ sơ Học sinh";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Hồ sơ Học sinh</h2>
        <div>
            <a asp-page="./Edit" asp-route-id="@Model.Student.Id" class="btn btn-warning text-white">Sửa</a>
            <a asp-page="./Index" class="btn btn-secondary">Trở về</a>
        </div>
    </div>
    
    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="card-title mb-0">Thông tin cá nhân</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">ID</dt>
                        <dd class="col-sm-8">@Model.Student.Id</dd>

                        <dt class="col-sm-4">Họ và Tên</dt>
                        <dd class="col-sm-8 fw-bold">@Model.Student.FullName</dd>

                        <dt class="col-sm-4">Ngày sinh</dt>
                        <dd class="col-sm-8">@(Model.Student.DateOfBirth.HasValue ? Model.Student.DateOfBirth.Value.ToString("dd/MM/yyyy") : "Chưa cập nhật")</dd>

                        <dt class="col-sm-4">Giới tính</dt>
                        <dd class="col-sm-8">@(Model.Student.Gender == "Male" ? "Nam" : (Model.Student.Gender == "Female" ? "Nữ" : "Khác"))</dd>

                        <dt class="col-sm-4">Ngày tạo</dt>
                        <dd class="col-sm-8">@Model.Student.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
                    </dl>
                </div>
            </div>
        </div>
        
        <div class="col-md-6">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0">Thông tin Phụ huynh</h5>
                </div>
                <div class="card-body">
                    @if (Model.Student.Parent != null)
                    {
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Họ và Tên</dt>
                            <dd class="col-sm-8">@Model.Student.Parent.FullName</dd>

                            <dt class="col-sm-4">Số điện thoại</dt>
                            <dd class="col-sm-8">@Model.Student.Parent.Phone</dd>

                            <dt class="col-sm-4">Email</dt>
                            <dd class="col-sm-8">@Model.Student.Parent.Email</dd>
                            
                            <dt class="col-sm-4"></dt>
                            <dd class="col-sm-8 mt-2">
                                <a asp-page="/Center/Parents/Details" asp-route-id="@Model.Student.ParentId" class="btn btn-sm btn-outline-primary">Xem hồ sơ phụ huynh</a>
                            </dd>
                        </dl>
                    }
                    else
                    {
                        <p class="text-muted mb-0">Không tìm thấy thông tin phụ huynh.</p>
                    }
                </div>
            </div>
            
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h5 class="card-title mb-0">Lớp học đang tham gia</h5>
                </div>
                <div class="card-body">
                    @if (Model.Student.ClassStudents != null && Model.Student.ClassStudents.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var cs in Model.Student.ClassStudents)
                            {
                                <li class="list-group-item px-0">
                                    <strong>@cs.Class?.ClassName</strong> 
                                    @if(cs.Class != null)
                                    {
                                        <span class="badge bg-secondary rounded-pill ms-2">@cs.Class.Status</span>
                                    }
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted mb-0">Học sinh chưa tham gia lớp học nào.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
