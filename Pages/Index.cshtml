@page
@model PROJECT_PRN232_.Pages.IndexModel
@{
    ViewData["Title"] = "Trang Chủ";
}

<div class="fade-in">
    <!-- Hero Section with Animated Background -->
    <div class="position-relative overflow-hidden py-5 mb-5 rounded-5 shadow-lg" style="background: linear-gradient(135deg, #1e1b4b 0%, #312e81 50%, #4f46e5 100%);">
        <!-- Decorative background glow -->
        <div class="position-absolute top-0 start-0 w-100 h-100 opacity-25" style="background: radial-gradient(circle at 80% 20%, #818cf8 0%, transparent 60%); pointer-events: none;"></div>
        
        <div class="container position-relative py-5 px-4 z-1 text-center text-white">
            <span class="badge bg-indigo text-white px-3 py-2 rounded-pill mb-3 small fw-bold" style="background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.25);">
                🚀 EduBridge v2.0 - Kỷ Nguyên Quản Lý Mới
            </span>
            <h1 class="display-3 fw-extrabold mb-3 text-white tracking-tight" style="font-weight: 800; text-shadow: 0 4px 12px rgba(0,0,0,0.15); font-family: var(--eb-font);">
                Cầu Nối Giáo Dục <span style="background: linear-gradient(to right, #c7d2fe, #818cf8, #a5b4fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Thông Minh</span>
            </h1>
            <p class="lead text-white-50 mx-auto mb-4" style="max-width: 650px; font-size: 1.15rem; font-weight: 500;">
                Hệ thống quản lý học tập, liên lạc real-time và đồng hành cùng tiến trình giáo dục của học viên một cách nhanh chóng, minh bạch và hiệu quả nhất.
            </p>
            
            <div class="d-flex justify-content-center gap-3">
                @if (User.Identity.IsAuthenticated)
                {
                    <a href="/Center/Dashboard" class="btn btn-light btn-lg px-4 py-2.5 rounded-pill fw-bold shadow text-primary hover-lift">
                        <i class="bi bi-speedometer2 me-2"></i>Truy cập Dashboard
                    </a>
                }
                else
                {
                    <a href="/Auth/Login" class="btn btn-light btn-lg px-4 py-2.5 rounded-pill fw-bold shadow text-primary hover-lift">
                        Đăng Nhập Ngay <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                }
            </div>
        </div>
    </div>

    <!-- Features Section -->
    <div class="container py-4">
        <div class="text-center mb-5">
            <h2 class="fw-bold text-dark mb-2" style="font-family: var(--eb-font);">Tính năng nổi bật của EduBridge</h2>
            <p class="text-muted">Trải nghiệm các phân hệ quản lý thông minh được thiết kế tối ưu nhất cho Trung tâm & Phụ huynh</p>
        </div>
        
        <div class="row g-4">
            <!-- Feature 1 -->
            <div class="col-md-4">
                <div class="card h-100 border-0 p-4 rounded-4 hover-card" style="box-shadow: 0 10px 30px rgba(79, 70, 229, 0.05); transition: all 0.3s;">
                    <div class="card-body d-flex flex-column align-items-center text-center">
                        <div class="feature-icon mb-4 d-flex align-items-center justify-content-center rounded-circle" style="width: 70px; height: 70px; background: rgba(79, 70, 229, 0.1); color: #4F46E5;">
                            <i class="bi bi-broadcast fs-2"></i>
                        </div>
                        <h4 class="fw-bold mb-3" style="color: var(--eb-text-heading);">Phát sóng thông báo</h4>
                        <p class="text-muted small mb-0">Tự động gom nhóm giáo án, bài tập, học liệu đính kèm thành một bản tin duy nhất gửi tức thời đến phụ huynh qua SignalR.</p>
                    </div>
                </div>
            </div>

            <!-- Feature 2 -->
            <div class="col-md-4">
                <div class="card h-100 border-0 p-4 rounded-4 hover-card" style="box-shadow: 0 10px 30px rgba(79, 70, 229, 0.05); transition: all 0.3s;">
                    <div class="card-body d-flex flex-column align-items-center text-center">
                        <div class="feature-icon mb-4 d-flex align-items-center justify-content-center rounded-circle" style="width: 70px; height: 70px; background: rgba(16, 185, 129, 0.1); color: #10B981;">
                            <i class="bi bi-chat-dots-fill fs-2"></i>
                        </div>
                        <h4 class="fw-bold mb-3" style="color: var(--eb-text-heading);">Chat Real-time</h4>
                        <p class="text-muted small mb-0">Kênh liên lạc trực tiếp hai chiều, bảo mật giữa Giáo viên/Trung tâm và Phụ huynh, hỗ trợ đắc lực trong việc cập nhật tình hình học tập.</p>
                    </div>
                </div>
            </div>

            <!-- Feature 3 -->
            <div class="col-md-4">
                <div class="card h-100 border-0 p-4 rounded-4 hover-card" style="box-shadow: 0 10px 30px rgba(79, 70, 229, 0.05); transition: all 0.3s;">
                    <div class="card-body d-flex flex-column align-items-center text-center">
                        <div class="feature-icon mb-4 d-flex align-items-center justify-content-center rounded-circle" style="width: 70px; height: 70px; background: rgba(245, 158, 11, 0.1); color: #F59E0B;">
                            <i class="bi bi-calendar-check fs-2"></i>
                        </div>
                        <h4 class="fw-bold mb-3" style="color: var(--eb-text-heading);">Số hóa điểm danh</h4>
                        <p class="text-muted small mb-0">Điểm danh điện tử tức thời, cập nhật điểm kiểm tra, nhận xét chi tiết của giáo viên gửi trực tiếp tới máy phụ huynh sau mỗi buổi học.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-lift {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .hover-lift:hover {
        transform: translateY(-2px) !important;
        box-shadow: 0 10px 20px rgba(255, 255, 255, 0.2) !important;
    }
</style>
